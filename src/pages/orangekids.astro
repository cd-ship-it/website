---
import { getEntry, getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import LocalizedInline from "../components/UI/LocalizedInline.astro";
import { filterCampusesForOrangeKids } from "../config/site";

const page = await getEntry("pages", "orange-kids");
if (!page) throw new Error('Content entry "pages/orange-kids" not found.');
const {
  title,
  seo,
  pageHeader,
  heroImage,
  missionStatement,
  coreCommitment,
  pillars,
  sundayMorning,
  contactPhone,
} = page.data;

// Pull service times for all campuses from service-times.md
const siteInfoEntries = await getCollection("siteInfo");
const serviceTimesEntry = siteInfoEntries.find((e) => e.slug === "service-times");
const campuses = serviceTimesEntry?.data.campuses ?? [];
const orangeKidsCampuses = filterCampusesForOrangeKids(campuses);

// Icon paths for the three pillars
const pillarIcons: Record<string, string> = {
  faith: `<svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-secondary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>`,
  family: `<svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-secondary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>`,
  fun: `<svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-secondary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
};

const titleEn = typeof title === "string" ? title : title.en;
const headerBg = pageHeader?.backgroundImage ?? "/uploads/page-header-bg.webp";
const headerTitle = pageHeader?.title
  ? (typeof pageHeader.title === "string" ? pageHeader.title : pageHeader.title.en)
  : titleEn;
const headerSubtitle = pageHeader?.subtitle
  ? (typeof pageHeader.subtitle === "string" ? pageHeader.subtitle : pageHeader.subtitle.en)
  : undefined;
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  image={heroImage ? { url: heroImage.src, alt: typeof heroImage.alt === "string" ? heroImage.alt : heroImage.alt.en } : undefined}
>
  <!-- ── Page Header ─────────────────────────────────────────────────────── -->
  <section
    class="relative py-24 md:py-32 bg-cover bg-center"
    style={`background-image: linear-gradient(rgba(26,20,16,0.55) 0%, rgba(26,20,16,0.80) 100%), url(${headerBg})`}
  >
    <div class="container">
      <div class="max-w-2xl">
        <h1 class="font-serif font-bold text-white mb-4 leading-tight" style="font-size: clamp(2rem, 5vw, 3.5rem);">
          <LocalizedInline value={title} />
        </h1>
        {pageHeader?.subtitle && (
          <p class="text-white/75 text-lg leading-relaxed">
            <LocalizedInline value={pageHeader.subtitle} />
          </p>
        )}
      </div>
    </div>
  </section>

  <!-- ── Mission Statement ──────────────────────────────────────────────── -->
  {missionStatement && (
    <section class="py-16">
      <div class="container">
        <div class="max-w-3xl mx-auto text-center">
          {heroImage && (
            <img
              src={heroImage.src}
              alt={typeof heroImage.alt === "string" ? heroImage.alt : heroImage.alt.en}
              class="w-45 h-40 object-cover rounded-full mx-auto mb-8 shadow-md"
            />
          )}
          {/* <h2 class="text-3xl md:text-4xl font-bold mb-6">
            <LocalizedInline value={title} />
          </h2> */}
          <p class="text-xl text-ink-3 leading-relaxed mb-6">
            <LocalizedInline value={missionStatement} />
          </p>
          {coreCommitment && (
            <p class="text-lg text-ink-3 leading-relaxed">
              <LocalizedInline value={coreCommitment} />
            </p>
          )}
        </div>
      </div>
    </section>
  )}

  <!-- ── Three Pillars ──────────────────────────────────────────────────── -->
  {pillars && pillars.length > 0 && (
    <section class="py-16 bg-cream">
      <div class="container">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
          {pillars.map((pillar) => (
            <div class="bg-white p-8 rounded-lg shadow-sm text-center">
              <div class="w-20 h-20 mx-auto mb-4 rounded-full bg-secondary-100 flex items-center justify-center"
                set:html={pillarIcons[pillar.icon] ?? pillarIcons.faith}
              />
              <h3 class="text-xl font-bold mb-3">
                <LocalizedInline value={pillar.title} />
              </h3>
              <p class="text-ink-3">
                <LocalizedInline value={pillar.description} />
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ── Sunday Morning Program ─────────────────────────────────────────── -->
  {sundayMorning && (
    <section class="py-16">
      <div class="container">
        <div class="max-w-5xl mx-auto">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">

            <!-- Text content -->
            <div>
              <p class="text-sm font-semibold tracking-widest uppercase text-secondary-600 mb-2">
                <LocalizedInline value={sundayMorning.heading} />
              </p>
              <h2 class="text-3xl md:text-4xl font-bold mb-6">
                <LocalizedInline value={{ en: "What Your Kids Will Discover", "zh-Hant": "孩子將學到什麼", "zh-Hans": "孩子将学到什么" }} />
              </h2>
              <p class="text-lg text-ink-3 mb-6">
                <LocalizedInline value={sundayMorning.description} />
              </p>

              <ul class="space-y-4 mb-6">
                {sundayMorning.keyPoints.map((point) => (
                  <li class="flex items-start gap-3">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-secondary-600 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    <span class="text-ink-3 text-lg">
                      <LocalizedInline value={point} />
                    </span>
                  </li>
                ))}
              </ul>

              {sundayMorning.childcareNote && (
                <div class="bg-cream-2 rounded-lg px-5 py-4 text-ink-3">
                  <LocalizedInline value={sundayMorning.childcareNote} />
                </div>
              )}
            </div>

            <!-- Image -->
            {sundayMorning.image && (
              <div class="rounded-xl overflow-hidden shadow-md">
                <img
                  src={sundayMorning.image.src}
                  alt={typeof sundayMorning.image.alt === "string" ? sundayMorning.image.alt : sundayMorning.image.alt.en}
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
              </div>
            )}

          </div>
        </div>
      </div>
    </section>
  )}

  <!-- ── Campus Schedule ────────────────────────────────────────────────── -->
  {orangeKidsCampuses.length > 0 && (
    <section class="py-16 bg-cream">
      <div class="container">
        <div class="text-center mb-12">
          {/* <h2 class="text-3xl md:text-4xl font-bold mb-4">
            <LocalizedInline value={{ en: "Find Us at Your Campus", "zh-Hant": "在您附近的會堂找到我們", "zh-Hans": "在您附近的会堂找到我们" }} />
          </h2> */}
          <p class="text-xl text-muted max-w-3xl mx-auto">
            <LocalizedInline value={{ en: "Orange Kids is available at the following Crosspoint campuses during Sunday worship services.", 
            "zh-Hant": "Orange Kids 在匯點教會以下會堂的主日崇拜期間均有提供。", "zh-Hans": "Orange Kids 在汇点教会各会堂的主日崇拜期间均有提供。" }} />
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
          {orangeKidsCampuses.map((campus) => (
            <div class="bg-white p-6 rounded-lg shadow-sm">
              <div class="flex items-center gap-3 mb-4">
                <span class="inline-block px-2 py-0.5 bg-secondary-100 text-secondary-800 text-xs font-semibold rounded-full uppercase tracking-wide">
                  <LocalizedInline value={campus.worshipDate} />
                </span>
                <h3 class="font-bold text-lg">
                  <LocalizedInline value={campus.campusName} />
                </h3>
              </div>
              <ul class="space-y-2">
                {campus.services.map((service) => (
                  <li class="flex items-center gap-2 text-ink-3">
                    <svg class="h-4 w-4 text-secondary-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <span class="text-sm"><LocalizedInline value={service} /></span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ── Contact CTA ────────────────────────────────────────────────────── -->
  <!-- <section
    class="py-20 bg-cover bg-center text-white"
    style={`background-image: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url(${headerBg})`}
  >
    <div class="container">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold mb-6 text-white">
          <LocalizedInline value={{ en: "Questions? We'd Love to Help.", "zh-Hant": "有問題嗎？我們很樂意幫助您。", "zh-Hans": "有问题吗？我们很乐意帮助您。" }} />
        </h2>
        <p class="text-xl mb-8">
          <LocalizedInline value={{ en: "Reach out to our team and we'll connect you with the right campus.", "zh-Hant": "聯繫我們的團隊，我們將為您聯絡最近的會堂。", "zh-Hans": "联系我们的团队，我们将为您联络最近的会堂。" }} />
        </p>
        <div class="flex flex-wrap justify-center gap-4">

          <a href="/contact" class="btn btn-ghost-white">
            <LocalizedInline value={{ en: "Contact Us", "zh-Hant": "聯絡我們", "zh-Hans": "联络我们" }} />
          </a>
        </div>
      </div>
    </div>
  </section> -->
</BaseLayout>
