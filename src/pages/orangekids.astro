---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import LocalizedInline from "../components/UI/LocalizedInline.astro";
import { filterCampusesForOrangeKids } from "../config/site";

const page = (await getCollection("pages")).find(
  (entry) =>
    entry.data.pageKind === "orange-kids" ||
    entry.id === "orange-kids" ||
    entry.slug === "orange-kids" ||
    entry.id === "orangekids" ||
    entry.slug === "orangekids",
);

if (!page || page.data.pageKind !== "orange-kids") {
  throw new Error('Content entry "pages/orange-kids" not found or wrong pageKind.');
}
const {
  title,
  seo,
  pageHeader,
  heroImage,
  missionStatement,
  coreCommitment,
  pillars,
  sundayMorning,
  contactPhone,
} = page.data;

// Pull service times for all campuses from service-times.md
const siteInfoEntries = await getCollection("siteInfo");
const serviceTimesEntry = siteInfoEntries.find((e) => e.slug === "service-times");
const campuses = serviceTimesEntry?.data.campuses ?? [];
const orangeKidsCampuses = filterCampusesForOrangeKids(campuses);

const pillarIcons: Record<string, string> = {
  faith: `<svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>`,
  family: `<svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>`,
  fun: `<svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
};
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  image={heroImage ? { url: heroImage.src, alt: typeof heroImage.alt === "string" ? heroImage.alt : heroImage.alt.en } : undefined}
>
  <!-- ── Orange Page Header ───────────────────────────────────────────────── -->
  <section
    class="relative py-16 md:py-20 overflow-hidden"
    style="background: linear-gradient(135deg, #D4820A 0%, #E8961F 45%, #F59E0B 100%);"
  >
    <!-- Dot-grid texture -->
    <div
      class="absolute inset-0 pointer-events-none"
      style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.18) 1px, transparent 0); background-size: 24px 24px;"
    ></div>
    <!-- Decorative circles -->
    <div class="absolute -right-16 -top-16 w-72 h-72 rounded-full bg-white/10 pointer-events-none"></div>
    <div class="absolute right-32 bottom-0 w-36 h-36 rounded-full bg-white/08 pointer-events-none"></div>
    <div class="absolute -left-8 bottom-4 w-48 h-48 rounded-full bg-black/05 pointer-events-none"></div>

    <div class="container relative z-10">
      <div class="max-w-2xl">
        <p class="text-white/75 text-xs font-bold tracking-[0.22em] uppercase mb-3">For Kids · 兒童事工</p>
        <h1 class="font-serif font-bold text-white mb-3 leading-tight text-page-title">
          <LocalizedInline value={title} />
        </h1>
        {pageHeader?.subtitle && (
          <p class="text-white/85 text-lg leading-relaxed">
            <LocalizedInline value={pageHeader.subtitle} />
          </p>
        )}
      </div>
    </div>
  </section>

  <!-- ── Mission Statement ──────────────────────────────────────────────── -->
  {missionStatement && (
    <section class="py-16 bg-white">
      <div class="container">
        <div class="max-w-3xl mx-auto text-center">
          {heroImage && (
            <img
              src={heroImage.src}
              alt={typeof heroImage.alt === "string" ? heroImage.alt : heroImage.alt.en}
              class="w-40 h-40 object-cover rounded-full mx-auto mb-8 shadow-lg ring-4 ring-secondary-200"
            />
          )}
          <p class="body-copy text-xl mb-6">
            <LocalizedInline value={missionStatement} />
          </p>
          {coreCommitment && (
            <p class="body-copy text-lg text-muted">
              <LocalizedInline value={coreCommitment} />
            </p>
          )}
        </div>
      </div>
    </section>
  )}

  <!-- ── Three Pillars ──────────────────────────────────────────────────── -->
  {pillars && pillars.length > 0 && (
    <section class="py-16" style="background: #FFF7ED;">
      <div class="container">
        <div class="text-center mb-10">
          <p class="text-secondary-600 text-xs font-bold tracking-[0.2em] uppercase mb-2">What We Believe</p>
          <h2 class="text-3xl font-bold text-heading">Our Commitments</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
          {pillars.map((pillar) => (
            <div class="bg-white rounded-2xl p-8 text-center shadow-sm border border-secondary-100">
              <div
                class="w-20 h-20 mx-auto mb-4 rounded-full flex items-center justify-center"
                style="background: linear-gradient(135deg, #E8961F, #F59E0B);"
                set:html={pillarIcons[pillar.icon] ?? pillarIcons.faith}
              />
              <h3 class="text-xl font-bold mb-3 text-heading">
                <LocalizedInline value={pillar.title} />
              </h3>
              <p class="body-copy text-muted">
                <LocalizedInline value={pillar.description} />
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ── Sunday Morning Program ─────────────────────────────────────────── -->
  {sundayMorning && (
    <section class="py-16 bg-white">
      <div class="container">
        <div class="max-w-5xl mx-auto">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">

            <div>
              <p class="text-secondary-600 text-sm font-bold tracking-widest uppercase mb-2">
                <LocalizedInline value={sundayMorning.heading} />
              </p>
              <h2 class="text-3xl md:text-4xl font-bold mb-6 text-heading">
                <LocalizedInline value={{ en: "What Your Kids Will Discover", "zh-Hant": "孩子將學到什麼", "zh-Hans": "孩子将学到什么" }} />
              </h2>
              <p class="body-copy text-lg mb-6">
                <LocalizedInline value={sundayMorning.description} />
              </p>

              <ul class="space-y-4 mb-6">
                {sundayMorning.keyPoints.map((point) => (
                  <li class="flex items-start gap-3">
                    <div class="mt-1 shrink-0 w-5 h-5 rounded-full flex items-center justify-center" style="background: #E8961F;">
                      <svg class="h-3 w-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                      </svg>
                    </div>
                    <span class="body-copy text-lg mb-0 flex-1">
                      <LocalizedInline value={point} />
                    </span>
                  </li>
                ))}
              </ul>

              {sundayMorning.childcareNote && (
                <div class="rounded-xl px-5 py-4 body-copy mb-0 border border-secondary-200" style="background: #FFF7ED;">
                  <LocalizedInline value={sundayMorning.childcareNote} />
                </div>
              )}
            </div>

            {sundayMorning.image && (
              <div class="rounded-2xl overflow-hidden shadow-lg">
                <img
                  src={sundayMorning.image.src}
                  alt={typeof sundayMorning.image.alt === "string" ? sundayMorning.image.alt : sundayMorning.image.alt.en}
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
              </div>
            )}

          </div>
        </div>
      </div>
    </section>
  )}

  <!-- ── Campus Schedule ────────────────────────────────────────────────── -->
  {orangeKidsCampuses.length > 0 && (
    <section class="py-16" style="background: #FFF7ED;">
      <div class="container">
        <div class="text-center mb-10">
          <p class="text-secondary-600 text-xs font-bold tracking-[0.2em] uppercase mb-2">Join Us</p>
          <h2 class="text-3xl font-bold text-heading mb-3">Find Us at Your Campus</h2>
          <p class="text-muted max-w-2xl mx-auto">
            <LocalizedInline value={{ en: "Orange Kids is available at the following Crosspoint campuses during Sunday worship services.",
            "zh-Hant": "Orange Kids 在匯點教會以下會堂的主日崇拜期間均有提供。", "zh-Hans": "Orange Kids 在汇点教会各会堂的主日崇拜期间均有提供。" }} />
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
          {orangeKidsCampuses.map((campus) => (
            <div class="bg-white rounded-2xl p-6 shadow-sm border border-secondary-100">
              <div class="flex items-center gap-3 mb-4">
                <span class="inline-block px-2.5 py-0.5 text-white text-xs font-bold rounded-full uppercase tracking-wide" style="background: #E8961F;">
                  <LocalizedInline value={campus.worshipDate} />
                </span>
                <h3 class="font-bold text-lg text-heading">
                  <LocalizedInline value={campus.campusName} />
                </h3>
              </div>
              <ul class="space-y-2">
                {campus.services.map((service) => (
                  <li class="flex items-center gap-2 body-copy mb-0">
                    <svg class="h-4 w-4 shrink-0" style="color: #E8961F;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <span class="text-sm text-ink-3"><LocalizedInline value={service} /></span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
