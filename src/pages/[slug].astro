---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/Sections/PageHeader.astro";
import { WP_DYNAMIC_PAGES, getWpDynamicPageConfig } from "../config/wpDynamicPages";
import { getWordPressUrl } from "../config/site";
import { fetchCategoryLatestPostLinkPreview } from "../lib/wpLinkPreview";
import {
  fetchWpDynamicPageRecord,
  shouldShowWpDynamicPostTitle,
  type WpMirrorItem,
  wpMirrorDisplayDates,
} from "../lib/wordpress/mirror";

export function getStaticPaths() {
  return WP_DYNAMIC_PAGES.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const cfg = slug ? getWpDynamicPageConfig(slug) : undefined;

if (!cfg) {
  return new Response("Not Found", {
    status: 404,
    headers: { "Content-Type": "text/plain; charset=utf-8" },
  });
}

const wpBaseUrl = getWordPressUrl();

const heartFallbackImage = {
  url: `${import.meta.env.BASE_URL}uploads/blog-header-bg.webp`,
  alt: "Heart of a Shepherd — Crosspoint Church",
};

let layoutTitle = cfg.seo.title;
let layoutDescription = cfg.seo.description;
let layoutImage = heartFallbackImage;
let layoutType: "website" | "article" = "website";
let record: WpMirrorItem | null = null;

if (cfg.kind === "wordpress_category_latest_post" && wpBaseUrl && cfg.wpCategorySlug) {
  try {
    const preview = await fetchCategoryLatestPostLinkPreview(wpBaseUrl, cfg.wpCategorySlug, {
      title: cfg.seo.title,
      description: cfg.seo.description,
      image: heartFallbackImage,
    });
    if (preview) {
      layoutTitle = preview.title;
      layoutDescription = preview.description;
      layoutImage = preview.image;
      layoutType = "article";
    }
  } catch {
    /* build-time fetch unavailable or network error — keep static SEO from config */
  }
}

if (wpBaseUrl) {
  record = await fetchWpDynamicPageRecord(cfg);
}

const { dateIso, dateLong } = wpMirrorDisplayDates(record);
const showPostTitle = shouldShowWpDynamicPostTitle(cfg, record);
---

<BaseLayout
  title={layoutTitle}
  description={layoutDescription}
  image={layoutImage}
  type={layoutType}
>
  <PageHeader
    title={cfg.pageHeader.title}
    subtitle={cfg.pageHeader.subtitle}
    backgroundImage={`${import.meta.env.BASE_URL}uploads/blog-header-bg.webp`}
  />

  <section class="py-16 bg-white">
    <div class="container max-w-4xl">
      {!wpBaseUrl ? (
        <div class="xp-panel-inner bg-red-50 p-6 text-red-700">
          <p>
            WordPress URL is not configured. Set <code class="text-sm">PUBLIC_WORDPRESS_URL</code>{" "}
            in your environment.
          </p>
        </div>
      ) : !record ? (
        <div class="xp-panel-inner bg-red-50 p-6 text-red-700">
          <p>No published content found yet.</p>
        </div>
      ) : (
        <article class="xp-panel-inner bg-white p-6 md:p-8">
          {dateIso && dateLong && (
            <p class="text-sm text-muted mb-3">
              <time datetime={dateIso}>{dateLong}</time>
            </p>
          )}

          {showPostTitle && (
            <h1 class="text-3xl md:text-4xl font-bold mb-6" set:html={record.title?.rendered ?? ""} />
          )}

          <div class="prose prose-lg max-w-none" set:html={record.content?.rendered ?? ""} />
          {record.link && (
            <p class="mt-8">
              <a
                href={record.link}
                target="_blank"
                rel="noopener noreferrer"
                class="text-primary-600 font-medium hover:underline"
              >
                View on WordPress →
              </a>
            </p>
          )}
        </article>
      )}
    </div>
  </section>
</BaseLayout>
