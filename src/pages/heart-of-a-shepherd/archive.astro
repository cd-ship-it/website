---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/Sections/PageHeader.astro";
import { withBaseUrl } from "../../lib/urls";
import { fetchAllHeartOfShepherdPosts } from "../../lib/heartOfShepherdApi";

const posts = await fetchAllHeartOfShepherdPosts();

const cardPosts = posts.map((post) => ({
  routeSlug: post.routeSlug,
  title: post.title || "Untitled",
  date: post.date,
  summary: ((post.excerpt || "").trim().slice(0, 20) || "No summary") + ((post.excerpt || "").trim().length > 20 ? "..." : ""),
}));
---

<BaseLayout
  title="Heart of a Shepherd Archive - Crosspoint Church"
  description="Browse previous Heart of a Shepherd issues."
>
  <PageHeader
    title="Heart of a Shepherd"
    subtitle="Previous Issues"
    backgroundImage={`${withBaseUrl("/uploads/blog-header-bg.webp")}`}
  />

  <section class="py-16" data-heart-archive-root data-posts={JSON.stringify(cardPosts)}>
    <div class="container">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold">Previous Issues</h2>
      </div>

      <div id="heart-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"></div>

      <div id="heart-empty" class="hidden text-center py-16 bg-cream rounded-lg">
        <p class="text-muted text-lg">No previous issues found.</p>
      </div>

      <div id="heart-pagination" class="hidden mt-10 flex items-center justify-center gap-2">
        <button id="heart-prev-page" class="px-4 py-2 text-sm font-medium text-ink-3 bg-white border border-gray-300 rounded-md hover:bg-cream disabled:opacity-40 disabled:cursor-not-allowed transition-colors">
          ← Previous
        </button>
        <span id="heart-page-info" class="px-4 py-2 text-sm text-muted"></span>
        <button id="heart-next-page" class="px-4 py-2 text-sm font-medium text-ink-3 bg-white border border-gray-300 rounded-md hover:bg-cream disabled:opacity-40 disabled:cursor-not-allowed transition-colors">
          Next →
        </button>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const root = document.querySelector('[data-heart-archive-root]') as HTMLElement | null;
  const POSTS = JSON.parse(root?.dataset.posts ?? '[]');
  const BASE = import.meta.env.BASE_URL;
  const PER_PAGE = 10;
  let currentPage = 1;

  function esc(str: string) {
    return (str ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function formatDate(dateStr: string) {
    if (!dateStr) return '';
    return new Date(dateStr).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'short',
      day: 'numeric',
    });
  }

  function cardHtml(post: { routeSlug: string; title: string; date: string; summary: string }) {
    return `
      <a href="${BASE}heart-of-a-shepherd/${encodeURIComponent(post.routeSlug)}"
         class="xp-panel-inner group block bg-white hover:shadow-xl transition-all duration-300 border border-gray-100 hover:border-primary-200">
        <div class="p-5">
          <p class="text-sm text-muted mb-2">${esc(formatDate(post.date))}</p>
          <h3 class="text-lg font-bold leading-snug mb-3 line-clamp-3">${esc(post.title)}</h3>
          <p class="text-sm text-muted mb-4">${esc(post.summary)}</p>
          <p class="text-primary-600 font-medium text-sm group-hover:underline">Read issue →</p>
        </div>
      </a>
    `;
  }

  function render(page: number) {
    const grid = document.getElementById('heart-grid');
    const empty = document.getElementById('heart-empty');
    const pagination = document.getElementById('heart-pagination');
    const info = document.getElementById('heart-page-info');
    const prevBtn = document.getElementById('heart-prev-page') as HTMLButtonElement | null;
    const nextBtn = document.getElementById('heart-next-page') as HTMLButtonElement | null;
    if (!grid || !empty || !pagination || !info || !prevBtn || !nextBtn) return;

    if (!POSTS.length) {
      grid.innerHTML = '';
      empty.classList.remove('hidden');
      pagination.classList.add('hidden');
      return;
    }

    empty.classList.add('hidden');
    const totalPages = Math.max(1, Math.ceil(POSTS.length / PER_PAGE));
    const boundedPage = Math.min(Math.max(1, page), totalPages);
    currentPage = boundedPage;
    const start = (boundedPage - 1) * PER_PAGE;
    const rows = POSTS.slice(start, start + PER_PAGE);
    grid.innerHTML = rows.map(cardHtml).join('');

    if (totalPages > 1) {
      info.textContent = `Page ${boundedPage} of ${totalPages}`;
      prevBtn.disabled = boundedPage <= 1;
      nextBtn.disabled = boundedPage >= totalPages;
      pagination.classList.remove('hidden');
    } else {
      pagination.classList.add('hidden');
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    render(1);
    (document.getElementById('heart-prev-page') as HTMLButtonElement | null)?.addEventListener('click', () => render(currentPage - 1));
    (document.getElementById('heart-next-page') as HTMLButtonElement | null)?.addEventListener('click', () => {
      render(currentPage + 1);
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  });
</script>
