---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Search | Crosspoint Church"
  description="Search the Crosspoint Church website."
>
  <section class="search-page">
    <div class="container search-page__container">
      <h1 class="search-page__title">Search</h1>

 

      <div id="search-ui" class="search-page__ui">
        <pagefind-input id="search-input" debounce="150" autofocus></pagefind-input>
        <pagefind-summary></pagefind-summary>
        <pagefind-results hide-sub-results></pagefind-results>
      </div>
      <p id="search-ui-message" class="search-page__message" aria-live="polite"></p>
    </div>
  </section>

  <link rel="stylesheet" href="/pagefind/pagefind-component-ui.css" />
  <script is:inline type="module" src="/pagefind/pagefind-component-ui.js"></script>
  <script is:inline type="module">
    document.addEventListener("DOMContentLoaded", () => {
      const MIN_QUERY_LENGTH = 3;
      const message = document.getElementById("search-ui-message");
      const root = document.getElementById("search-ui");
      if (!root) return;

      const getInstance = () => {
        const manager = window.PagefindComponents?.getInstanceManager?.();
        return manager?.getInstance?.("default");
      };

      const runSearch = (term) => {
        if (typeof term !== "string" || term.trim().length < MIN_QUERY_LENGTH) return false;
        const instance = getInstance();
        if (!instance) return false;
        instance.triggerSearch(term.trim());
        return true;
      };

      const runSearchWhenReady = (term, retries = 20) => {
        if (runSearch(term) || retries <= 0) return;
        window.setTimeout(() => runSearchWhenReady(term, retries - 1), 100);
      };

      document.querySelectorAll("[data-search-example]").forEach((el) => {
        el.addEventListener("click", () => {
          const term = el.getAttribute("data-search-example");
          if (!term) return;
          runSearchWhenReady(term);
        });
      });

      const q = new URLSearchParams(window.location.search).get("q");
      if (q) {
        runSearchWhenReady(q);
      } else {
        const focusWhenReady = (retries = 20) => {
          const input = document.getElementById("search-input");
          if (input) {
            input.focus();
          } else if (retries > 0) {
            window.setTimeout(() => focusWhenReady(retries - 1), 100);
          }
        };
        focusWhenReady();
      }

      window.setTimeout(() => {
        if (!getInstance() && message) {
          message.textContent =
            "Search index is unavailable in development preview. Run a production build to enable search.";
        }
      }, 400);
    });
  </script>
</BaseLayout>

<style>
  .search-page {
    padding: 5rem 0 7rem;
  }

  .search-page__container {
    max-width: 56rem;
    margin: 0 auto;
    text-align: center;
  }

  .search-page__title {
    font-size: clamp(2.2rem, 4vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #0d2f4f;
  }

  .search-page__subtitle {
    margin-top: 0.75rem;
    color: #4b5563;
    font-size: 1.05rem;
  }

  .search-page__ui {
    margin-top: 2rem;
    text-align: left;
    --pf-text: #0d2f4f;
    --pf-background: #fff;
    --pf-border: #050505;
    --pf-border-focus: #f97316;
    --pf-font: inherit;
    --pf-input-height: 56px;
    --pf-input-font-size: 17px;
    --pf-border-radius: 9999px;
    --pf-result-title-font-size: 16px;
    --pf-result-excerpt-font-size: 14px;
    --pf-results-gap: 10px;
  }

  .search-page__ui pagefind-results {
    margin-top: 1rem;
  }

  .search-page__message {
    margin-top: 1rem;
    color: #6b7280;
    font-size: 0.95rem;
  }

  :global(pagefind-results mark) {
    background: #ffedd5;
    color: #9a3412;
  }
</style>
