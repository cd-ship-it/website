---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Search | Crosspoint Church"
  description="Search the Crosspoint Church website."
>
  <section class="search-page">
    <div class="container search-page__container">
      <h1 class="search-page__title">Search</h1>

 

      <div id="search-ui" class="search-page__ui"></div>
      <p id="search-ui-message" class="search-page__message" aria-live="polite"></p>
    </div>
  </section>

  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      const message = document.getElementById("search-ui-message");
      const root = document.getElementById("search-ui");
      if (!root) return;

      // Derive pagefind base from the actual page URL at runtime.
      // This works regardless of what subpath the site is deployed under (e.g. /v2/).
      // Page is always at [base]/search/, so strip 'search' to get [base]/.
      const segments = window.location.pathname.replace(/\/+$/, "").split("/");
      segments.pop(); // remove 'search'
      const pfBase = (segments.join("/") || "") + "/pagefind/";

      // Inject CSS
      const link = document.createElement("link");
      link.rel = "stylesheet";
      link.href = pfBase + "pagefind-ui.css";
      document.head.appendChild(link);

      // Inject JS, then initialise UI once loaded
      const script = document.createElement("script");
      script.src = pfBase + "pagefind-ui.js";
      script.onerror = () => {
        if (message) {
          message.textContent =
            "Search index is unavailable in development preview. Run a production build to enable search.";
        }
      };
      script.onload = () => {
        const PagefindCtor = window.pagefindUI || window.PagefindUI;
        if (!PagefindCtor) {
          if (message) message.textContent = "Search index failed to load.";
          return;
        }

        new PagefindCtor({
          element: "#search-ui",
          showSubResults: true,
          resetStyles: false,
        });

        const getSearchInput = () => root.querySelector(".pagefind-ui__search-input");

        const runSearch = (term) => {
          const input = getSearchInput();
          if (!(input instanceof HTMLInputElement)) return false;
          input.value = term;
          input.focus();
          input.dispatchEvent(new Event("input", { bubbles: true }));
          return true;
        };

        const runSearchWhenReady = (term, retries = 20) => {
          if (runSearch(term) || retries <= 0) return;
          window.setTimeout(() => runSearchWhenReady(term, retries - 1), 100);
        };

        document.querySelectorAll("[data-search-example]").forEach((el) => {
          el.addEventListener("click", () => {
            const term = el.getAttribute("data-search-example");
            if (!term) return;
            runSearchWhenReady(term);
          });
        });

        const q = new URLSearchParams(window.location.search).get("q");
        if (q) {
          runSearchWhenReady(q);
        } else {
          const focusWhenReady = (retries = 20) => {
            const input = getSearchInput();
            if (input instanceof HTMLInputElement) {
              input.focus();
            } else if (retries > 0) {
              window.setTimeout(() => focusWhenReady(retries - 1), 100);
            }
          };
          focusWhenReady();
        }
      };
      document.head.appendChild(script);
    });
  </script>
</BaseLayout>

<style>
  .search-page {
    padding: 5rem 0 7rem;
  }

  .search-page__container {
    max-width: 56rem;
    margin: 0 auto;
    text-align: center;
  }

  .search-page__title {
    font-size: clamp(2.2rem, 4vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #0d2f4f;
  }

  .search-page__subtitle {
    margin-top: 0.75rem;
    color: #4b5563;
    font-size: 1.05rem;
  }

  .search-page__ui {
    margin-top: 2rem;
    text-align: left;
  }

 

  .search-page__message {
    margin-top: 1rem;
    color: #6b7280;
    font-size: 0.95rem;
  }

  :global(.search-page .pagefind-ui) {
    --pagefind-ui-scale: 1;
    --pagefind-ui-primary: #f97316;
    --pagefind-ui-text: #0d2f4f;
    --pagefind-ui-background: #fff;
    --pagefind-ui-border: #050505;
    --pagefind-ui-tag: #f3f4f6;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 9999px;
    --pagefind-ui-image-border-radius: 0.75rem;
    --pagefind-ui-image-box-ratio: 3 / 2;
    --pagefind-ui-font: inherit;
  }

  :global(.search-page .pagefind-ui__search-input) {
    min-height: 3.5rem;
    padding-inline: 1.5rem;
    font-size: 1.05rem;
    border-width: 13px;
    border-color: #c2410c;
    background-color: #fff7ed;
  }

  :global(.search-page .pagefind-ui__search-input:focus) {
    border-color: #f97316;
    box-shadow: 0 0 0 4px rgba(249, 115, 22, 0.2);
  }

  :global(.search-page .pagefind-ui__result-title a) {
    color: #0d2f4f;
  }

  :global(.search-page .pagefind-ui__result-image) {
    display: none;
  }
</style>
