---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import LocalizedInline from "../components/UI/LocalizedInline.astro";

const entry = (await getCollection("pages")).find(
  (e) => e.data.pageKind === "our-season",
);

if (!entry || entry.data.pageKind !== "our-season") {
  throw new Error('Content entry "pages/our-season" not found or wrong pageKind.');
}

const {
  seo,
  heroGhost,
  heroTitle,
  heroSub,
  heroCta,
  openingQuote,
  reality,
  numbers,
  stayed,
  hardPart,
  ahead,
  finale,
} = entry.data;
---

<BaseLayout title={seo.title} description={seo.description}>

  <!-- Page-specific fonts. Rendered in body; browsers handle stylesheet links here fine. -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Cormorant:ital,wght@0,400;0,600;0,700;1,400;1,700&family=Barlow:wght@300;400;500;600&family=Barlow+Condensed:wght@600;700;800&display=swap"
    rel="stylesheet"
  />

  <div class="still-standing">

    <!-- HERO: meta is minimal, just year + name -->
    <section class="hero">
      <div class="hero-grid-bg"></div>
      <div class="hero-ghost" aria-hidden="true">{heroGhost}</div>
      <h1>
        <LocalizedInline value={heroTitle.line1} /><br />
        <em><LocalizedInline value={heroTitle.line2} /></em>
      </h1>
      <p class="hero-sub">
        <strong><LocalizedInline value={heroSub.lead} /></strong><br />
        <LocalizedInline value={heroSub.body} />
      </p>
      <div class="hero-cta">
        <a href={heroCta.primary.href} class="btn-primary">
          <LocalizedInline value={heroCta.primary.label} />
        </a>
        <a href={heroCta.secondary.href} class="btn-ghost">
          <LocalizedInline value={heroCta.secondary.label} />
        </a>
      </div>
    </section>

    <!-- QUOTE: large decorative opening mark, no label -->
    <div class="quote-band reveal">
      <blockquote>&ldquo;<LocalizedInline value={openingQuote.text} /></blockquote>
      <cite>{openingQuote.attribution}</cite>
    </div>

    <!-- REALITY: word-mark is tucked under the h2, not floating above -->
    <section id="reality" class="section-wrap reveal">
      <div class="ch" aria-hidden="true">{reality.chapterNumber}</div>
      <div class="max-w">
        <div class="reality-layout">
          <div class="reality-left">
            <h2><LocalizedInline value={reality.heading} /></h2>
            <span class="word-mark" style="margin-top:1rem;">
              <LocalizedInline value={reality.wordMark} />
            </span>
          </div>
          <div class="reality-right">
            {reality.paragraphs.map((p) => (
              <p><LocalizedInline value={p} /></p>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- NUMBERS: no label at all — numbers speak -->
    <div class="numbers-band reveal">
      <div class="numbers-grid">
        {numbers.map((n) => (
          <div class="number-cell">
            <div class="num-big">{n.value}</div>
            <div class="num-label"><LocalizedInline value={n.label} /></div>
          </div>
        ))}
      </div>
    </div>

    <!-- STAYED: headline does ALL the work, zero labeling -->
    <section class="section-wrap bg-dark reveal">
      <div class="max-w">
        <div class="stayed-layout">
          <div>
            <div class="stayed-h"><LocalizedInline value={stayed.heading} /></div>
          </div>
          <div class="stayed-body">
            <p><LocalizedInline value={stayed.body} /></p>
            <div class="scripture">
              &ldquo;<LocalizedInline value={stayed.scripture.text} />&rdquo;
              <cite>{stayed.scripture.citation}</cite>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- HARD PART: vertical text on the left edge, not an eyebrow -->
    <section class="section-wrap bg-mid reveal">
      <div class="max-w">
        <div class="hard-wrap">
          <div class="vert-label"><LocalizedInline value={hardPart.label} /></div>
          <div class="hard-copy">
            {hardPart.paragraphs.map((p) => (
              <p><LocalizedInline value={p} /></p>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- AHEAD: ghost chapter number, headline leads -->
    <section id="ahead" class="section-wrap reveal">
      <div class="ch" aria-hidden="true">{ahead.chapterNumber}</div>
      <div class="max-w">
        <div class="ahead-top">
          <div>
            <h2>
              {ahead.headingLines.map((line, idx) => (
                <>
                  {idx > 0 && <br />}
                  {line.style === "accent" ? (
                    <em><LocalizedInline value={line.text} /></em>
                  ) : (
                    <LocalizedInline value={line.text} />
                  )}
                </>
              ))}
            </h2>
          </div>
          <div class="ahead-body">
            <p><LocalizedInline value={ahead.body} /></p>
          </div>
        </div>
        <div class="milestones-grid">
          {ahead.milestones.map((m) => (
            <div class="ms-cell">
              <div class="ms-title"><LocalizedInline value={m.title} /></div>
              <div class="ms-body"><LocalizedInline value={m.body} /></div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FINAL -->
    <div class="final-band">
      <div class="final-h">
        {finale.lines.map((line, idx) => (
          <>
            {idx > 0 && <br />}
            <LocalizedInline value={line} />
          </>
        ))}
      </div>
      <p class="final-p"><LocalizedInline value={finale.body} /></p>
    </div>

  </div>

</BaseLayout>

<style is:global>
  /* ─────────────────────────────────────────────────────────────────
     "Still Standing" page — scoped under `.still-standing` so it
     doesn't leak into the rest of the site. Typography, colors, and
     component styles mirror the design mock exactly.
     ───────────────────────────────────────────────────────────────── */
  .still-standing {
    --ss-black:  #080808;
    --ss-dark:   #111111;
    --ss-mid:    #1A1A1A;
    --ss-border: #1E1E1E;
    --ss-gold:   #E09A0A;
    --ss-gold-lt:#F5C842;
    --ss-cream:  #F0E8D6;
    --ss-dim:    #706860;
    --ss-muted:  #3A3530;

    background: var(--ss-black);
    color: var(--ss-cream);
    font-family: 'Barlow', sans-serif;
    font-weight: 300;
    line-height: 1.7;
  }

  .still-standing *,
  .still-standing *::before,
  .still-standing *::after {
    box-sizing: border-box;
  }

  html:has(.still-standing) { scroll-behavior: smooth; }

  /* HERO */
  .still-standing .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 0 6vw 9vh;
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--ss-border);
  }

  .still-standing .hero-grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.016) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.016) 1px, transparent 1px);
    background-size: 80px 80px;
    pointer-events: none;
  }

  .still-standing .hero-ghost {
    position: absolute;
    right: 3vw;
    bottom: -2vh;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: clamp(160px, 28vw, 400px);
    line-height: 1;
    color: transparent;
    -webkit-text-stroke: 1px #1c1c1c;
    letter-spacing: -0.03em;
    pointer-events: none;
    user-select: none;
  }

  .still-standing .hero-meta {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2rem;
    position: relative;
    z-index: 1;
  }

  .still-standing .hero-meta-year {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: 13px;
    letter-spacing: 0.1em;
    color: var(--ss-gold);
  }

  .still-standing .hero-meta-rule {
    flex: 1;
    max-width: 3rem;
    height: 1px;
    background: var(--ss-gold);
    opacity: 0.5;
  }

  .still-standing .hero-meta-name {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ss-dim);
  }

  .still-standing .hero h1 {
    font-family: 'Cormorant', serif;
    font-weight: 700;
    font-size: clamp(60px, 10.5vw, 148px);
    line-height: 0.9;
    letter-spacing: -0.02em;
    position: relative;
    z-index: 1;
    max-width: 12ch;
    color: var(--ss-cream);
    margin: 0;
  }

  .still-standing .hero h1 em {
    font-style: italic;
    color: var(--ss-gold);
  }

  .still-standing .hero-sub {
    margin-top: 2rem;
    font-size: clamp(20px, 1.4vw, 19px);
    color: var(--ss);
    position: relative;
    z-index: 1;
    max-width: 40ch;
  }

  .still-standing .hero-sub strong {
    color: var(--ss-cream);
    font-weight: 500;
  }

  .still-standing .hero-cta {
    display: flex;
    gap: 1rem;
    margin-top: 2.5rem;
    position: relative;
    z-index: 1;
    flex-wrap: wrap;
  }

  .still-standing .btn-primary {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 0.85rem 2rem;
    background: var(--ss-gold);
    color: var(--ss-black);
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.2s;
    display: inline-block;
    border-radius: 0;
    box-shadow: none;
  }

  .still-standing .btn-primary:hover { background: var(--ss-gold-lt); }

  .still-standing .btn-ghost {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 0.85rem 2rem;
    background: transparent;
    color: var(--ss-cream);
    border: 1px solid var(--ss-border);
    cursor: pointer;
    text-decoration: none;
    transition: border-color 0.2s;
    display: inline-block;
    border-radius: 0;
  }

  .still-standing .btn-ghost:hover { border-color: #444; }

  /* SECTION WRAP */
  .still-standing .section-wrap {
    padding: 9vh 6vw;
    border-bottom: 1px solid var(--ss-border);
    position: relative;
    overflow: hidden;
  }

  .still-standing .section-wrap.bg-mid  { background: var(--ss-mid); }
  .still-standing .section-wrap.bg-dark { background: var(--ss-dark); }

  .still-standing .max-w { max-width: 1100px; margin: 0 auto; }

  /* Chapter number — floats top-right as a ghost */
  .still-standing .ch {
    position: absolute;
    top: 4vh;
    right: 5vw;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: clamp(80px, 12vw, 160px);
    line-height: 1;
    color: transparent;
    -webkit-text-stroke: 1px #1e1e1e;
    letter-spacing: -0.03em;
    pointer-events: none;
    user-select: none;
  }

  /* REALITY LAYOUT */
  .still-standing .reality-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8vw;
    align-items: center;
  }

  @media (max-width: 760px) {
    .still-standing .reality-layout { grid-template-columns: 1fr; }
  }

  .still-standing .reality-left h2 {
    font-family: 'Cormorant', serif;
    font-weight: 700;
    font-size: clamp(42px, 5.5vw, 76px);
    line-height: 1.0;
    letter-spacing: -0.02em;
    color: var(--ss-cream);
    margin: 0;
  }

  .still-standing .reality-left h2 em {
    font-style: italic;
    color: var(--ss-gold);
  }

  .still-standing .word-mark {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--ss-gold);
    display: block;
    margin-bottom: 0.9rem;
  }

  .still-standing .reality-right p {
    font-size: 20px;
    color: #fff;
    line-height: 1.85;
    margin: 0;
  }
  .still-standing .reality-right p + p { margin-top: 1.2em; }

  .still-standing .pull-stat {
    font-family: 'Cormorant', serif;
    font-size: clamp(20px, 2.8vw, 34px);
    font-style: italic;
    color: var(--ss-cream);
    border-left: 2px solid var(--ss-gold);
    padding-left: 1.5rem;
    margin: 2.5rem 0;
    line-height: 1.35;
  }

  /* NUMBERS BAND */
  .still-standing .numbers-band {
    background: var(--ss-gold);
    padding: 7vh 6vw;
    border-bottom: 1px solid #c48800;
  }

  .still-standing .numbers-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: rgba(0,0,0,0.12);
    border: 1px solid rgba(0,0,0,0.12);
    max-width: 900px;
    margin: 0 auto;
  }

  @media (max-width: 580px) {
    .still-standing .numbers-grid { grid-template-columns: 1fr; }
  }

  .still-standing .number-cell {
    background: var(--ss-gold);
    padding: 3rem 2.5rem;
    text-align: center;
    transition: background 0.2s;
  }

  .still-standing .number-cell:hover { background: var(--ss-gold-lt); }

  .still-standing .num-big {
    font-family: 'Cormorant', serif;
    font-weight: 700;
    font-size: clamp(60px, 8vw, 96px);
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--ss-black);
  }

  .still-standing .num-label {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(0,0,0,0.45);
    margin-top: 0.5rem;
  }

  /* QUOTE */
  .still-standing .quote-band {
    padding: 9vh 6vw;
    text-align: center;
    border-bottom: 1px solid var(--ss-border);
    position: relative;
    background: var(--ss-gold);
  }

  .still-standing .quote-band::before {
    content: '\201C';
    font-family: 'Cormorant', serif;
    font-weight: 700;
    font-size: 140px;
    line-height: 1;
    color: var(--ss-cream);
    position: absolute;
    top: 3vh;
    left: 50%;
    transform: translateX(-50%);
    pointer-events: none;
  }

  .still-standing .quote-band blockquote {
    font-family: 'Cormorant', serif;
    font-style: italic;
    font-size: clamp(22px, 3.2vw, 42px);
    line-height: 1.35;
    color: var(--ss-black);
    max-width: 22ch;
    margin: 0 auto 1.5rem;
    position: relative;
    z-index: 1;
  }

  .still-standing .quote-band cite {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--ss-black);
    font-style: normal;
  }

  /* HARD PART */
  .still-standing .hard-wrap {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 3.5rem;
    align-items: start;
  }

  @media (max-width: 640px) {
    .still-standing .hard-wrap { grid-template-columns: 1fr; }
    .still-standing .vert-label { display: none; }
  }

  .still-standing .vert-label {
    writing-mode: vertical-rl;
    text-orientation: mixed;
    transform: rotate(180deg);
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 18px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: orange;
    padding-top: 0.2rem;
    align-self: stretch;
    display: flex;
    align-items: center;
    border-right: 1px solid var(--ss-border);
    padding-right: 1.25rem;
  }

  .still-standing .hard-copy p {
    font-size: 20px;
    color: #fff;
    line-height: 1.85;
    margin: 0;
  }
  .still-standing .hard-copy p + p { margin-top: 1.2em; }

  /* LESSONS */
  .still-standing .lessons-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1px;
    background: #0f0f0f;
    border: 1px solid #0f0f0f;
    margin-top: 0;
  }

  .still-standing .lessons-intro { margin-bottom: 3rem; }

  .still-standing .lessons-intro h2 {
    font-family: 'Cormorant', serif;
    font-weight: 700;
    font-size: clamp(34px, 4vw, 54px);
    line-height: 1.0;
    letter-spacing: -0.02em;
    color: var(--ss-cream);
    margin: 0;
  }

  .still-standing .lessons-intro h2 em {
    font-style: italic;
    color: var(--ss-gold);
  }

  .still-standing .lesson-card {
    background: var(--ss-mid);
    padding: 2.2rem 1.8rem;
    position: relative;
    transition: background 0.2s;
    overflow: hidden;
  }

  .still-standing .lesson-card:hover { background: #222; }

  .still-standing .l-num {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--ss-gold);
    margin-bottom: 1rem;
    display: block;
  }

  .still-standing .l-ghost {
    position: absolute;
    bottom: 0.5rem;
    right: 1rem;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: 72px;
    line-height: 1;
    color: #161616;
    letter-spacing: -0.03em;
    pointer-events: none;
    user-select: none;
  }

  .still-standing .l-title {
    font-family: 'Cormorant', serif;
    font-weight: 700;
    font-size: 20px;
    color: var(--ss-cream);
    margin-bottom: 0.75rem;
    line-height: 1.2;
    max-width: 18ch;
    position: relative;
    z-index: 1;
  }

  .still-standing .l-body {
    font-size: 14px;
    color: var(--ss-dim);
    line-height: 1.75;
    position: relative;
    z-index: 1;
  }

  /* STAYED */
  .still-standing .stayed-layout {
    display: grid;
    grid-template-columns: 5fr 7fr;
    gap: 7vw;
    align-items: start;
  }

  @media (max-width: 760px) {
    .still-standing .stayed-layout { grid-template-columns: 1fr; }
  }

  .still-standing .stayed-h {
    font-family: 'Cormorant', serif;
    font-weight: 700;
    font-size: clamp(52px, 7.5vw, 100px);
    line-height: 0.95;
    letter-spacing: -0.02em;
    color: var(--ss-cream);
  }

  .still-standing .stayed-h em {
    font-style: italic;
    color: var(--ss-gold);
  }

  .still-standing .stayed-body p {
    font-size: 20px;
    color: #fff;
    line-height: 1.85;
    margin: 0;
  }
  .still-standing .stayed-body p + p { margin-top: 1.1em; }

  .still-standing .promise-box {
    border: 1px solid var(--ss-border);
    padding: 2rem;
    margin-top: 2.5rem;
    position: relative;
  }

  .still-standing .promise-box::before {
    content: '';
    display: block;
    width: 2rem;
    height: 2px;
    background: var(--ss-gold);
    margin-bottom: 1.2rem;
  }

  .still-standing .promise-box p {
    font-size: 15px;
    color: var(--ss-dim);
    line-height: 1.85;
  }

  .still-standing .scripture {
    font-family: 'Cormorant', serif;
    font-style: italic;
    font-size: clamp(16px, 1.8vw, 23px);
    line-height: 1.55;
    color: var(--ss-cream);
    border-top: 1px solid var(--ss-border);
    padding-top: 2rem;
    margin-top: 2.5rem;
  }

  .still-standing .scripture cite {
    display: block;
    font-style: normal;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--ss-gold);
    margin-top: 0.8rem;
  }

  /* AHEAD */
  .still-standing .ahead-top {
    display: grid;
    grid-template-columns: 2fr 3fr;
    gap: 7vw;
    align-items: start;
    margin-bottom: 5rem;
  }

  @media (max-width: 760px) {
    .still-standing .ahead-top { grid-template-columns: 1fr; }
  }

  .still-standing .ahead-top h2 {
    font-family: 'Cormorant', serif;
    font-weight: 700;
    font-size: clamp(42px, 5.5vw, 72px);
    line-height: 1.0;
    letter-spacing: -0.02em;
    color: var(--ss-cream);
    margin: 0;
  }

  .still-standing .ahead-top h2 em {
    font-style: italic;
    color: var(--ss-gold);
  }

  .still-standing .ahead-body p {
    font-size: 18px;
    color: #fff;
    line-height: 1.85;
    margin: 0;
  }
  .still-standing .ahead-body p + p { margin-top: 1.1em; }

  .still-standing .milestones-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: #0f0f0f;
    border: 1px solid #0f0f0f;
  }

  @media (max-width: 600px) {
    .still-standing .milestones-grid { grid-template-columns: 1fr; }
  }

  .still-standing .ms-cell {
    background: var(--ss-dark);
    padding: 2.2rem 1.8rem;
    transition: background 0.2s;
    border-top: 2px solid var(--ss-gold);
  }

  .still-standing .ms-cell:hover { background: #181818; }

  .still-standing .ms-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 19px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ss-cream);
    margin-bottom: 0.5rem;
    margin-top: 1rem;
  }

  .still-standing .ms-body {
    font-size: 18px;
    color: #888888;
    line-height: 1.7;
  }

  /* MISSION */
  .still-standing .mission-band {
    padding: 9vh 6vw;
    text-align: center;
    border-bottom: 1px solid var(--ss-border);
    background: var(--ss-black);
  }

  .still-standing .mission-rule {
    width: 4rem;
    height: 1px;
    background: var(--ss-gold);
    margin: 0 auto 3rem;
    opacity: 0.6;
  }

  .still-standing .mission-band h2 {
    font-family: 'Cormorant', serif;
    font-weight: 700;
    font-size: clamp(30px, 4.5vw, 58px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    max-width: 22ch;
    margin: 0 auto 1.5rem;
    color: var(--ss-cream);
  }

  .still-standing .mission-band p {
    font-size: 12px;
    color: var(--ss-dim);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
  }

  /* FINAL BAND */
  .still-standing .final-band {
    background: var(--ss-gold);
    padding: 11vh 6vw;
    text-align: center;
  }

  .still-standing .final-h {
    font-family: 'Cormorant', serif;
    font-weight: 700;
    font-size: clamp(36px, 7vw, 96px);
    line-height: 1.0;
    letter-spacing: -0.02em;
    color: var(--ss-black);
    max-width: 18ch;
    margin: 0 auto 2.5rem;
  }

  .still-standing .final-p {
    font-size: 29px;
    color: rgba(0,0,0,0.45);
    max-width: 38ch;
    margin: 0 auto;
    line-height: 2.8;
  }

  /* SCROLL REVEAL */
  .still-standing .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }

  .still-standing .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* HERO ANIMATION */
  @keyframes ssFadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .still-standing .hero-meta { animation: ssFadeUp 0.7s 0.1s ease both; }
  .still-standing .hero h1   { animation: ssFadeUp 0.7s 0.25s ease both; }
  .still-standing .hero-sub  { animation: ssFadeUp 0.7s 0.4s ease both; }
  .still-standing .hero-cta  { animation: ssFadeUp 0.7s 0.55s ease both; }

  @media (prefers-reduced-motion: reduce) {
    .still-standing .reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
    .still-standing .hero-meta,
    .still-standing .hero h1,
    .still-standing .hero-sub,
    .still-standing .hero-cta {
      animation: none;
    }
  }
</style>

<script>
  const reveals = document.querySelectorAll<HTMLElement>('.still-standing .reveal');
  if (reveals.length && typeof IntersectionObserver !== 'undefined') {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('visible');
            observer.unobserve(e.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
    );
    reveals.forEach((el) => observer.observe(el));
  } else {
    reveals.forEach((el) => el.classList.add('visible'));
  }
</script>
