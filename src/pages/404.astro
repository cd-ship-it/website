---
import BaseLayout from "../layouts/BaseLayout.astro";

const GA_ID = import.meta.env.PUBLIC_GA_MEASUREMENT_ID ?? "";
---

<BaseLayout
  title="Page not found · Crosspoint Church"
  description="The page you are looking for could not be found."
>
  <section
    class="container flex flex-col items-center justify-center px-4 py-16 min-h-[calc(100vh-12rem)] text-center"
  >
    <p class="text-2xl md:text-3xl font-serif font-bold text-heading">
      Oops... Page not found.
    </p>
    <p class="text-muted mt-4 max-w-xl">
      The page you requested may have moved or no longer exists.
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a href="/" class="btn btn-primary">Go Home</a>
      <a href="/campus" class="btn btn-secondary">Find a Campus</a>
      <a href="/im-new" class="btn btn-secondary">I'm New</a>
    </div>
  </section>

  {
    GA_ID && (
      <script define:vars={{ GA_ID }}>
        function notFoundPayload() {
          return {
            requested_path:
              window.location.pathname + window.location.search + window.location.hash,
            page_location: window.location.href,
            from_referrer: document.referrer || undefined,
          };
        }

        function sendNotFoundEvent() {
          if (typeof gtag !== "function") return false;
          gtag("event", "page_not_found", notFoundPayload());
          return true;
        }

        function trySend(attemptsLeft) {
          if (sendNotFoundEvent()) return;
          if (attemptsLeft <= 0) return;
          window.setTimeout(function () {
            trySend(attemptsLeft - 1);
          }, 250);
        }

        window.addEventListener("load", function () {
          trySend(20);
        });
      </script>
    )
  }
</BaseLayout>
