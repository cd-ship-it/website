---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Page not found · Crosspoint Church"
  description="The page you are looking for could not be found."
>
  <section
    class="container flex flex-col items-center justify-center px-4 py-16 min-h-[calc(100vh-12rem)] text-center"
  >
    <p class="text-2xl md:text-3xl font-serif font-bold text-heading">
      Oops... Page not found.
    </p>
    <p class="text-muted mt-4 max-w-xl">
      The page you requested may have moved or no longer exists.
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a href="/" class="btn btn-primary">Go Home</a>
      <a href="/campus" class="btn btn-secondary">Find a Campus</a>
      <a href="/im-new" class="btn btn-secondary">I'm New</a>
    </div>
  </section>
</BaseLayout>
