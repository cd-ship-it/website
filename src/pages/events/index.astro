---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/Sections/PageHeader.astro";
import { fetchAllEvents } from "../../lib/eventApi";
const EVENTS_API_URL = import.meta.env.PUBLIC_EVENTS_API_URL ?? "/api/events.php";
let PREBUILT_EVENT_SLUGS: string[] = [];

try {
  const prebuiltEvents = await fetchAllEvents();
  PREBUILT_EVENT_SLUGS = prebuiltEvents
    .map((event) => event.slug)
    .filter((slug): slug is string => !!slug);
} catch {
  PREBUILT_EVENT_SLUGS = [];
}
---

<BaseLayout
  title="Events - Crosspoint Church"
  description="Stay updated with upcoming events and activities at our church."
>
  <PageHeader 
    title="Events" 
    subtitle="Join us for upcoming activities and gatherings"
    backgroundImage="/uploads/events-header-bg.webp"
  />

  <section
    class="py-16"
    data-events-root
    data-api-url={EVENTS_API_URL}
    data-prebuilt-slugs={JSON.stringify(PREBUILT_EVENT_SLUGS)}
  >
    <div class="container">
      <div class="text-center mb-12">
        <h2 class="section-heading mb-4">All Events</h2>
        <p class="text-xl text-muted max-w-3xl mx-auto">
          Explore what is happening and click through for full event details
        </p>
      </div>

      <div id="events-loading" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {Array.from({ length: 6 }).map(() => (
          <div class="bg-cream-2 rounded-xl p-5 animate-pulse">
            <div class="h-6 w-3/4 bg-gray-200 rounded mb-4"></div>
            <div class="h-16 w-24 bg-gray-200 rounded mb-4"></div>
            <div class="h-4 w-full bg-gray-200 rounded mb-2"></div>
            <div class="h-4 w-2/3 bg-gray-200 rounded"></div>
          </div>
        ))}
      </div>

      <div id="events-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 hidden"></div>

      <div id="events-empty" class="hidden text-center py-12 bg-cream rounded-lg">
        <p class="text-muted">No events available at the moment.</p>
      </div>

      <div id="events-error" class="hidden text-center py-12 bg-red-50 rounded-lg">
        <p class="text-red-600 mb-4">Could not load events. Please try again later.</p>
        <button id="events-retry" class="px-4 py-2 rounded-md bg-red-600 text-white hover:bg-red-700">
          Retry
        </button>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import { normalizeEvent, parseEventsPayload } from "../../lib/eventApi";
  import { monthLabel, dayNum, weekDay, fullDate, rangeLabel } from "../../lib/events/format";

  const root = document.querySelector('[data-events-root]');
  const EVENTS_API_URL = root?.dataset.apiUrl ?? '';
  const PREBUILT_EVENT_SLUGS = JSON.parse(root?.dataset.prebuiltSlugs ?? '[]');

  function esc(str) {
    return (str ?? "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;");
  }

  function cardHtml(event) {
    const hasPrebuiltDetails = PREBUILT_EVENT_SLUGS.includes(event.slug);
    const wrapperTag = hasPrebuiltDetails ? "a" : "div";
    const wrapperAttrs = hasPrebuiltDetails
      ? `href="/events/${encodeURIComponent(event.slug)}" class="group block xp-panel-inner bg-white border border-gray-100 hover:shadow-lg hover:border-primary-200 hover:-translate-y-0.5 transition-all duration-300 flex flex-col overflow-hidden cursor-pointer focus:outline-none focus:ring-2 focus:ring-primary-500"`
      : `class="group block xp-panel-inner bg-white border border-gray-100 flex flex-col overflow-hidden opacity-90" aria-disabled="true"`;
    const ctaLabel = hasPrebuiltDetails ? "See details →" : "Details available after next update";

    const featuredImg =
      event.image && String(event.image).trim()
        ? `<div class="relative aspect-[16/9] w-full shrink-0 bg-cream-2 border-b border-gray-100 overflow-hidden">
            <img
              src="${esc(String(event.image).trim())}"
              alt="${esc(event.title)}"
              class="h-full w-full object-cover"
              loading="lazy"
              decoding="async"
              onerror="this.closest('div')?.remove()"
            />
          </div>`
        : "";

    return `
      <${wrapperTag} ${wrapperAttrs}>
        ${featuredImg}
        <div class="flex gap-4 items-start p-5 flex-1">
          <div class="shrink-0 rounded-lg overflow-hidden border border-gray-200 w-20 h-20 text-center bg-white">
            <div class="bg-secondary-500 text-ink text-micro-label py-1">${esc(monthLabel(event.startDate))}</div>
            <div class="text-2xl font-bold text-heading leading-tight pt-2">${esc(dayNum(event.startDate))}</div>
            <div class="text-xs text-muted pb-2">${esc(weekDay(event.startDate))}</div>
          </div>
          <div class="min-w-0 flex-1">
            <h3 class="text-lg font-bold text-heading mb-2 line-clamp-2">${esc(event.title)}</h3>
            <p class="text-sm text-muted mb-2">${esc(rangeLabel(event.startDate, event.endDate, event.time))}</p>
            ${event.location ? `<p class="text-sm text-muted mb-2 line-clamp-1">${esc(event.location)}</p>` : ""}
            <p class="mt-3 text-sm font-medium text-primary-600 ${hasPrebuiltDetails ? "group-hover:underline" : ""}">${esc(ctaLabel)}</p>
          </div>
        </div>
      </${wrapperTag}>
    `;
  }

  async function loadEvents() {
    const loading = document.getElementById("events-loading");
    const grid = document.getElementById("events-grid");
    const empty = document.getElementById("events-empty");
    const error = document.getElementById("events-error");

    loading.classList.remove("hidden");
    grid.classList.add("hidden");
    empty.classList.add("hidden");
    error.classList.add("hidden");

    try {
      const res = await fetch(EVENTS_API_URL, { cache: "no-store" });
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const json = await res.json();
      const events = parseEventsPayload(json)
        .filter((event) => event.slug && event.startDate)
        .sort((a, b) => new Date(a.startDate).getTime() - new Date(b.startDate).getTime());

      loading.classList.add("hidden");

      if (!events.length) {
        empty.classList.remove("hidden");
        return;
      }

      grid.innerHTML = events.map(cardHtml).join("");
      grid.classList.remove("hidden");
    } catch {
      loading.classList.add("hidden");
      error.classList.remove("hidden");
    }
  }

  document.addEventListener("DOMContentLoaded", () => {
    loadEvents();
    document.getElementById("events-retry")?.addEventListener("click", loadEvents);
  });
</script>
