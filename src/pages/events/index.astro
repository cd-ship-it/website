---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/Sections/PageHeader.astro";
import { fetchAllEvents } from "../../lib/eventApi";
import type { EventItem } from "../../lib/eventApi";
import { monthLabel, dayNum, weekDay, rangeLabel } from "../../lib/events/format";
import { withBaseUrl } from "../../lib/urls";
let events: EventItem[] = [];
try {
  events = (await fetchAllEvents())
    .filter((event) => event.slug && event.startDate)
    .sort((a, b) => new Date(a.startDate).getTime() - new Date(b.startDate).getTime());
} catch {
  events = [];
}
---

<BaseLayout
  title="Events - Crosspoint Church"
  description="Stay updated with upcoming events and activities at our church."
>
  <PageHeader 
    title="Events" 
    subtitle="Join us for upcoming activities and gatherings"
    backgroundImage={`${withBaseUrl("/uploads/events-header-bg.webp")}`}
  />

  <section class="py-16">
    <div class="container">
      <div class="text-center mb-12">
        <h2 class="section-heading mb-4">All Events</h2>
        <p class="text-xl text-muted max-w-3xl mx-auto">
          Explore what is happening and click through for full event details
        </p>
      </div>

      {events.length === 0 ? (
        <div class="text-center py-12 bg-cream rounded-lg">
          <p class="text-muted">No events available at the moment.</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {events.map((event) => (
            <a
              href={`${import.meta.env.BASE_URL}events/${encodeURIComponent(event.slug)}`}
              class="group block xp-panel-inner bg-white border border-gray-100 hover:shadow-lg hover:border-primary-200 hover:-translate-y-0.5 transition-all duration-300 flex flex-col overflow-hidden cursor-pointer focus:outline-none focus:ring-2 focus:ring-primary-500"
            >
              {event.image && (
                <div class="relative aspect-[16/9] w-full shrink-0 bg-cream-2 border-b border-gray-100 overflow-hidden">
                  <img
                    src={event.image}
                    alt={event.title}
                    class="h-full w-full object-cover"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
              )}
              <div class="flex gap-4 items-start p-5 flex-1">
                <div class="shrink-0 rounded-lg overflow-hidden border border-gray-200 w-20 h-20 text-center bg-white">
                  <div class="bg-secondary-500 text-ink text-micro-label py-1">
                    {monthLabel(event.startDate)}
                  </div>
                  <div class="text-2xl font-bold text-heading leading-tight pt-2">
                    {dayNum(event.startDate)}
                  </div>
                  <div class="text-xs text-muted pb-2">{weekDay(event.startDate)}</div>
                </div>
                <div class="min-w-0 flex-1">
                  <h3 class="text-lg font-bold text-heading mb-2 line-clamp-2">{event.title}</h3>
                  <p class="text-sm text-muted mb-2">
                    {rangeLabel(event.startDate, event.endDate, event.time)}
                  </p>
                  {event.location && <p class="text-sm text-muted mb-2 line-clamp-1">{event.location}</p>}
                  <p class="mt-3 text-sm font-medium text-primary-600 group-hover:underline">
                    See details →
                  </p>
                </div>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
