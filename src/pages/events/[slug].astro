---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Button from "../../components/UI/Button.astro";
import { fetchAllEvents } from "../../lib/eventApi";
import type { EventItem } from "../../lib/eventApi";

function formatDate(dateStr: string) {
  return new Date(`${dateStr}T00:00:00`).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
    weekday: "short",
  });
}

export async function getStaticPaths() {
  try {
    const events = await fetchAllEvents();
    return events.map((event) => ({
      params: { slug: event.slug },
      props: { event },
    }));
  } catch {
    return [];
  }
}

const { event } = Astro.props as { event: EventItem };
const formattedDate = formatDate(event.startDate);
const formattedEndDate = event.endDate ? formatDate(event.endDate) : null;
const isFutureEvent = new Date(event.startDate) > new Date();
---

<BaseLayout
  title={`${event.title} - Events - Crosspoint Church`}
  description={event.summary}
  type="article"
>
  <section class="py-12">
    <div class="container max-w-4xl mx-auto">
      <h1 class="text-3xl md:text-4xl font-bold mb-4">{event.title}</h1>

      <div class="bg-cream rounded-xl p-6 mb-8 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="flex items-start gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mt-0.5 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          <div>
            <p class="text-xs font-semibold text-muted uppercase tracking-wide mb-0.5">Date</p>
            <p class="font-medium text-gray-900">
              {formattedEndDate && formattedEndDate !== formattedDate
                ? `${formattedDate} - ${formattedEndDate}`
                : formattedDate}
            </p>
            {event.time && <p class="text-sm text-muted">{event.time}</p>}
          </div>
        </div>

        {event.location && (
          <div class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mt-0.5 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <div>
              <p class="text-xs font-semibold text-muted uppercase tracking-wide mb-0.5">Location</p>
              <p class="font-medium text-gray-900">{event.location}</p>
            </div>
          </div>
        )}
      </div>

      {event.content && (
        <article
          class="prose prose-lg max-w-none prose-headings:text-heading prose-p:text-ink-3 prose-li:text-ink-3 prose-a:text-primary-600 hover:prose-a:text-primary-700"
          set:html={event.content}
        ></article>
      )}

      <div class="mt-12 flex flex-wrap gap-4">
        {isFutureEvent && event.registrationLink && (
          <Button href={event.registrationLink} target="_blank" variant="primary">
            Register for This Event
          </Button>
        )}

        <Button href="/events" variant="outline">
          Back to All Events
        </Button>
      </div>
    </div>
  </section>
</BaseLayout>