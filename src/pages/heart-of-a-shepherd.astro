---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/Sections/PageHeader.astro";
import "../assets/styles/wp-rendered.css";
import { getWordPressUrl } from "../config/site";
import { withBaseUrl } from "../lib/urls";
import { fetchWpDynamicPageRecord } from "../lib/wordpress/mirror";
import { fetchCategoryLatestPostLinkPreview } from "../lib/wpLinkPreview";

const wpBaseUrl = getWordPressUrl();
const fallbackImage = {
  url: `${withBaseUrl("/uploads/blog-header-bg.webp")}`,
  alt: "Heart of a Shepherd — Crosspoint Church",
};

let layoutTitle = "Heart of a Shepherd - Crosspoint Church";
let layoutDescription = "Latest Heart of a Shepherd post from Crosspoint Church.";
let layoutImage = fallbackImage;
let layoutType: "website" | "article" = "website";

if (wpBaseUrl) {
  try {
    const preview = await fetchCategoryLatestPostLinkPreview(wpBaseUrl, "word-of-your-pastor", {
      title: layoutTitle,
      description: layoutDescription,
      image: fallbackImage,
    });
    if (preview) {
      layoutTitle = preview.title;
      layoutDescription = preview.description;
      layoutImage = preview.image;
      layoutType = "article";
    }
  } catch {
    // Build-time preview fetch failed; use static fallback SEO.
  }
}

const record = wpBaseUrl
  ? await fetchWpDynamicPageRecord({
      slug: "heart-of-a-shepherd",
      kind: "wordpress_category_latest_post",
      wpCategorySlug: "word-of-your-pastor",
      pageHeader: {
        title: "Heart of a Shepherd",
        subtitle: "Heart of a Shepherd",
      },
      seo: {
        title: "Heart of a Shepherd - Crosspoint Church",
        description: "Latest Heart of a Shepherd post from Crosspoint Church.",
      },
      showPostTitle: false,
    })
  : null;
---

<BaseLayout
  title={layoutTitle}
  description={layoutDescription}
  image={layoutImage}
  type={layoutType}
>
  <PageHeader
    title="Heart of a Shepherd"
    subtitle="Heart of a Shepherd"
    backgroundImage={`${withBaseUrl("/uploads/blog-header-bg.webp")}`}
  />

  <section class="py-16">
    <div class="container max-w-4xl">
      {!wpBaseUrl ? (
        <div class="bg-red-50 p-6 text-red-700">
          <p>
            WordPress URL is not configured. Set <code class="text-sm">PUBLIC_WORDPRESS_URL</code>{" "}
            in your environment.
          </p>
        </div>
      ) : !record ? (
        <div class="bg-red-50 p-6 text-red-700">
          <p>No published content found yet.</p>
        </div>
      ) : (
        <article>
          <div class="prose prose-lg max-w-none" set:html={record.content?.rendered ?? ""} />
          <div class="mt-10">
            <a
              href={`${import.meta.env.BASE_URL}heart-of-a-shepherd/archive`}
              class="inline-flex items-center rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-ink-3 hover:bg-cream transition-colors"
            >
              Previous Issues
            </a>
          </div>
        </article>
      )}
    </div>
  </section>
</BaseLayout>
