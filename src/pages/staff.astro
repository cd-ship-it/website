---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/Sections/PageHeader.astro";
import StaffList from "../components/Sections/StaffList.astro";
---

<BaseLayout
  title="Staff - Church Name"
  description="Meet our dedicated church staff and leadership team who serve our congregation with passion and commitment."
>
  <PageHeader 
    title="Our Staff" 
    subtitle="Meet our dedicated leadership team"
    backgroundImage="/uploads/page-header-bg.webp"
  />
  
  <!-- Staff List -->
  <StaffList />
  
  <!-- Contact Staff CTA -->
  <section class="py-16 bg-cream">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold mb-6">Need to Contact a Staff Member?</h2>
        <p class="text-xl text-muted mb-8">
          Our staff is here to serve you and answer any questions you may have. Feel free to reach out to any of our team members directly or contact our main office.
        </p>
        
        <div class="flex flex-wrap justify-center gap-4">
          <a 
            href="/contact" 
            class="inline-flex items-center justify-center px-5 py-3 text-base font-medium text-white bg-primary-900 rounded-md shadow-sm hover:bg-primary-950 focus:outline-none focus:ring-2 focus:ring-primary-700 focus:ring-offset-2"
          >
            Contact Us
          </a>
          
          <a 
            href="/about-us" 
            class="inline-flex items-center justify-center px-5 py-3 text-base font-medium text-ink-3 bg-white border border-gray-300 rounded-md shadow-sm hover:bg-cream focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2"
          >
            Learn More About Our Church
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>