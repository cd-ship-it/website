---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/Sections/PageHeader.astro";
import StaffList from "../components/Sections/StaffList.astro";
import LocalizedContent from "../components/UI/LocalizedContent.astro";
import type { SiteLang } from "../lib/i18n";

const aboutPageContent: Record<
  SiteLang,
  {
    pageTitle: string;
    pageSubtitle: string;
    missionVision: {
      sections: Array<{ heading: string; paragraphs: string[] }>;
    };
  }
> = {
  en: {
    pageTitle: "About Us",
    pageSubtitle: "Our History, Mission, and Values",
    missionVision: {
      sections: [
        {
          heading: "Our Mission",
          paragraphs: [
            "To know Christ and to make Him known through worship, discipleship, fellowship, and service.",
          ],
        },
        {
          heading: "Our Vision",
          paragraphs: [
            "To be a vibrant, growing community of believers who are transformed by the Gospel and transforming our community with the love of Christ.",
          ],
        },
      ],
    },
  },
  "zh-Hant": {
    pageTitle: "關於我們",
    pageSubtitle: "我們的歷史、使命與核心價值",
    missionVision: {
      sections: [
        {
          heading: "我們的使命",
          paragraphs: [
            "藉著敬拜、門徒訓練、團契與服事，認識基督並使人認識祂。",
          ],
        },
        {
          heading: "我們的異象",
          paragraphs: [
            "成為一個充滿生命力、持續成長的信徒群體，因福音被改變，並以基督的愛轉化我們的社區。",
          ],
        },
      ],
    },
  },
  "zh-Hans": {
    pageTitle: "关于我们",
    pageSubtitle: "我们的历史、使命与核心价值",
    missionVision: {
      sections: [
        {
          heading: "我们的使命",
          paragraphs: [
            "借着敬拜、门徒训练、团契与服事，认识基督并使人认识祂。",
          ],
        },
        {
          heading: "我们的异象",
          paragraphs: [
            "成为一个充满生命力、持续成长的信徒群体，因福音被改变，并以基督的爱转化我们的社区。",
          ],
        },
      ],
    },
  },
};

/** For static prerender: sync header text in the browser from stored language (no SSR cookies). */
const aboutHeaderI18n: Record<SiteLang, { pageTitle: string; pageSubtitle: string }> = {
  en: { pageTitle: aboutPageContent.en.pageTitle, pageSubtitle: aboutPageContent.en.pageSubtitle },
  "zh-Hant": {
    pageTitle: aboutPageContent["zh-Hant"].pageTitle,
    pageSubtitle: aboutPageContent["zh-Hant"].pageSubtitle,
  },
  "zh-Hans": {
    pageTitle: aboutPageContent["zh-Hans"].pageTitle,
    pageSubtitle: aboutPageContent["zh-Hans"].pageSubtitle,
  },
};
---

<BaseLayout
  title="About Us - Church Name"
  description="Learn about our church's history, mission, values, and the people who make our community special."
>
  <PageHeader 
    title={aboutPageContent.en.pageTitle}
    subtitle={aboutPageContent.en.pageSubtitle}
    titleDataI18n="about-page-title"
    subtitleDataI18n="about-page-subtitle"
    backgroundImage="https://images.unsplash.com/photo-1438032005730-c779502df39b?w=1920&h=600&fit=crop&crop=center"
  />
  
  <!-- Mission & Vision -->
  <section class="py-16">
    <div class="container">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div>
          <LocalizedContent
            clientLocaleSync
            content={{
              en: aboutPageContent.en.missionVision,
              "zh-Hant": aboutPageContent["zh-Hant"].missionVision,
              "zh-Hans": aboutPageContent["zh-Hans"].missionVision,
            }}
          />
        </div>
        
        <div>
          <img 
            src="https://images.unsplash.com/photo-1493225457124-a3eb161ffa5f?w=800&h=600&fit=crop&crop=center" 
            alt="Worship at our church" 
            class="rounded-lg shadow-lg object-cover w-full h-full"
          />
        </div>
      </div>
    </div>
  </section>
  
  <!-- Core Values -->
  <section class="py-16 bg-cream">
    <div class="container">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Our Core Values</h2>
        <p class="text-xl text-muted max-w-3xl mx-auto">
          These principles guide everything we do as a church community
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-white p-8 rounded-lg shadow-sm">
          <div class="w-16 h-16 rounded-full bg-primary-100 flex items-center justify-center mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Biblical Teaching</h3>
          <p class="text-ink-3">
            We are committed to teaching God's Word faithfully and helping people apply it to their lives. We believe the Bible is God's inspired, inerrant Word and our ultimate authority.
          </p>
        </div>
        
        <div class="bg-white p-8 rounded-lg shadow-sm">
          <div class="w-16 h-16 rounded-full bg-secondary-100 flex items-center justify-center mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-secondary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Authentic Community</h3>
          <p class="text-ink-3">
            We believe spiritual growth happens best in community. We foster genuine relationships where people can be known, loved, and challenged to grow in their faith.
          </p>
        </div>
        
        <div class="bg-white p-8 rounded-lg shadow-sm">
          <div class="w-16 h-16 rounded-full bg-accent-100 flex items-center justify-center mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-accent-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Missional Living</h3>
          <p class="text-ink-3">
            We believe every follower of Jesus is called to share His love with others. We equip and encourage our members to live on mission in their neighborhoods, workplaces, and beyond.
          </p>
        </div>
        
        <div class="bg-white p-8 rounded-lg shadow-sm">
          <div class="w-16 h-16 rounded-full bg-green-100 flex items-center justify-center mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Spiritual Growth</h3>
          <p class="text-ink-3">
            We are committed to helping people grow in their relationship with Christ, becoming more like Him in their thoughts, words, and actions through discipleship and spiritual practices.
          </p>
        </div>
        
        <div class="bg-white p-8 rounded-lg shadow-sm">
          <div class="w-16 h-16 rounded-full bg-secondary-100 flex items-center justify-center mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-secondary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Spirit-Led Worship</h3>
          <p class="text-ink-3">
            We value authentic, heartfelt worship that glorifies God and transforms lives. We seek to create environments where people can encounter God's presence.
          </p>
        </div>
        
        <div class="bg-white p-8 rounded-lg shadow-sm">
          <div class="w-16 h-16 rounded-full bg-yellow-100 flex items-center justify-center mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-yellow-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Servant Leadership</h3>
          <p class="text-ink-3">
            We believe leadership is about service, not status. We develop and empower leaders who model Christ-like humility and sacrifice as they guide others.
          </p>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Church History -->
  <section class="py-16">
    <div class="container">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Our History</h2>
        <p class="text-xl text-muted max-w-3xl mx-auto">
          The story of how our church has grown and evolved over the years
        </p>
      </div>
      
      <div class="max-w-4xl mx-auto">
        <div class="relative pl-8 sm:pl-16 py-6 group">
          <div class="flex flex-col sm:flex-row items-start mb-1 group-last:before:hidden before:absolute before:left-2 sm:before:left-7 before:h-full before:px-px before:bg-gray-300 before:self-start before:-translate-x-1/2 before:translate-y-3 after:absolute after:left-2 sm:after:left-7 after:w-4 after:h-4 after:bg-primary-600 after:border-4 after:border-white after:rounded-full after:-translate-x-1/2 after:translate-y-1.5">
            <time class="sm:w-28 text-xs text-muted uppercase">1950</time>
            <div>
              <h3 class="text-xl font-bold text-heading">Church Founded</h3>
              <p class="text-ink-3">
                Our church was founded by a small group of dedicated believers who met in homes for Bible study and prayer.
              </p>
            </div>
          </div>
          
          <div class="relative pl-8 sm:pl-16 py-6 group">
            <div class="flex flex-col sm:flex-row items-start mb-1 group-last:before:hidden before:absolute before:left-2 sm:before:left-7 before:h-full before:px-px before:bg-gray-300 before:self-start before:-translate-x-1/2 before:translate-y-3 after:absolute after:left-2 sm:after:left-7 after:w-4 after:h-4 after:bg-primary-600 after:border-4 after:border-white after:rounded-full after:-translate-x-1/2 after:translate-y-1.5">
              <time class="sm:w-28 text-xs text-muted uppercase">1965</time>
              <div>
                <h3 class="text-xl font-bold text-heading">First Building</h3>
                <p class="text-ink-3">
                  As the congregation grew, we purchased our first building and expanded our ministries to serve the community.
                </p>
              </div>
            </div>
          </div>
          
          <div class="relative pl-8 sm:pl-16 py-6 group">
            <div class="flex flex-col sm:flex-row items-start mb-1 group-last:before:hidden before:absolute before:left-2 sm:before:left-7 before:h-full before:px-px before:bg-gray-300 before:self-start before:-translate-x-1/2 before:translate-y-3 after:absolute after:left-2 sm:after:left-7 after:w-4 after:h-4 after:bg-primary-600 after:border-4 after:border-white after:rounded-full after:-translate-x-1/2 after:translate-y-1.5">
              <time class="sm:w-28 text-xs text-muted uppercase">1988</time>
              <div>
                <h3 class="text-xl font-bold text-heading">New Campus</h3>
                <p class="text-ink-3">
                  We moved to our current location and built a larger sanctuary to accommodate our growing congregation.
                </p>
              </div>
            </div>
          </div>
          
          <div class="relative pl-8 sm:pl-16 py-6 group">
            <div class="flex flex-col sm:flex-row items-start mb-1 group-last:before:hidden before:absolute before:left-2 sm:before:left-7 before:h-full before:px-px before:bg-gray-300 before:self-start before:-translate-x-1/2 before:translate-y-3 after:absolute after:left-2 sm:after:left-7 after:w-4 after:h-4 after:bg-primary-600 after:border-4 after:border-white after:rounded-full after:-translate-x-1/2 after:translate-y-1.5">
              <time class="sm:w-28 text-xs text-muted uppercase">2010</time>
              <div>
                <h3 class="text-xl font-bold text-heading">Community Center</h3>
                <p class="text-ink-3">
                  We opened our community center to better serve our neighbors through various outreach programs and ministries.
                </p>
              </div>
            </div>
          </div>
          
          <div class="relative pl-8 sm:pl-16 py-6 group">
            <div class="flex flex-col sm:flex-row items-start mb-1 group-last:before:hidden before:absolute before:left-2 sm:before:left-7 before:h-full before:px-px before:bg-gray-300 before:self-start before:-translate-x-1/2 before:translate-y-3 after:absolute after:left-2 sm:after:left-7 after:w-4 after:h-4 after:bg-primary-600 after:border-4 after:border-white after:rounded-full after:-translate-x-1/2 after:translate-y-1.5">
              <time class="sm:w-28 text-xs text-muted uppercase">Present</time>
              <div>
                <h3 class="text-xl font-bold text-heading">Continuing the Mission</h3>
                <p class="text-ink-3">
                  Today, we continue to grow and adapt while staying true to our mission of knowing Christ and making Him known.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Leadership Team Preview -->
  <section class="py-16 bg-cream">
    <div class="container">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Meet Our Leadership</h2>
        <p class="text-xl text-muted max-w-3xl mx-auto">
          Our dedicated staff and leadership team serve our congregation with passion and commitment
        </p>
      </div>
      
      <!-- Show limited staff preview -->
      <StaffList showAll={false} limit={3} />
      
      <div class="mt-12 text-center">
        <a 
          href="/staff" 
          class="inline-flex items-center justify-center px-5 py-3 text-base font-medium text-white bg-primary-900 rounded-md shadow-sm hover:bg-primary-950 focus:outline-none focus:ring-2 focus:ring-primary-700 focus:ring-offset-2"
        >
          Meet All Our Staff
        </a>
      </div>
    </div>
  </section>
  
  <!-- Statement of Faith -->
  <section class="py-16">
    <div class="container">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">What We Believe</h2>
        <p class="text-xl text-muted max-w-3xl mx-auto">
          Our church adheres to these fundamental Christian beliefs
        </p>
      </div>
      
      <div class="max-w-4xl mx-auto prose prose-lg">
        <h3>The Bible</h3>
        <p>
          We believe the Bible is God's Word, inspired by the Holy Spirit, without error in the original manuscripts, and the final authority for all Christian faith and life.
        </p>
        
        <h3>God</h3>
        <p>
          We believe in one God who exists eternally in three persons: Father, Son, and Holy Spirit. Each person is fully God, yet there is one God.
        </p>
        
        <h3>Jesus Christ</h3>
        <p>
          We believe Jesus Christ is fully God and fully human. He was born of a virgin, lived a sinless life, died on the cross as the substitute for sinners, rose bodily from the grave, and ascended to heaven where He now serves as our High Priest and Advocate.
        </p>
        
        <h3>Holy Spirit</h3>
        <p>
          We believe the Holy Spirit convicts the world of sin, regenerates believers, indwells them, and empowers them for godly living and service.
        </p>
        
        <h3>Salvation</h3>
        <p>
          We believe salvation is by grace alone, through faith alone, in Christ alone. Good works are the necessary fruit of true faith but are not the basis of our right standing before God.
        </p>
        
        <h3>The Church</h3>
        <p>
          We believe the church is the body of Christ, consisting of all true believers. Its mission is to worship God, build up believers in their faith, and share the gospel with the world.
        </p>
        
        <h3>The Future</h3>
        <p>
          We believe in the personal, visible return of Jesus Christ, the resurrection of the dead, the final judgment, and the eternal state of blessing for the righteous and punishment for the unrighteous.
        </p>
      </div>
    </div>
  </section>

  <script define:vars={{ aboutHeaderI18n }}>
    function normalizeAboutLang(value) {
      return ["en", "zh-Hant", "zh-Hans"].includes(value) ? value : "en";
    }
    document.addEventListener("DOMContentLoaded", () => {
      const lang = normalizeAboutLang(document.documentElement.dataset.lang || "en");
      const block = aboutHeaderI18n[lang] ?? aboutHeaderI18n.en;
      const h1 = document.querySelector('[data-i18n="about-page-title"]');
      const sub = document.querySelector('[data-i18n="about-page-subtitle"]');
      if (h1) h1.textContent = block.pageTitle;
      if (sub) sub.textContent = block.pageSubtitle;
    });
  </script>
</BaseLayout>