---
import { getEntry } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/Sections/PageHeader.astro";
import LocalizedInline from "../components/UI/LocalizedInline.astro";
import { pickLocalizedText, resolveLocalizedSlot } from "../lib/i18n";
import { withBaseUrl } from "../lib/urls";

const page = await getEntry("about", "about-us");
if (!page) throw new Error('Content entry "about/about-us" not found.');

const { seo, pageHeader, mission, vision, history, testimonies = [] } = page.data;
const ctaBackgroundImage = withBaseUrl(pageHeader.backgroundImage);

if (!mission || !vision || !history) {
  throw new Error('about-us.md must define mission, vision, and history.');
}
---

<BaseLayout title={seo.title} description={seo.description}>

  <!-- ── Page Header (same fixed height as other pages using PageHeader) ─── -->
  <PageHeader
    title={pageHeader.title}
    subtitle={pageHeader.subtitle}
    backgroundImage={pageHeader.backgroundImage}
  />

  <!-- ── Mission + Vision (two rows, ~50/50 text + image) ───────────────── -->
  <section class="xp-panel">
    <div class="container-xp-stack">
      <!-- Card 1: Mission — text left, image right (same chrome as index `xp-panel-inner`) -->
      <div class="xp-panel-inner">
        <div class="grid grid-cols-1 md:grid-cols-2 md:min-h-[min(22rem,52vh)] items-stretch">
          <div class="p-8 lg:p-10 flex flex-col justify-center">
            <h2 class="section-heading">
              <LocalizedInline value={mission.heading} />
            </h2>
            <p class="body-copy">
              <LocalizedInline value={mission.body} />
            </p>
          </div>
          <div class="relative min-h-[14rem] md:min-h-0 bg-cream-2">
            <img
              src={`${withBaseUrl("/uploads/about/mission.png")}`}
              alt={pickLocalizedText(mission.heading, "en")}
              class="absolute inset-0 w-full h-full object-cover"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
      </div>

      <!-- Card 2: Vision — image left, text right (mobile: text first, then image) -->
      <div class="xp-panel-inner">
        <div class="grid grid-cols-1 md:grid-cols-2 md:min-h-[min(22rem,52vh)] items-stretch">
          <div class="order-2 md:order-1 relative min-h-[14rem] md:min-h-0 bg-cream-2">
            <img
              src={`${withBaseUrl("/uploads/about/vision.png")}`}
              alt={pickLocalizedText(vision.heading, "en")}
              class="absolute inset-0 w-full h-full object-cover"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="order-1 md:order-2 p-8 lg:p-10 flex flex-col justify-center">

            <h2 class="section-heading">
              <LocalizedInline value={vision.heading} />
            </h2>
            <p class="body-copy">
              <LocalizedInline value={vision.body} />
            </p>
          </div>
        </div>
      </div>

      <!-- Card 3: Our Pastors — text left, image right -->
      <div class="xp-panel-inner">
        <div class="grid grid-cols-1 md:grid-cols-2 md:min-h-[min(22rem,52vh)] items-stretch">
          <div class="p-8 lg:p-10 flex flex-col justify-center">
            <h2 class="section-heading">
              <LocalizedInline
                value={{ en: "Our Pastors", "zh-Hant": "我們的牧者", "zh-Hans": "我们的牧者" }}
              />
            </h2>
            <p class="body-copy mb-6">
              <LocalizedInline
                value={{
                  en: "Our pastoral team is committed to guiding, teaching, and shepherding the Crosspoint community across all campuses.",
                  "zh-Hant":
                    "我們的牧者團隊致力於在各會堂引導、教導與牧養匯點教會的弟兄姊妹。",
                  "zh-Hans": "我们的牧者团队致力于在各会堂引导、教导与牧养汇点教会的弟兄姊妹。",
                }}
              />
            </p>
            <a href={`${import.meta.env.BASE_URL}about-pastors`} class="btn btn-primary self-start">
              <LocalizedInline
                value={{
                  en: "Meet our pastoral team",
                  "zh-Hant": "認識牧者團隊",
                  "zh-Hans": "认识牧者团队",
                }}
              />
            </a>
          </div>
          <div class="relative min-h-[14rem] md:min-h-0 bg-cream-2">
            <img
              src={`${withBaseUrl("/uploads/milpitas-Building-sq.webp")}`}
              alt={pickLocalizedText(
                { en: "Milpitas campus building", "zh-Hant": "Milpitas 會堂", "zh-Hans": "Milpitas 会堂" },
                "en",
              )}
              class="absolute inset-0 h-full w-full object-cover"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ── Still Standing Banner ────────────────────────────────────────────
  <section class="still-standing-banner">
    <div class="still-standing-grid" aria-hidden="true"></div>
    <div class="container relative z-[1]">
      <div class="max-w-3xl">
        <h2 class="still-standing-title">
          <span class="still-standing-white">
            <LocalizedInline value={{ en: "Still", "zh-Hant": "依然", "zh-Hans": "依然" }} />
          </span>
          <span class="still-standing-orange">
            <LocalizedInline value={{ en: "Standing.", "zh-Hant": "屹立。", "zh-Hans": "屹立。" }} />
          </span>
        </h2>
        <p class="still-standing-lede">
          <LocalizedInline value={{
            en: "The storm came. We stayed.",
            "zh-Hant": "風雨來襲，我們仍然堅守。",
            "zh-Hans": "风雨来袭，我们仍然坚守。"
          }} />
        </p>
        <p class="still-standing-body">
          <LocalizedInline value={{
            en: "Here's what it cost us, what it taught us, and where we're going.",
            "zh-Hant": "這是我們所付出的代價、從中學到的功課，以及未來要走的方向。",
            "zh-Hans": "这是我们所付出的代价、从中学到的功课，以及未来要走的方向。"
          }} />
        </p>
        <a href={`${import.meta.env.BASE_URL}our-season`} class="btn still-standing-btn">
          <LocalizedInline value={{
            en: "Read Our Season",
            "zh-Hant": "閱讀我們的季節",
            "zh-Hans": "阅读我们的季节"
          }} />
        </a>
      </div>
    </div>
  </section> -->


  <!-- ── History Timeline ───────────────────────────────────────────────── -->
  <section class="py-20 bg-white">
    <div class="container">

      <!-- Section heading -->
      <div
        class="relative mb-16 overflow-hidden rounded-2xl bg-cover bg-center px-4 py-14 text-center text-white md:py-16"
        style={`background-image: linear-gradient(rgba(211, 168, 140, 0.5) 0%, rgba(59, 39, 26, 0.78) 100%), url(${withBaseUrl("/uploads/about/25-years-faith-growth.png)")}`}
      >
        <p class="eyebrow mb-3 text-white/90">
          <LocalizedInline value={{ en: "Our Amazing Story", "zh-Hant": "我們的奇妙故事", "zh-Hans": "我们的奇妙故事" }} />
        </p>
        <h2 class="font-serif font-bold text-white" style="font-size: var(--font-section-major);">
          <LocalizedInline value={{ en: "25 Years of Faith", "zh-Hant": "25年的信心與成長", "zh-Hans": "25年的信心与成长" }} />
        </h2>
      </div>

      <!-- Timeline -->
      <div class="timeline-root">
        {history.map((entry, i) => {
          const isLeft = i % 2 === 0;
          const hasImages = entry.images && entry.images.length > 0;
          return (
            <div class={`timeline-entry timeline-entry--${isLeft ? "left" : "right"}`} data-year={entry.year}>

              {/* ── Card ── */}
              <div class="timeline-card">
                {/* Year pill (mobile only) */}
                <span class="timeline-year-pill">
                  {entry.year}
                </span>

                {/* Description */}
                <p class="text-ink-3 leading-relaxed text-sm md:text-base">
                  <span class="st-i18n">
                    <span class="st-lang st-lang-en">{resolveLocalizedSlot(entry, "en")}</span>
                    <span class="st-lang st-lang-zh-Hant">{resolveLocalizedSlot(entry, "zh-Hant")}</span>
                    <span class="st-lang st-lang-zh-Hans">{resolveLocalizedSlot(entry, "zh-Hans")}</span>
                  </span>
                </p>

                {/* Images */}
                {hasImages && (
                  <div class="mt-4 flex flex-col gap-2">
                    {entry.images!.map((src) => (
                      <img
                        src={`${withBaseUrl(src)}`}
                        alt={`Crosspoint Church ${entry.year}`}
                        class="w-full rounded-lg object-cover max-h-44"
                        loading="lazy"
                      />
                    ))}
                  </div>
                )}
              </div>

              {/* ── Year Badge (desktop) ── */}
              <div class="timeline-badge" aria-hidden="true">
                <span>{entry.year}</span>
              </div>

              {/* ── Spacer column (desktop) ── */}
              <div class="timeline-spacer" aria-hidden="true" />

            </div>
          );
        })}
      </div>

    </div>
  </section>

  <!-- ── Testimonies ───────────────────────────────────────────────────── -->
  <section class="py-20 bg-[#0d1b2e]">
    <div class="container">

      <div class="text-center mb-12">
        <p class="eyebrow text-secondary-400 mb-3">
          <LocalizedInline value={{ en: "Hear from Our Members", "zh-Hant": "聆聽弟兄姊妹的見證", "zh-Hans": "聆听弟兄姊妹的见证" }} />
        </p>
        <h2 class="font-serif font-bold text-white" style="font-size: var(--font-section-major);">
          <LocalizedInline value={{ en: "Our Testimonies", "zh-Hant": "信仰見證", "zh-Hans": "信仰见证" }} />
        </h2>
      </div>

      <div class="testimonies-grid">
        {testimonies.map((t) => (
          <div class="testimony-card">
            <video
              controls
              preload="metadata"
              playsinline
              class="testimony-video"
              {...(t.poster ? { poster: t.poster } : {})}
              data-thumb-offset={t.poster ? undefined : "1"}
              aria-label={`Testimony by ${t.name}`}
            >
              <source src={`${withBaseUrl("/uploads/testimonies/${encodeURIComponent(t.file)")}}`} type="video/mp4" />
              Your browser does not support the video tag.
            </video>
            <p class="testimony-name">{t.name}</p>
          </div>
        ))}
      </div>

    </div>
  </section>


  <!-- ── CTA ────────────────────────────────────────────────────────────── -->
  <section
    class="py-20 bg-cover bg-center text-white"
    style={`background-image: linear-gradient(rgba(13,59,106,0.88), rgba(31,110,179,0.80)), url(${ctaBackgroundImage})`}
  >
    <div class="container">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="font-serif font-bold text-white mb-4" style="font-size: var(--font-section-major);">
          <LocalizedInline value={{ en: "Come Visit Us", "zh-Hant": "歡迎蒞臨", "zh-Hans": "欢迎莅临" }} />
        </h2>
        <p class="text-white/80 text-lg mb-8">
          <LocalizedInline value={{
            en: "We'd love to meet you. Find a campus near you and join us this Sunday.",
            "zh-Hant": "我們很期待與您見面。尋找離您最近的會堂，這個主日與我們同聚。",
            "zh-Hans": "我们很期待与您见面。寻找离您最近的会堂，这个主日与我们同聚。"
          }} />
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href={`${import.meta.env.BASE_URL}campus`} class="btn btn-secondary">
            <LocalizedInline value={{ en: "Find a Campus", "zh-Hant": "尋找會堂", "zh-Hans": "寻找会堂" }} />
          </a>
          <a href={`${import.meta.env.BASE_URL}contact`} class="btn btn-ghost-white">
            <LocalizedInline value={{ en: "Contact Us", "zh-Hant": "聯絡我們", "zh-Hans": "联络我们" }} />
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll(".testimony-video[data-thumb-offset]").forEach((el) => {
      const v = el;
      if (!(v instanceof HTMLVideoElement)) return;
      const raw = v.getAttribute("data-thumb-offset");
      const offset = raw ? parseFloat(raw, 10) : 1;

      v.addEventListener("play", function jumpToStartFromThumbPreview() {
        if (v.dataset.thumbPreview === "1") {
          v.currentTime = 0;
          delete v.dataset.thumbPreview;
          v.removeEventListener("play", jumpToStartFromThumbPreview);
        }
      });

      const seek = () => {
        if (!(v.duration > 0) || Number.isNaN(offset)) return;
        const t = Math.min(offset, Math.max(0, v.duration - 0.05));
        v.addEventListener(
          "seeked",
          () => {
            v.dataset.thumbPreview = "1";
          },
          { once: true },
        );
        v.currentTime = t;
      };
      if (v.readyState >= 1) seek();
      else v.addEventListener("loadedmetadata", seek, { once: true });
    });
  });
</script>

<!-- ─────────────────────────────────────────────────────────────────────────
     Timeline styles
     ─────────────────────────────────────────────────────────────────────── -->
<style>
/* ── Still Standing Banner ── */
.still-standing-banner {
  position: relative;
  width: 100%;
  background: #000;
  color: #fff;
  padding: clamp(4rem, 9vw, 7.5rem) 0;
  overflow: hidden;
  isolation: isolate;
}

.still-standing-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
  background-size: 72px 72px;
  pointer-events: none;
  z-index: 0;
}

.still-standing-title {
  font-family: var(--serif);
  font-weight: 700;
  line-height: 0.95;
  letter-spacing: -0.02em;
  font-size: clamp(3.75rem, 10vw, 8rem);
  margin-bottom: 2rem;
  display: flex;
  flex-wrap: wrap;
  gap: 0 0.35em;
}

.still-standing-white {
  color: #f5efe1;
}

.still-standing-orange {
  color: var(--orange);
  font-style: italic;
}

.still-standing-lede {
  font-family: var(--sans, inherit);
  font-weight: 600;
  color: #fff;
  font-size: clamp(1.1rem, 1.6vw, 1.375rem);
  margin-bottom: 0.75rem;
}

.still-standing-body {
  color: rgba(255, 255, 255, 0.65);
  font-size: clamp(1rem, 1.3vw, 1.125rem);
  line-height: 1.6;
  max-width: 38rem;
  margin-bottom: 2.25rem;
}

.still-standing-btn {
  background: #facc15;
  color: #0a0a0a;
  font-weight: 800;
  letter-spacing: 0.02em;
  padding: 0.9rem 1.75rem;
  font-size: 0.95rem;
  text-transform: uppercase;
  box-shadow: 0 10px 30px rgba(250, 204, 21, 0.25);
  transition: transform 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
}
.still-standing-btn:hover {
  background: #fde047;
  transform: translateY(-2px);
  box-shadow: 0 14px 36px rgba(250, 204, 21, 0.35);
}
.still-standing-btn:focus-visible {
  outline: 2px solid #fde047;
  outline-offset: 3px;
}

/* ── Testimonies ── */
.testimonies-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.5rem;
  max-width: 56rem;
  margin-inline: auto;
}

@media (min-width: 640px) {
  .testimonies-grid {
    grid-template-columns: repeat(2, 1fr);
  }
  /* 5th item: center it spanning both columns */
  .testimonies-grid > *:last-child:nth-child(odd) {
    grid-column: 1 / -1;
    max-width: calc(50% - 0.75rem);
    margin-inline: auto;
    width: 100%;
  }
}

.testimony-card {
  display: flex;
  flex-direction: column;
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.09);
  border-radius: 1rem;
  overflow: hidden;
}

.testimony-video {
  width: 100%;
  aspect-ratio: 16 / 9;
  display: block;
  background: #000;
}

.testimony-name {
  padding: 0.75rem 1rem;
  font-family: var(--serif);
  font-weight: 600;
  font-size: 0.95rem;
  color: rgba(255,255,255,0.85);
  text-align: center;
}

/* ── Shared ── */
.timeline-root {
  position: relative;
  max-width: 56rem;
  margin-inline: auto;
}

.timeline-card {
  background: #fff;
  border-radius: 1rem;
  box-shadow: 0 2px 12px rgba(26,20,16,0.08);
  padding: 1.5rem;
  transition: box-shadow 0.25s var(--ease, ease);
}
.timeline-card:hover {
  box-shadow: 0 6px 28px rgba(26,20,16,0.13);
}

/* ── Mobile: single-column ── */
.timeline-entry {
  display: flex;
  flex-direction: column;
  margin-bottom: 1.5rem;
}

/* Same chrome as desktop `.timeline-badge` (blue circle + cream ring), for mobile stack */
.timeline-year-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 4rem;
  height: 4rem;
  border-radius: 50%;
  background: #1f6eb3;
  color: #fff;
  font-weight: 700;
  font-family: var(--serif);
  font-size: 1.1rem;
  line-height: 1.1;
  text-align: center;
  margin-bottom: 0.75rem;
  flex-shrink: 0;
  box-shadow: 0 0 0 4px #fff, 0 0 0 6px var(--cream-3, #e8ded0);
}

/* Hide desktop badge on mobile */
.timeline-badge { display: none; }
.timeline-spacer { display: none; }

/* ── Desktop: three-column grid with centre line ── */
@media (min-width: 768px) {
  /* Vertical centre line */
  .timeline-root::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--cream-3, #e8ded0);
    transform: translateX(-50%);
  }

  .timeline-year-pill { display: none; }
  .timeline-badge { display: flex; }
  .timeline-spacer { display: block; }

  .timeline-entry {
    display: grid;
    grid-template-columns: 1fr 5rem 1fr;
    grid-template-rows: auto;
    column-gap: 1.5rem;
    align-items: start;
    margin-bottom: 3rem;
    flex-direction: unset;
  }

  /* LEFT entries: card col-1, badge col-2, spacer col-3 */
  .timeline-entry--left .timeline-card    { grid-column: 1; grid-row: 1; text-align: right; }
  .timeline-entry--left .timeline-badge   { grid-column: 2; grid-row: 1; }
  .timeline-entry--left .timeline-spacer  { grid-column: 3; grid-row: 1; }

  /* RIGHT entries: spacer col-1, badge col-2, card col-3 */
  .timeline-entry--right .timeline-spacer { grid-column: 1; grid-row: 1; }
  .timeline-entry--right .timeline-badge  { grid-column: 2; grid-row: 1; }
  .timeline-entry--right .timeline-card   { grid-column: 3; grid-row: 1; text-align: left; }

  /* Year badge circle (center column on timeline) */
  .timeline-badge {
    width: 4rem;
    height: 4rem;
    border-radius: 50%;
    background: #1f6eb3;
    color: #fff;
    font-weight: 700;
    font-family: var(--serif);
    font-size: 1.1rem;
    align-items: center;
    justify-content: center;
    text-align: center;
    box-shadow: 0 0 0 4px #fff, 0 0 0 6px var(--cream-3, #e8ded0);
    z-index: 1;
    position: relative;
    margin-top: 0.375rem; /* align with first line of card text */
    flex-shrink: 0;
    line-height: 1.1;
  }

  /* Connector lines from badge to card */
  .timeline-entry--left .timeline-badge::before,
  .timeline-entry--right .timeline-badge::after {
    content: '';
    position: absolute;
    top: 50%;
    width: 1.5rem;
    height: 2px;
    background: var(--cream-3, #e8ded0);
    transform: translateY(-50%);
  }
  .timeline-entry--left .timeline-badge::before  { right: 100%; }
  .timeline-entry--right .timeline-badge::after  { left: 100%; }
}

/* ── Scroll-entrance animation ── */
@media (prefers-reduced-motion: no-preference) {
  .timeline-card {
    opacity: 0;
    transform: translateY(1.25rem);
    transition: opacity 0.5s ease, transform 0.5s ease, box-shadow 0.25s ease;
  }
  .timeline-card.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
}
</style>

<script>
  // Trigger scroll-entrance animation for timeline cards
  const cards = document.querySelectorAll<HTMLElement>('.timeline-card');
  if (typeof IntersectionObserver !== 'undefined') {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            io.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 }
    );
    cards.forEach((card) => io.observe(card));
  } else {
    // Fallback: show all immediately
    cards.forEach((card) => card.classList.add('is-visible'));
  }
</script>
