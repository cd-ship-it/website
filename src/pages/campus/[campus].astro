---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import LocalizedInline from "../../components/UI/LocalizedInline.astro";
import { getEventsApiUrl, getSermonApiUrl, isCampusExcludedFromOrangeKids } from "../../config/site";

export async function getStaticPaths() {
  const campuses = await getCollection("campus", ({ data }) => !data.draft);
  return campuses.map((entry) => ({
    params: { campus: entry.data.campusId.toLowerCase().replace(/\s+/g, "-") },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const {
  campusId,
  hero,
  introTagline,
  description,
  emotionalHighlights,
  quickFacts,
  firstVisitNotes,
  photoShowcase,
  googleMapsUrl,
  googleMapsZoom,
  lifeGroupDirectoryUrl,
  seo,
  wpEventCategoryId,
} = entry.data;

/** Maps Embed API supports `zoom`; `pb=` embeds ignore it — zoom is baked into `pb`. */
function googleMapIframeSrc(url: string, zoom?: number): string {
  if (!url || zoom == null) return url;
  try {
    const u = new URL(url);
    if (u.pathname.includes("/maps/embed/v1/")) {
      u.searchParams.set("zoom", String(zoom));
      return u.toString();
    }
  } catch {
    /* invalid URL */
  }
  return url;
}

const mapIframeSrc = googleMapsUrl ? googleMapIframeSrc(googleMapsUrl, googleMapsZoom) : "";

const showOrangeKidsPromoOnCampusPage = !isCampusExcludedFromOrangeKids(campusId);

// Pull service times for this campus from service-times.md
const siteInfoEntries = await getCollection("siteInfo");
const serviceTimesEntry = siteInfoEntries.find((e) => e.slug === "service-times");
const campusServiceData = serviceTimesEntry?.data.campuses?.find((c) => {
  const name = typeof c.campusName === "string" ? c.campusName : c.campusName.en;
  return name === campusId;
});

const heroAlt = typeof hero.alt === "string" ? hero.alt : hero.alt.en;
const showHeroOrangeBlueGradient =
  (hero as { gradient?: boolean }).gradient === true;
const campusDisplayName =
  campusServiceData?.campusName ?? { en: campusId };

function getEnglishValue(value: unknown): string {
  if (typeof value === "string") return value;
  if (value && typeof value === "object" && "en" in value && typeof (value as { en?: unknown }).en === "string") {
    return (value as { en: string }).en;
  }
  return "";
}

function languageTagsFromServices(services: unknown[] | undefined): string[] {
  if (!services?.length) return [];
  const found = new Set<string>();
  for (const item of services) {
    const text = getEnglishValue(item).toLowerCase();
    if (text.includes("cantonese")) found.add("Cantonese");
    if (text.includes("mandarin")) found.add("Mandarin");
    if (text.includes("english")) found.add("English");
    if (text.includes("youth")) found.add("Youth");
  }
  return Array.from(found);
}

const languageTags = languageTagsFromServices(campusServiceData?.services as unknown[] | undefined);

const SERMON_API_URL = getSermonApiUrl();
const EVENTS_API_URL = getEventsApiUrl();
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  image={{ url: hero.image, alt: heroAlt }}
>
  <!-- ── Hero ─────────────────────────────────────────────────────────────── -->
  <section class="relative min-h-[320px] md:min-h-[380px] flex items-center justify-center overflow-hidden">
    <img
      src={hero.image}
      alt={heroAlt}
      class="absolute inset-0 w-full h-full object-cover"
    />
    {showHeroOrangeBlueGradient ? (
      <div
        class="pointer-events-none absolute inset-0 z-[1] bg-gradient-to-br from-secondary-500/80 via-secondary-400/35 to-primary-600/85"
        aria-hidden="true"
      />
    ) : null}
    <div class="relative z-10 container text-center">
      <p class="text-white/70 text-sm font-semibold tracking-widest uppercase mb-2">
        <LocalizedInline value={{ en: "Crosspoint Church", "zh-Hant": "匯點教會", "zh-Hans": "匯點教會" }} />
      </p>
      <h1 class="text-5xl md:text-7xl font-bold text-white leading-none">
        <LocalizedInline value={campusDisplayName} />
      </h1>
      {introTagline && (
        <p class="mt-5 text-base md:text-lg text-white/85 max-w-3xl mx-auto leading-relaxed">
          <LocalizedInline value={introTagline} />
        </p>
      )}
    </div>
  </section>

  <section class="bg-white border-b border-cream-3">
    <div class="container py-6">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
        <div class="xp-panel-inner bg-cream p-4">
          <p class="text-xs uppercase tracking-widest text-muted mb-1">
            <LocalizedInline value={{ en: "Worship Day", "zh-Hant": "聚會日", "zh-Hans": "聚会日" }} />
          </p>
          <p class="font-semibold text-ink">
            <LocalizedInline value={campusServiceData?.worshipDate ?? { en: "See service times below", "zh-Hant": "請參考下方崇拜時間", "zh-Hans": "请参考下方崇拜时间" }} />
          </p>
        </div>
        <div class="xp-panel-inner bg-cream p-4">
          <p class="text-xs uppercase tracking-widest text-muted mb-1">
            <LocalizedInline value={{ en: "Languages", "zh-Hant": "語言", "zh-Hans": "语言" }} />
          </p>
          <p class="font-semibold text-ink">
            {languageTags.length > 0 ? languageTags.join(" • ") : "See service times"}
          </p>
        </div>
        <div class="xp-panel-inner bg-cream p-4">
          <p class="text-xs uppercase tracking-widest text-muted mb-1">
            <LocalizedInline value={{ en: "Address", "zh-Hant": "地址", "zh-Hans": "地址" }} />
          </p>
          <p class="font-semibold text-ink">
            <LocalizedInline value={quickFacts?.address ?? { en: "See map below", "zh-Hant": "請參考下方地圖", "zh-Hans": "请参考下方地图" }} />
          </p>
        </div>
        <div class="xp-panel-inner bg-cream p-4 flex items-center justify-between gap-3">
          <div>
            <p class="text-xs uppercase tracking-widest text-muted mb-1">
              <LocalizedInline value={{ en: "Plan Your Visit", "zh-Hant": "規劃你的行程", "zh-Hans": "规划你的行程" }} />
            </p>
            <p class="text-sm text-muted">
              <LocalizedInline value={quickFacts?.region ?? { en: "Get directions before you come", "zh-Hant": "先查看路線更方便", "zh-Hans": "先查看路线更方便" }} />
            </p>
          </div>
          {googleMapsUrl ? (
            <a href={googleMapsUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary whitespace-nowrap">
              <LocalizedInline value={{ en: "Directions", "zh-Hant": "路線", "zh-Hans": "路线" }} />
            </a>
          ) : null}
        </div>
      </div>
    </div>
  </section>

  <!-- ── Campus Description ───────────────────────────────────────────────── -->
  <section class="py-16 bg-white">
    <div class="container max-w-5xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-[1.35fr_1fr] gap-10 items-start">
        <div class="xp-panel-inner bg-cream p-6 md:p-7">
          <p class="text-xs uppercase tracking-widest text-muted mb-3">
            <LocalizedInline value={{ en: "About this campus", "zh-Hant": "關於這個會堂", "zh-Hans": "关于这个会堂" }} />
          </p>
          <p class="text-lg md:text-xl text-muted leading-relaxed max-w-[68ch]">
            <LocalizedInline value={description} />
          </p>
        </div>
        {emotionalHighlights?.length ? (
          <div class="xp-panel-inner bg-cream p-6">
            <h2 class="text-lg font-bold mb-4">
              <LocalizedInline value={{ en: "Why people stay here", "zh-Hant": "為何大家留在這裡", "zh-Hans": "为何大家留在这里" }} />
            </h2>
            <ul class="space-y-3 text-sm text-muted leading-relaxed">
              {emotionalHighlights.map((item) => (
                <li class="flex gap-2">
                  <span class="mt-1 h-1.5 w-1.5 rounded-full bg-secondary-500 shrink-0" aria-hidden="true"></span>
                  <span><LocalizedInline value={item} /></span>
                </li>
              ))}
            </ul>
          </div>
        ) : null}
      </div>
    </div>
  </section>

  {photoShowcase?.length ? (
    <section class="py-16 bg-cream">
      <div class="container">
        <div class="flex items-end justify-between gap-4 mb-8">
          <h2 class="text-2xl font-bold">
            <LocalizedInline value={{ en: "Campus Life", "zh-Hant": "會堂生活", "zh-Hans": "会堂生活" }} />
          </h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
          {photoShowcase.map((photo) => (
            <figure class="xp-panel-inner bg-white overflow-hidden">
              <img src={photo.image} alt={typeof photo.alt === "string" ? photo.alt : photo.alt.en} class="h-52 w-full object-cover" loading="lazy" />
            </figure>
          ))}
        </div>
      </div>
    </section>
  ) : null}

  <!-- ── Service Times + Google Map ───────────────────────────────────────── -->
  <section class="py-16 bg-white">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">

        <!-- Service Times -->
        <div>
          <h2 class="text-2xl font-bold mb-6">
            <LocalizedInline value={{ en: "Service Times", "zh-Hant": "崇拜時間", "zh-Hans": "崇拜时间" }} />
          </h2>
          {campusServiceData ? (
            <div class="xp-panel-inner bg-white p-8">
              <span class="inline-block px-3 py-1 bg-primary-100 text-primary-800 text-xs font-semibold rounded-full uppercase tracking-widest mb-6">
                <LocalizedInline value={campusServiceData.worshipDate} />
              </span>
              <ul class="space-y-4">
                {campusServiceData.services.map((service) => (
                  <li class="flex items-center gap-3 text-base md:text-lg">
                    <svg class="h-5 w-5 text-primary-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <span><LocalizedInline value={service} /></span>
                  </li>
                ))}
              </ul>
            </div>
          ) : (
            <p class="text-muted">
              <LocalizedInline value={{ en: "Service time information coming soon.", "zh-Hant": "崇拜時間即將更新。", "zh-Hans": "崇拜时间即将更新。" }} />
            </p>
          )}
          {showOrangeKidsPromoOnCampusPage ? (
            <!-- Children's program (omitted for campuses in orangeKidsExcludedCampuses) -->
            <div class="mt-10">
              <h2 class="text-2xl font-bold mb-6">
                <LocalizedInline value={{ en: "Childcare and Children's Program", "zh-Hant": "托兒服務及兒童活動", "zh-Hans": "托儿服務及儿童活动" }} />
              </h2>
              <div class="xp-panel-inner bg-white p-8">
                <p class="body-copy mb-6">
 <LocalizedInline value={{ en: "We provide childcare services and children's programs for your little ones during worship service times.", 
 "zh-Hant": "我們提供托兒服務及兒童活動，讓您的小孩在我們的主日崇拜時間得到照顧。", "zh-Hans": "我们提供托儿服务及儿童活动，让您的小孩在我们的主日崇拜时间得到照顾。" }} />
                </p>
                <a class="btn btn-primary" href="/orangekids">
                  <LocalizedInline value={{ en: "Learn more >", "zh-Hant": "查看更多 >", "zh-Hans": "查看更多 >" }} />
                </a>
              </div>
            </div>
          ) : null}

          {lifeGroupDirectoryUrl ? (
            <div class="mt-10">
              <h3 class="text-xl font-bold mb-4">
                <LocalizedInline
                  value={{en: "Life Group Directory","zh-Hant": "小組目錄","zh-Hans": "小组目录"}}
                />
              </h3>
              <a
                href={lifeGroupDirectoryUrl}
                class="inline-flex items-center justify-center rounded-lg bg-primary-600 px-5 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-primary-700"
                target="_blank"
                rel="noopener noreferrer"
              >
                <LocalizedInline
                  value={{
                    en: "View directory","zh-Hant": "查看目錄","zh-Hans": "查看目录",
                  }}
                />
              </a>
            </div>
          ) : null}
            

            


        </div>

        <!-- Google Map -->
        <div>
          <h2 class="text-2xl font-bold mb-6">
            <LocalizedInline value={{ en: "Location", "zh-Hant": "地點", "zh-Hans": "地点" }} />
          </h2>
          <div class="xp-panel-inner overflow-hidden aspect-video bg-cream-2 flex items-center justify-center">
            {googleMapsUrl ? (
              <iframe
                src={mapIframeSrc}
                width="100%"
                height="100%"
                style="border:0; display:block;"
                allowfullscreen
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title={`Map of ${campusId} campus`}
              ></iframe>
            ) : (
              <p class="text-muted text-sm">
                <LocalizedInline value={{ en: "Map coming soon", "zh-Hant": "地圖即將提供", "zh-Hans": "地图即将提供" }} />
              </p>
            )}
          </div>
          {firstVisitNotes && (
            <div class="xp-panel-inner bg-cream p-6 mt-6">
              <h3 class="text-lg font-bold mb-4">
                <LocalizedInline value={{ en: "First visit tips", "zh-Hant": "第一次來的提示", "zh-Hans": "第一次来的提示" }} />
              </h3>
              <ul class="space-y-3 text-sm text-muted">
                {firstVisitNotes.parking && (
                  <li>
                    <strong class="text-ink">
                      <LocalizedInline value={{ en: "Parking:", "zh-Hant": "停車：", "zh-Hans": "停车：" }} />
                    </strong>{" "}
                    <LocalizedInline value={firstVisitNotes.parking} />
                  </li>
                )}
                {firstVisitNotes.arrival && (
                  <li>
                    <strong class="text-ink">
                      <LocalizedInline value={{ en: "Arrival:", "zh-Hant": "抵達：", "zh-Hans": "抵达：" }} />
                    </strong>{" "}
                    <LocalizedInline value={firstVisitNotes.arrival} />
                  </li>
                )}
                {firstVisitNotes.kidsCheckIn && (
                  <li>
                    <strong class="text-ink">
                      <LocalizedInline value={{ en: "Kids check-in:", "zh-Hant": "兒童報到：", "zh-Hans": "儿童报到：" }} />
                    </strong>{" "}
                    <LocalizedInline value={firstVisitNotes.kidsCheckIn} />
                  </li>
                )}
              </ul>
            </div>
          )}
        </div>

      </div>
    </div>
  </section>

  <!-- ── Recent Sermons + Upcoming Events ─────────────────────────────────── -->
  <section class="py-16 bg-white">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">

        <!-- Recent Sermons -->
        <div>
          <div class="flex items-center justify-between mb-6">
            <h2 class="text-2xl font-bold">
              <LocalizedInline value={{ en: "Recent Sermons", "zh-Hant": "最新講道", "zh-Hans": "最新讲道" }} />
            </h2>
            <a href="/sermons" class="text-sm text-primary-600 font-medium hover:underline">
              <LocalizedInline value={{ en: "View all →", "zh-Hant": "查看全部 →", "zh-Hans": "查看全部 →" }} />
            </a>
          </div>

          <!-- Loading skeleton -->
          <div id="sermons-loading" class="space-y-4">
            {Array.from({ length: 3 }).map(() => (
              <div class="bg-cream-2 rounded-lg p-4 animate-pulse flex gap-4">
                <div class="bg-gray-200 rounded w-24 h-16 shrink-0"></div>
                <div class="flex-1 space-y-2 py-1">
                  <div class="h-4 bg-gray-200 rounded w-3/4"></div>
                  <div class="h-3 bg-gray-200 rounded w-1/2"></div>
                  <div class="h-3 bg-gray-200 rounded w-1/3"></div>
                </div>
              </div>
            ))}
          </div>

          <div id="sermons-list" class="space-y-4 hidden"></div>
          <div id="sermons-empty" class="hidden text-center py-10 bg-cream rounded-lg">
            <p class="text-muted">
              <LocalizedInline value={{ en: "Online sermons coming soon.", "zh-Hant": "線上講道即將提供", "zh-Hans": "線上講道即將提供" }} />
            </p>
          </div>
          <div id="sermons-error" class="hidden text-center py-10 bg-red-50 rounded-lg">
            <p class="text-red-600 text-sm">Could not load sermons. Please try again later.</p>
          </div>
        </div>

        <!-- Upcoming Events -->
        <div>
          <div class="flex items-center justify-between mb-6">
            <h2 class="text-2xl font-bold">
              <LocalizedInline value={{ en: "Upcoming Events", "zh-Hant": "即將舉行的活動", "zh-Hans": "即将举行的活动" }} />
            </h2>
            <a href="/events" class="text-sm text-primary-600 font-medium hover:underline">
              <LocalizedInline value={{ en: "View all →", "zh-Hant": "查看全部 →", "zh-Hans": "查看全部 →" }} />
            </a>
          </div>

          <!-- Loading skeleton -->
          <div id="events-loading" class="space-y-4">
            {Array.from({ length: 3 }).map(() => (
              <div class="bg-cream-2 rounded-lg p-4 animate-pulse flex gap-4">
                <div class="bg-gray-200 rounded w-16 h-16 shrink-0"></div>
                <div class="flex-1 space-y-2 py-1">
                  <div class="h-4 bg-gray-200 rounded w-3/4"></div>
                  <div class="h-3 bg-gray-200 rounded w-1/2"></div>
                  <div class="h-3 bg-gray-200 rounded w-1/3"></div>
                </div>
              </div>
            ))}
          </div>

          <div id="events-list" class="space-y-4 hidden"></div>
          <div id="events-empty" class="hidden text-center py-10 bg-cream rounded-lg">
            <p class="text-muted">
              <LocalizedInline value={{ en: "No upcoming events for this campus.", "zh-Hant": "此會堂暫無即將舉行的活動。", "zh-Hans": "此会堂暂无即将举行的活动。" }} />
            </p>
          </div>
          <div id="events-error" class="hidden text-center py-10 bg-red-50 rounded-lg">
            <p class="text-red-600 text-sm">Could not load events. Please try again later.</p>
          </div>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>

<script define:vars={{ SERMON_API_URL, EVENTS_API_URL, campusId, wpEventCategoryId }}>
  // ── Shared helpers ─────────────────────────────────────────────────────────
  function esc(str) {
    return (str ?? "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;");
  }

  function formatDate(dateStr) {
    return new Date(dateStr + "T00:00:00").toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
      day: "numeric",
    });
  }

  function monthLabel(dateStr) {
    return new Date(dateStr + "T00:00:00")
      .toLocaleDateString("en-US", { month: "short" })
      .toUpperCase();
  }

  function dayNum(dateStr) {
    return new Date(dateStr + "T00:00:00").toLocaleDateString("en-US", { day: "2-digit" });
  }

  function weekDay(dateStr) {
    return new Date(dateStr + "T00:00:00").toLocaleDateString("en-US", { weekday: "short" });
  }

  function show(id) { document.getElementById(id)?.classList.remove("hidden"); }
  function hide(id) { document.getElementById(id)?.classList.add("hidden"); }

  // ── Sermons ────────────────────────────────────────────────────────────────
  const LANG_COLORS = {
    English:   "bg-primary-100 text-primary-800",
    Cantonese: "bg-secondary-100 text-secondary-800",
    Mandarin:  "bg-accent-100 text-accent-800",
  };

  function langBadge(lang) {
    const labels = { English: "English", Cantonese: "粵語", Mandarin: "國語" };
    const label = labels[lang] ?? lang;
    const color = LANG_COLORS[lang] ?? "bg-cream-2 text-ink-3";
    return `<span class="inline-block px-2 py-0.5 text-xs font-medium rounded-full ${color}">${esc(label)}</span>`;
  }

  function sermonCard(sermon) {
    const thumb = `https://img.youtube.com/vi/${esc(sermon.youtube_id)}/mqdefault.jpg`;
    const preacher = [sermon.preacher_chi, sermon.preacher_eng].filter(Boolean).join(" · ") || "—";
    return `
      <a href="/sermons/${esc(sermon.youtube_id)}"
         class="flex gap-4 items-start bg-cream-2 hover:bg-cream rounded-lg p-4 transition-colors group">
        <div class="relative shrink-0 w-28 rounded overflow-hidden aspect-video bg-gray-200">
          <img src="${thumb}" alt="${esc(sermon.sermon_title)}"
               class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
               loading="lazy"
               onerror="this.src='/uploads/sermon-placeholder.webp'" />
        </div>
        <div class="min-w-0 flex-1">
          <div class="flex items-start justify-between gap-2 mb-1">
            <h3 class="font-semibold text-sm leading-snug line-clamp-2 flex-1">${esc(sermon.sermon_title)}</h3>
            ${langBadge(sermon.language)}
          </div>
          <p class="text-xs text-muted">${esc(formatDate(sermon.date))}</p>
          <p class="text-xs text-muted">${esc(preacher)}</p>
          <p class="text-xs text-primary-600 font-medium mt-1 group-hover:underline">Watch →</p>
        </div>
      </a>
    `;
  }

  async function loadSermons() {
    const url = new URL(SERMON_API_URL);
    url.searchParams.set("location", campusId);
    url.searchParams.set("per_page", "4");

    try {
      const res = await fetch(url.toString(), { cache: "no-store" });
      if (!res.ok) throw new Error();
      const json = await res.json();
      const sermons = Array.isArray(json) ? json : (json.data ?? []);

      hide("sermons-loading");

      if (!sermons.length) {
        show("sermons-empty");
        return;
      }

      document.getElementById("sermons-list").innerHTML = sermons.map(sermonCard).join("");
      show("sermons-list");
    } catch {
      hide("sermons-loading");
      show("sermons-error");
    }
  }

  // ── Events ─────────────────────────────────────────────────────────────────
  function rendered(v) {
    if (typeof v === "string") return v;
    return typeof v?.rendered === "string" ? v.rendered : "";
  }

  function pickStr(obj, keys) {
    for (const k of keys) {
      const v = obj?.[k];
      if (typeof v === "string" && v.trim()) return v.trim();
    }
    return "";
  }

  function normalizeDate(input) {
    if (!input) return "";
    const m = String(input).match(/^(\d{4}-\d{2}-\d{2})/);
    if (m) return m[1];
    const d = new Date(input);
    return isNaN(d.getTime()) ? "" : d.toISOString().slice(0, 10);
  }

  function normalizeEvent(raw) {
    const rec = (raw && typeof raw === "object") ? raw : {};
    const acf = (rec.acf && typeof rec.acf === "object") ? rec.acf : {};
    const title =
      rendered(rec.title) ||
      pickStr(rec, ["event_title", "name", "title"]) ||
      pickStr(acf, ["event_title", "name", "title"]) ||
      "Untitled Event";
    const startDate = normalizeDate(
      pickStr(rec, ["start_date", "startDate", "event_start_date", "date"]) ||
      pickStr(acf, ["start_date", "startDate", "event_start_date", "date"])
    );
    const endDate = normalizeDate(
      pickStr(rec, ["end_date", "endDate", "event_end_date"]) ||
      pickStr(acf, ["end_date", "endDate", "event_end_date"])
    ) || undefined;
    const time =
      pickStr(rec, ["time", "event_time", "start_time"]) ||
      pickStr(acf, ["time", "event_time", "start_time"]) || undefined;
    const location =
      pickStr(rec, ["location", "venue_name"]) ||
      pickStr(acf, ["location", "venue_name"]) || undefined;
    return { title, startDate, endDate, time, location };
  }

  function eventCard(event) {
    const dateRange = event.endDate && event.endDate !== event.startDate
      ? `${formatDate(event.startDate)} – ${formatDate(event.endDate)}`
      : formatDate(event.startDate);
    const when = event.time ? `${dateRange} • ${event.time}` : dateRange;

    return `
      <div class="flex gap-4 items-start bg-cream-2 rounded-lg p-4">
        <div class="shrink-0 rounded-lg overflow-hidden border border-gray-200 w-16 h-16 text-center bg-white">
          <div class="bg-secondary-500 text-ink text-micro-label py-0.5">
            ${esc(monthLabel(event.startDate))}
          </div>
          <div class="text-xl font-bold text-heading leading-tight pt-1">
            ${esc(dayNum(event.startDate))}
          </div>
          <div class="text-xs text-muted">
            ${esc(weekDay(event.startDate))}
          </div>
        </div>
        <div class="min-w-0 flex-1">
          <h3 class="font-semibold text-sm leading-snug line-clamp-2 mb-1">${esc(event.title)}</h3>
          <p class="text-xs text-muted">${esc(when)}</p>
          ${event.location ? `<p class="text-xs text-muted mt-0.5 line-clamp-1">${esc(event.location)}</p>` : ""}
        </div>
      </div>
    `;
  }

  async function loadEvents() {
    const today = new Date().toISOString().slice(0, 10);

    // Build the events URL with WordPress category filter
    const url = new URL(EVENTS_API_URL);
    if (wpEventCategoryId) url.searchParams.set("category", String(wpEventCategoryId));
    url.searchParams.set("per_page", "3");

      console.log(url.toString());
    try {
      const res = await fetch(url.toString(), { cache: "no-store" });
      if (!res.ok) throw new Error();
      const json = await res.json();

      const raw = Array.isArray(json) ? json : (Array.isArray(json?.data) ? json.data : []);
      const events = raw
        .map(normalizeEvent)
        .filter((e) => e.startDate && e.startDate >= today)
        .sort((a, b) => a.startDate.localeCompare(b.startDate))
        .slice(0, 4);

      hide("events-loading");

      if (!events.length) {
        show("events-empty");
        return;
      }

      document.getElementById("events-list").innerHTML = events.map(eventCard).join("");
      show("events-list");
    } catch {
      hide("events-loading");
      show("events-error");
    }
  }

  // ── Boot ───────────────────────────────────────────────────────────────────
  document.addEventListener("DOMContentLoaded", () => {
    loadSermons();
    loadEvents();
  });
</script>
