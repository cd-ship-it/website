---
import { getEntry } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/Sections/PageHeader.astro";
import Button from "../components/UI/Button.astro";
import LocalizedInline from "../components/UI/LocalizedInline.astro";
import { pickLocalizedText } from "../lib/i18n";
import ServiceTimesCampuses from "../components/Sections/ServiceTimesCampuses.astro";
import { getServiceTimesCampuses } from "../lib/siteInfo/serviceTimes";


const page =
  (await getEntry("pages", "im-new.md")) ??
  (await getEntry("pages", "im-new"));
if (!page || page.data.pageKind !== "im-new") {
  throw new Error('Content entry "pages/im-new" not found or wrong pageKind.');
}
const data = page.data;
const campuses = await getServiceTimesCampuses();

const iconPaths: Record<string, string> = {
  clock: "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z",
  music: "M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3",
  book: "M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253",
};
---

<BaseLayout
  title={pickLocalizedText(data.seo.title, "en")}
  description={pickLocalizedText(data.seo.description, "en")}
>
  <PageHeader
    title={data.pageHeader.title}
    subtitle={data.pageHeader.subtitle}
    backgroundImage={data.pageHeader.backgroundImage}
  />
  
  <!-- What to Expect -->
  <section class="py-16">
    <div class="container">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4"><LocalizedInline value={data.expectSection.heading} /></h2>
        <p class="text-xl text-muted max-w-3xl mx-auto">
          <LocalizedInline value={data.expectSection.subheading} />
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {data.expectSection.cards.map((card) => (
        <div class="text-center p-6">
          <div class="w-20 h-20 mx-auto mb-4 rounded-full bg-primary-100 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={iconPaths[card.icon]} />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3"><LocalizedInline value={card.title} /></h3>
          <p class="body-copy">
            <LocalizedInline value={card.body} />
          </p>
        </div>
        ))}
      </div>
    </div>
  </section>
  
  
  <!-- Service Times -->
  <section class="panel panel--services xp-panel-shell">
    <div class="xp-panel-inner">
      {campuses.length > 0 && (
        <ServiceTimesCampuses campuses={campuses} />
      )}
    </div>
  </section>
  
  <!-- For Kids -->
  <section id="kids" class="py-16 bg-cream">
    <div class="container">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold mb-6"><LocalizedInline value={data.kidsSection.heading} /></h2>
          <p class="body-copy text-lg mb-6">
            <LocalizedInline value={data.kidsSection.intro} />
          </p>
          
          <ul class="space-y-4 mb-6">
            {data.kidsSection.items.map((item) => (
              <li class="flex items-start">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary-600 mr-2 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="body-copy mb-0 flex-1">
                <strong><LocalizedInline value={item.title} />:</strong> <LocalizedInline value={item.body} />
              </span>
            </li>
            ))}
          </ul>
          
          <p class="body-copy mb-6">
            <LocalizedInline value={data.kidsSection.safetyNote} />
          </p>
          
          <Button href={data.kidsSection.ctaHref}>
            <LocalizedInline value={data.kidsSection.ctaText} />
          </Button>
        </div>
        
        <div>
          <img 
            src={data.kidsSection.image}
            alt={pickLocalizedText(data.kidsSection.imageAlt, "en")}
            class="rounded-lg shadow-lg object-cover w-full h-full"
          />
        </div>
      </div>
    </div>
  </section>

  
  <!-- FAQ -->
  <section class="py-16 bg-cream">
    <div class="container">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4"><LocalizedInline value={data.faqSection.heading} /></h2>
        <p class="text-xl text-muted max-w-3xl mx-auto">
          <LocalizedInline value={data.faqSection.subheading} />
        </p>
      </div>
      <div class="max-w-4xl mx-auto space-y-4">
        {data.faqSection.items.map((item) => (
          <div class="xp-panel-inner p-6">
            <h3 class="text-xl font-bold mb-2"><LocalizedInline value={item.question} /></h3>
            <p class="body-copy mb-0"><LocalizedInline value={item.answer} /></p>
          </div>
        ))}
      </div>
    </div>
  </section>
  
  <!-- Plan Your Visit CTA -->
  <section id="volunteer" class="py-20 bg-cover bg-center text-white"
    style={`background-image: linear-gradient(rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.6)), url(${data.visitCta.backgroundImage})`}
  >
    <div class="container">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold mb-6 text-white"><LocalizedInline value={data.visitCta.heading} /></h2>
        <p class="text-xl mb-8">
          <LocalizedInline value={data.visitCta.body} />
        </p>
        
        <div class="flex flex-wrap justify-center gap-4">
          <Button href={data.visitCta.contactHref} variant="primary" size="lg">
            <LocalizedInline value={data.visitCta.contactText} />
          </Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>