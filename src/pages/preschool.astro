---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Crosspoint Preschool · No longer in operation"
  description="Crosspoint Preschool has closed. Thank you for your interest."
>
  <section
    class="container flex flex-col items-center justify-center px-4 py-16 min-h-[calc(100vh-12rem)] text-center"
  >
    <h1 class="text-2xl md:text-3xl font-serif font-bold text-heading max-w-2xl">
      Thank you for visiting
    </h1>
    <p class="text-muted mt-6 max-w-xl text-lg leading-relaxed">
      Crosspoint Preschool is no longer in operation. We are grateful for every family who was part of
      our community over the years.
    </p>
    <div class="mt-10 flex flex-wrap justify-center gap-3">
      <a href="/" class="btn btn-primary">Crosspoint Church home</a>
    </div>
  </section>
</BaseLayout>
