---
import type { GetStaticPaths } from "astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  fetchExplicitWordPressItemsById,
  fetchWordPressItemsByCategorySlug,
  mergeWordPressMirrorItems,
  parseWordPressIds,
  type WpMirrorItem,
} from "../../lib/wordpress/mirror";

interface StaticPathProps extends Record<string, unknown> {
  item: WpMirrorItem;
  slugLower: string;
}

export const getStaticPaths: GetStaticPaths = async () => {
  const categorySlug = import.meta.env.PUBLIC_WP_MIRROR_CATEGORY_SLUG ?? "wp_mirror";
  const mirrorIds = parseWordPressIds(import.meta.env.PUBLIC_WP_MIRROR_IDS);

  const [explicitItems, categoryItems] = await Promise.all([
    fetchExplicitWordPressItemsById(mirrorIds),
    fetchWordPressItemsByCategorySlug(categorySlug),
  ]);
  const mergedItems = mergeWordPressMirrorItems(categoryItems, explicitItems);

  const paths: Array<{ params: { slug: string }; props: StaticPathProps }> = [];
  const seenRouteSlugs = new Set<string>();

  for (const item of mergedItems) {
    const canonicalSlug = item.slug;
    const slugLower = canonicalSlug.toLowerCase();
    const routeCandidates = canonicalSlug === slugLower ? [canonicalSlug] : [canonicalSlug, slugLower];

    for (const routeSlug of routeCandidates) {
      if (seenRouteSlugs.has(routeSlug)) {
        continue;
      }
      seenRouteSlugs.add(routeSlug);
      paths.push({
        params: { slug: routeSlug },
        props: { item, slugLower },
      });
    }
  }

  return paths;
};

const { item } = Astro.props as unknown as StaticPathProps;
---

<BaseLayout title={item.title.rendered || "WordPress Mirror"}>
  <main class="wp-mirror-page">
    <article>
      <h1 set:html={item.title.rendered} />
      <div class="wp-mirror-content" set:html={item.content.rendered} />
    </article>
  </main>
</BaseLayout>

