---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroSection from "../components/Sections/HeroSection.astro";
import Ticker from "../components/Sections/Ticker.astro";
import HomeSecondHero from "../components/Sections/home-second-hero.astro";
import EventList from "../components/Sections/EventList.astro";
import SermonList from "../components/Sections/SermonList.astro";
import FinalCTA from "../components/Sections/FinalCTA.astro";
import ServiceTimesCampuses from "../components/Sections/ServiceTimesCampuses.astro";
import NewToCrosspoint from "../components/Sections/new-to-crosspoint.astro";
import { getCollection } from "astro:content";
import type { LocalizedText } from "../lib/i18n";

const siteInfoEntries = await getCollection("siteInfo");
const matchSiteInfo = (key: string) =>
  siteInfoEntries.find(
    (item) =>
      item.id === key ||
      item.slug === key ||
      item.id.endsWith(`/${key}`) ||
      item.id.endsWith(`/${key}.md`) ||
      item.id === `${key}.md`,
  );

// ── Hero ─────────────────────────────────────────────────────────────────────
const homeHeroEntry = matchSiteInfo("home-hero");
const hero = homeHeroEntry?.data.hero;

const serviceTimesEntry = matchSiteInfo("service-times");
const campuses = (serviceTimesEntry?.data.campuses ?? []) as Array<{
  campusName: string | LocalizedText;
  worshipDate: string | LocalizedText;
  services: (string | LocalizedText)[];
}>;
const sectionHeading = serviceTimesEntry?.data.sectionHeading as LocalizedText | undefined;

---

<BaseLayout>
  <div class="panel-deck">
    <!-- PANEL 1 — HERO -->
    <section class="panel panel--hero">
      <div class="panel-inner">
        
        {hero ? (
          <HeroSection
            title={hero.heroTitle}
            subtitle={hero.heroSubtitle}
            backgroundImage={hero.backgroundImage}
            ctaText={hero.ctaText}
            ctaLink={hero.ctaLink}
            secondaryCtaText={hero.secondaryCtaText}
            secondaryCtaLink={hero.secondaryCtaLink}
          />
        ) : (
          <HeroSection />
        )}
      
        
      </div>
      <!-- Ticker -->
        <Ticker />
    </section>
    
    <section class="panel panel--services xp-panel-shell">
      <div class="xp-panel-inner">
        {sectionHeading && campuses.length > 0 && (
          <ServiceTimesCampuses sectionHeading={sectionHeading} campuses={campuses} />
        )}
      </div>
    </section>

    <!-- PANEL 2 — Second hero -->
    <section class="panel panel--secondhero xp-panel-shell">
      <div class="xp-panel-inner">
        <HomeSecondHero />
      </div>
    </section>

    <!-- PANEL 3 — Newtocrosspoint -->
    <section class="panel panel--pathways xp-panel-shell">
      <div class="xp-panel-inner">
        <NewToCrosspoint variant="pathways" />
      </div>
    </section>

    <!-- PANEL 4 — events -->
    <section class="panel panel--events xp-panel-shell">
      <div class="xp-panel-inner">
        <EventList />
      </div>
    </section>

    <!-- PANEL 6 — sermons -->
    <section class="panel panel--sermons xp-panel-shell">
      <div class="xp-panel-inner">
        <SermonList variant="home" />
      </div>
    </section>

    <!-- PANEL 7 — CTA -->
    <section class="panel panel--cta xp-panel-shell">
      <div class="xp-panel-inner">
        <FinalCTA />
      </div>
    </section>
  </div>
  

</BaseLayout>
