---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroSection from "../components/Sections/HeroSection.astro";
import Ticker from "../components/Sections/Ticker.astro";
import HomeSecondHero from "../components/Sections/home-second-hero.astro";
import EventList from "../components/Sections/EventList.astro";
import SermonList from "../components/Sections/SermonList.astro";
import FinalCTA from "../components/Sections/FinalCTA.astro";
import ServiceTimesCampuses from "../components/Sections/ServiceTimesCampuses.astro";
import NewToCrosspoint from "../components/Sections/new-to-crosspoint.astro";
import { getEntry } from "astro:content";
import { getServiceTimesData } from "../lib/siteInfo/serviceTimes";

// Use getEntry (not getCollection().find) so we resolve the canonical slug and avoid
// duplicate-id glob warnings where the first match can be stale relative to the last.
// ── Hero ─────────────────────────────────────────────────────────────────────
const homeHeroEntry =
  (await getEntry("siteInfo", "home-hero.md")) ??
  (await getEntry("siteInfo", "home-hero"));
const hero = homeHeroEntry?.data.hero;

const { campuses, sectionHeading } = await getServiceTimesData();

const homeGsapDisabled =
  import.meta.env.PUBLIC_HOME_GSAP_DISABLED === "true" ||
  import.meta.env.PUBLIC_HOME_GSAP_DISABLED === "1";

---

<BaseLayout
  title="Crosspoint Church · San Francisco Bay Area & Tri-Valley"
  description="Crosspoint Church serves the San Francisco Bay Area and Tri-Valley with worship, community, and faith for every season."
>
  <div class="panel-deck">
    <!-- PANEL 1 — HERO -->
    <section class="panel panel--hero">
      <div class="panel-inner">
        

        {hero ? (
          <HeroSection
            title={hero.heroTitle}
            titleEditorial={hero.heroTitleEditorial}
            subtitle={hero.heroSubtitle}
            backgroundImage={hero.backgroundImage}
            backgroundVideo={hero.backgroundVideo}
            ctaText={hero.ctaText}
            ctaLink={hero.ctaLink}
            secondaryCtaText={hero.secondaryCtaText}
            secondaryCtaLink={hero.secondaryCtaLink}
          />
        ) : (
          <HeroSection />
        )}
      
        
      </div>
      <!-- Ticker -->
        <!-- <Ticker /> -->
    </section>
    
    <section class="panel panel--services">
      {sectionHeading && campuses.length > 0 && (
        <ServiceTimesCampuses sectionHeading={sectionHeading} campuses={campuses} />
      )}
    </section>

    <!-- PANEL 2 — Second hero -->
    <section class="panel panel--secondhero">
      <HomeSecondHero />
    </section>

    <!-- PANEL 3 — Newtocrosspoint -->
    <!-- <section class="panel panel--pathways">
      <NewToCrosspoint variant="pathways" />
    </section> -->

    <!-- PANEL 4 — events -->
    <section class="panel panel--events">
      <EventList />
    </section>

    <!-- PANEL 6 — sermons -->
    <section class="panel panel--sermons">
      <SermonList variant="home" />
    </section>

    <!-- PANEL 7 — CTA -->
    <section class="panel panel--cta">
      <FinalCTA />
    </section>
  </div>

  {!homeGsapDisabled ? (
    <script>
      import { initHomePageGsap } from "../scripts/home-page-gsap";
      initHomePageGsap();
    </script>
  ) : null}

</BaseLayout>
