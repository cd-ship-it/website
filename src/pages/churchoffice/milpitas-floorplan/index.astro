---
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout title="Milpitas Floor Plan | Crosspoint Church Office" description="Milpitas church office floor plan.">
  <section class="py-10">
    <div class="container max-w-5xl">
      <h1 class="mb-6 text-3xl font-semibold text-primary-700">Milpitas Floor Plan</h1>
      <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
        <iframe
          src="https://drive.google.com/file/d/0B-rDvRrEG54IdjcwMjh2ckNVTG8/preview"
          class="h-[530px] w-full"
          loading="lazy"
          allow="autoplay"
          title="Milpitas Floor Plan"
        ></iframe>
      </div>
    </div>
  </section>
</BaseLayout>
