---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Pleasanton Room Calendar | Crosspoint Church Office" description="Reserve a room in Pleasanton.">
  <section class="py-10">
    <div class="container max-w-4xl">
      <h1 class="mb-6 text-3xl font-semibold text-primary-700">To Reserve a Room in Pleasanton</h1>

      <h2 class="mb-2 text-xl font-semibold text-primary-700">Step 1</h2>
      <p class="mb-3 text-ink-2">Check the calendar below for free slot(s).</p>
      <p class="mb-8">
        <a
          class="text-secondary-600 underline hover:text-secondary-700"
          href="https://calendar.google.com/calendar/u/0/embed?src=xptplroom@gmail.com&ctz=America/Los_Angeles"
          target="_blank"
          rel="noopener noreferrer"
        >
          Open Pleasanton room calendar
        </a>
      </p>

      <h2 class="mb-2 text-xl font-semibold text-primary-700">Step 2</h2>
      <p class="text-ink-2">
        Fill out the reservation form:
        <a
          class="text-secondary-600 underline hover:text-secondary-700"
          href="https://docs.google.com/forms/d/e/1FAIpQLScvp7_9KR1h818zVKpoGJt2JcMrTT2BN1I5XD-DTgD9zD2pyA/viewform"
          target="_blank"
          rel="noopener noreferrer"
        >
          room reservation form
        </a>.
      </p>
    </div>
  </section>
</BaseLayout>
