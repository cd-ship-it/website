---
import { fetchAllSermons, fetchSermon, buildSermonUrl } from "../../lib/sermonApi";
import { htmlLangFromSermonLanguage } from "../../lib/htmlLang";

export async function getStaticPaths() {
  const sermons = await fetchAllSermons();
  return sermons.map((sermon) => ({
    params: { slug: sermon.youtube_id },
    props: { youtube_id: sermon.youtube_id },
  }));
}

const { youtube_id } = Astro.props as { youtube_id: string };
const sermon = await fetchSermon(youtube_id).catch(() => null);
const newUrl = sermon ? buildSermonUrl(sermon) : '/sermons';

const htmlLang = htmlLangFromSermonLanguage(sermon?.language);
---
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="refresh" content={`0;url=${newUrl}`} />
    <link rel="canonical" href={newUrl} />
  </head>
  <body>
    <script define:vars={{ newUrl }}>window.location.replace(newUrl);</script>
    <p>Redirecting… <a href={newUrl}>Click here if not redirected.</a></p>
  </body>
</html>
