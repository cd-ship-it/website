  ---
  import BaseLayout from "../../layouts/BaseLayout.astro";
  import PageHeader from "../../components/Sections/PageHeader.astro";
  import Button from "../../components/UI/Button.astro";
import { fetchAllSermons, fetchSermon } from "../../lib/sermonApi";
  import type { Sermon } from "../../lib/sermonApi";
  import { LANG_LABELS, LANG_COLORS } from "../../lib/sermons/constants";
  import { formatDateLong, preacherLabel } from "../../lib/sermons/format";
import { withBaseUrl } from "../../lib/urls";

type SermonSummarySection = {
  heading?: string;
  summary?: string;
  timestamps?: string[];
  bible_references?: string[];
};

type SermonSummaryPayload = {
  excerpt?: string;
  key_takeaways?: string[];
  sections?: SermonSummarySection[];
};

function parseSummaryPayload(raw: string): SermonSummaryPayload | null {
  const trimmed = (raw ?? "").trim();
  if (!trimmed) return null;
  const fenced = trimmed.match(/^```(?:json)?\s*([\s\S]*?)\s*```$/i);
  const source = (fenced?.[1] ?? trimmed).trim();
  if (!source.startsWith("{") || !source.endsWith("}")) return null;
  try {
    const parsed = JSON.parse(source) as SermonSummaryPayload;
    return parsed && typeof parsed === "object" ? parsed : null;
  } catch {
    return null;
  }
}

  export async function getStaticPaths() {
    const sermons = await fetchAllSermons();
    return sermons.map((sermon) => ({
      params: { slug: sermon.youtube_id },
      props: { sermon },
    }));
  }

  const { sermon } = Astro.props as { sermon: Sermon };
  const latest = await fetchSermon(sermon.youtube_id).catch(() => null);
  const sermonData: Sermon = latest
    ? {
        ...sermon,
        ...latest,
        // Prevent empty strings from clobbering list values.
        sermon_title: latest.sermon_title || sermon.sermon_title,
        preacher_chi: latest.preacher_chi || sermon.preacher_chi,
        preacher_eng: latest.preacher_eng || sermon.preacher_eng,
        location: latest.location || sermon.location,
        language: latest.language || sermon.language,
        summary: latest.summary || sermon.summary,
      }
    : sermon;

  const preacher = preacherLabel(sermonData.preacher_chi, sermonData.preacher_eng);
  const formattedDate = formatDateLong(sermonData.date);
  const langLabel = LANG_LABELS[sermonData.language] ?? sermonData.language;
  const langColor = LANG_COLORS[sermonData.language] ?? 'bg-cream-2 text-ink-3';
const parsedSummary = parseSummaryPayload(sermonData.summary);
const transcriptTextRaw =
  latest && typeof latest === "object" && "transcript" in latest && typeof (latest as Record<string, unknown>).transcript === "string"
    ? ((latest as Record<string, unknown>).transcript as string).trim()
    : "";
const transcriptText =
  transcriptTextRaw &&
  transcriptTextRaw.toLowerCase() !== "null" &&
  transcriptTextRaw.toLowerCase() !== "undefined"
    ? transcriptTextRaw
    : "";
  ---

  <BaseLayout
    title={`${sermonData.sermon_title} - Sermons - Crosspoint Church`}
    description={sermonData.summary || `Watch "${sermonData.sermon_title}" by ${preacher}`}
    type="article"
  >
    <!-- <PageHeader
      title={sermon.sermon_title}
      backgroundImage={`${withBaseUrl("/uploads/sermons-header-bg.webp")}`}
    /> -->

    <section class="py-12">
      <div class="container max-w-4xl mx-auto">

 

        <!-- YouTube embed -->
        <div class="mb-8">
          <div class="relative w-full rounded-xl overflow-hidden shadow-lg" style="padding-top: 56.25%;">
            <iframe
              class="absolute inset-0 w-full h-full"
              src={`https://www.youtube.com/embed/${sermonData.youtube_id}`}
              title={sermonData.sermon_title}
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            ></iframe>
          </div>
        </div>
       <!-- Sermon meta -->
      <div class="bg-cream rounded-xl p-6 mb-8 grid grid-cols-2 gap-4">
        <div class="flex items-start gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mt-0.5 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
          <div>
            <p class="text-xs font-semibold text-muted uppercase tracking-wide mb-0.5">Preacher</p>
            <p class="font-medium text-gray-900">{preacher}</p>
          </div>
        </div>

        <div class="flex items-start gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mt-0.5 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
