  ---
  import BaseLayout from "../../layouts/BaseLayout.astro";
  import PageHeader from "../../components/Sections/PageHeader.astro";
  import Button from "../../components/UI/Button.astro";
  import { fetchAllSermons } from "../../lib/sermonApi";
  import type { Sermon } from "../../lib/sermonApi";
  import { LANG_LABELS, LANG_COLORS } from "../../lib/sermons/constants";
  import { formatDateLong, preacherLabel } from "../../lib/sermons/format";
import { withBaseUrl } from "../../lib/urls";

  export async function getStaticPaths() {
    const sermons = await fetchAllSermons();
    return sermons.map((sermon) => ({
      params: { slug: sermon.youtube_id },
      props: { sermon },
    }));
  }

  const { sermon } = Astro.props as { sermon: Sermon };

  const preacher = preacherLabel(sermon.preacher_chi, sermon.preacher_eng);
  const formattedDate = formatDateLong(sermon.date);
  const langLabel = LANG_LABELS[sermon.language] ?? sermon.language;
  const langColor = LANG_COLORS[sermon.language] ?? 'bg-cream-2 text-ink-3';
  ---

  <BaseLayout
    title={`${sermon.sermon_title} - Sermons - Crosspoint Church`}
    description={sermon.summary || `Watch "${sermon.sermon_title}" by ${preacher}`}
    type="article"
  >
    <!-- <PageHeader
      title={sermon.sermon_title}
      backgroundImage={`${withBaseUrl("/uploads/sermons-header-bg.webp")}`}
    /> -->

    <section class="py-12">
      <div class="container max-w-4xl mx-auto">

 

        <!-- YouTube embed -->
        <div class="mb-8">
          <div class="relative w-full rounded-xl overflow-hidden shadow-lg" style="padding-top: 56.25%;">
            <iframe
              class="absolute inset-0 w-full h-full"
              src={`https://www.youtube.com/embed/${sermon.youtube_id}`}
              title={sermon.sermon_title}
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            ></iframe>
          </div>
        </div>
       <!-- Sermon meta -->
      <div class="bg-cream rounded-xl p-6 mb-8 grid grid-cols-2 gap-4">
        <div class="flex items-start gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mt-0.5 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
          <div>
            <p class="text-xs font-semibold text-muted uppercase tracking-wide mb-0.5">Preacher</p>
            <p class="font-medium text-gray-900">{preacher}</p>
          </div>
        </div>

        <div class="flex items-start gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mt-0.5 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          <div>
            <p class="text-xs font-semibold text-muted uppercase tracking-wide mb-0.5">Date</p>
            <p class="font-medium text-gray-900">{formattedDate}</p>
          </div>
        </div>

        <div class="flex items-start gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mt-0.5 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <div>
            <p class="text-xs font-semibold text-muted uppercase tracking-wide mb-0.5">Location</p>
            <p class="font-medium text-gray-900">{sermon.location}</p>
          </div>
        </div>

        <div class="flex items-start gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mt-0.5 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129" />
          </svg>
          <div>
            <p class="text-xs font-semibold text-muted uppercase tracking-wide mb-0.5">Language</p>
            <span class={`inline-block px-2 py-0.5 text-xs font-medium rounded-full ${langColor}`}>
              {langLabel}
            </span>
          </div>
        </div>
      </div>        

        <!-- Summary -->
        {sermon.summary && (
          <div class="bg-primary-50 border-l-4 border-primary-600 rounded-r-xl p-6 mb-8">
            <h2 class="text-lg font-bold text-heading mb-2">Summary</h2>
          <div
            class="text-primary-800 leading-relaxed [&_ul]:list-disc [&_ul]:pl-6 [&_ol]:list-decimal [&_ol]:pl-6 [&_li]:my-1"
            set:html={sermon.summary}
          ></div>
          
          </div>
        )}

        <!-- Actions -->
        <div class="flex flex-wrap gap-4 mt-8">
          <Button href={`${import.meta.env.BASE_URL}sermons`} variant="outline">
            ← Back to All Sermons
          </Button>
          <Button
            href={`https://www.youtube.com/watch?v=${sermon.youtube_id}`}
            variant="primary"
            target="_blank"
          >
            Watch on YouTube ↗
          </Button>
        </div>

      </div>
    </section>
  </BaseLayout>
