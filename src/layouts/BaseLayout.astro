---
import "../assets/styles/global.css";
import Seo from "../components/UI/Seo.astro";
import Header from "../components/Global/Header.astro";
import Footer from "../components/Global/Footer.astro";

export interface Props {
  title?: string;
  description?: string;
  image?: {
    url: string;
    alt: string;
  };
  type?: "website" | "article";
  canonicalUrl?: string;
}

const {
  title = "Church Name - A Welcoming Christian Community",
  description = "We are a welcoming Christian community dedicated to sharing God's love through worship, fellowship, and service.",
  image = {
    url: "/uploads/church-default.webp",
      alt: "Church Namxe",
  },
  type = "website",
  canonicalUrl,
} = Astro.props;

type SiteLang = "en" | "zh-Hant" | "zh-Hans";
const VALID_LANGS: SiteLang[] = ["en", "zh-Hant", "zh-Hans"];

function normalizeLang(input?: string): SiteLang {
  return (VALID_LANGS as string[]).includes(input ?? "") ? (input as SiteLang) : "en";
}

/**
 * Prerender/static builds: do not read cookies (that touches request headers).
 * Initial HTML uses English; the inline script below syncs lang from storage/cookie in the browser.
 */
const initialLang = normalizeLang("en");
---

<!doctype html>
<html lang={initialLang} data-lang={initialLang}>
  <head>
    <meta charset="UTF-8" />
    <!-- Sync language before paint so LocalizedInline + CSS match stored preference (static HTML defaults to en). -->
    <script is:inline>
      (function () {
        var VALID = ["en", "zh-Hant", "zh-Hans"];
        function norm(v) {
          return VALID.indexOf(v) !== -1 ? v : "en";
        }
        var key = "site_lang";
        var lang = null;
        try {
          lang = localStorage.getItem(key);
        } catch (e) {}
        if (!lang || VALID.indexOf(lang) === -1) {
          var m = document.cookie.match(/(?:^|; )site_lang=([^;]+)/);
          if (m) {
            try {
              lang = decodeURIComponent(m[1]);
            } catch (e2) {}
          }
        }
        lang = norm(lang || "en");
        document.documentElement.lang = lang;
        document.documentElement.setAttribute("data-lang", lang);
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <Seo
      title={title}
      description={description}
      image={image}
      type={type}
      canonicalUrl={canonicalUrl}
    />

    
    
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">
  </head>
  <body>
    <div class="flex flex-col min-h-screen">
      <Header />
      
      <main class="flex-grow">
        <slot />
      </main>
      
      <Footer />
    </div>
  </body>
</html>