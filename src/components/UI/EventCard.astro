---
import type { EventItem } from "../../lib/eventApi";

export interface Props {
  event: EventItem;
  featured?: boolean;
}

const { event, featured = false } = Astro.props as Props;

function monthLabel(dateStr: string) {
  return new Date(`${dateStr}T00:00:00`)
    .toLocaleDateString("en-US", { month: "short" })
    .toUpperCase();
}

function dayNum(dateStr: string) {
  return new Date(`${dateStr}T00:00:00`).toLocaleDateString("en-US", { day: "2-digit" });
}

function weekDay(dateStr: string) {
  return new Date(`${dateStr}T00:00:00`).toLocaleDateString("en-US", { weekday: "short" });
}

function fullDate(dateStr: string) {
  return new Date(`${dateStr}T00:00:00`).toLocaleDateString("en-US", {
    month: "short",
    day: "numeric",
    weekday: "short",
    year: "numeric",
  });
}

function rangeLabel(startDate: string, endDate?: string, time?: string) {
  const start = fullDate(startDate);
  const end = endDate && endDate !== startDate ? fullDate(endDate) : "";
  const dateText = end ? `${start} - ${end}` : start;
  return time ? `${dateText} • ${time}` : dateText;
}
---

<a
  href={`/events/${encodeURIComponent(event.slug)}`}
  class:list={[
    "group block bg-white border border-cream-3 hover:shadow-lg hover:border-secondary-300 transition-all duration-300 cursor-pointer focus:outline-none focus:ring-2 focus:ring-secondary-400",
    featured
      ? "p-6 md:p-8 flex flex-col md:flex-row gap-6 items-start rounded-2xl hover:-translate-y-1"
      : "xp-panel-inner p-5 flex flex-col hover:-translate-y-1",
  ]}
>
  <div class:list={["flex gap-4 items-start", featured ? "md:flex-row flex-row w-full" : ""]}>
    <div class:list={[
      "shrink-0 rounded-xl overflow-hidden border border-gray-200 text-center bg-white",
      featured ? "w-24 h-24" : "w-20 h-20",
    ]}>
      <div class="bg-secondary-500 text-ink text-micro-label py-1">{monthLabel(event.startDate)}</div>
      <div class:list={["font-bold text-heading leading-tight pt-2", featured ? "text-4xl" : "text-2xl"]}>{dayNum(event.startDate)}</div>
      <div class="text-xs text-muted pb-2">{weekDay(event.startDate)}</div>
    </div>
    <div class="min-w-0 flex-1">
      {featured && (
        <span class="inline-block mb-2 px-2.5 py-0.5 text-xs font-bold tracking-wider uppercase bg-secondary-500 text-ink rounded-full">
          Featured Event
        </span>
      )}
      <h3 class:list={["font-bold text-heading mb-2", featured ? "text-2xl line-clamp-2" : "text-lg line-clamp-2"]}>{event.title}</h3>
      <p class="text-sm text-muted mb-2">{rangeLabel(event.startDate, event.endDate, event.time)}</p>
      {event.location && <p class="text-sm text-muted mb-2 line-clamp-1">{event.location}</p>}
      <p class:list={["font-medium text-secondary-600 group-hover:text-secondary-500 group-hover:underline transition-colors", featured ? "mt-4 text-base" : "mt-3 text-sm"]}>See details →</p>
    </div>
  </div>
</a>
