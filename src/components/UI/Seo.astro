---
import { withBaseUrl } from "../../lib/urls";
import { serializeJsonLd } from "../../lib/serializeJsonLd";
export interface Props {
  title: string;
  description: string;
  image?: {
    url: string;
    alt: string;
  };
  type?: "website" | "article";
  canonicalUrl?: string;
  /** Article JSON-LD only: e.g. sermon preacher name */
  articleAuthor?: string;
}

const {
  title,
  description,
  image = {
    url: `${withBaseUrl("/uploads/church-default.webp")}`,
    alt: "Crosspoint Church",
  },
  type = "website",
  canonicalUrl,
  articleAuthor,
} = Astro.props;

// Get the canonical URL
const canonicalURL = canonicalUrl || new URL(Astro.url.pathname, Astro.site);
const canonicalHref =
  typeof canonicalURL === "string" ? canonicalURL : canonicalURL.href;

// Get Church address and contact info (would come from site config in a real implementation)
const churchInfo = {
  name: "Crosspoint Church",
  address: {
    streetAddress: "658 Gibraltar Ct",
    addressLocality: "Milpitas",
    addressRegion: "CA",
    postalCode: "95035",
    addressCountry: "US",
  },
  telephone: "+1-408-586-8688",
  email: "com@crosspointchurchsv.org",
  url: Astro.site?.toString() || "https://crosspointchurchsv.org",
};

/** Major SF Bay Area & Tri-Valley cities for LocalBusiness-style discovery (schema.org areaServed). */
const bayAreaCityNames = [
  "San Francisco",
  "Oakland",
  "San Jose",
  "Fremont",
  "Hayward",
  "Berkeley",
  "Livermore",
  "Dublin",
  "San Ramon",
  "Danville",
  "Walnut Creek",
];

const churchJsonLd = {
  "@context": "https://schema.org",
  "@type": "Church",
  name: churchInfo.name,
  address: {
    "@type": "PostalAddress",
    streetAddress: churchInfo.address.streetAddress,
    addressLocality: churchInfo.address.addressLocality,
    addressRegion: churchInfo.address.addressRegion,
    postalCode: churchInfo.address.postalCode,
    addressCountry: churchInfo.address.addressCountry,
  },
  telephone: churchInfo.telephone,
  email: churchInfo.email,
  url: churchInfo.url,
  areaServed: bayAreaCityNames.map((name) => ({ "@type": "City" as const, name })),
};

const articleAuthorName = articleAuthor?.trim() || "";

const articleJsonLd =
  type === "article"
    ? {
        "@context": "https://schema.org",
        "@type": "Article",
        headline: title,
        image: new URL(image.url, Astro.site).href,
        description,
        ...(articleAuthorName
          ? {
              author: {
                "@type": "Person" as const,
                name: articleAuthorName,
              },
            }
          : {}),
        publisher: {
          "@type": "Organization",
          name: churchInfo.name,
          logo: {
            "@type": "ImageObject",
            url: new URL(`${withBaseUrl("/uploads/logo.png")}`, Astro.site).href,
          },
        },
        url: canonicalHref,
        mainEntityOfPage: {
          "@type": "WebPage",
          "@id": canonicalHref,
        },
      }
    : null;

const churchJsonLdHtml = serializeJsonLd(churchJsonLd);
const articleJsonLdHtml = articleJsonLd ? serializeJsonLd(articleJsonLd) : null;
---

<!-- Basic SEO -->
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalHref} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalHref} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image.url, Astro.site)} />
<meta property="og:image:alt" content={image.alt} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalHref} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL(image.url, Astro.site)} />
<meta property="twitter:image:alt" content={image.alt} />

<!-- JSON-LD Schema for Church -->
{churchJsonLdHtml && (
  <script type="application/ld+json" set:html={churchJsonLdHtml} />
)}

{
  articleJsonLdHtml && (
    <script type="application/ld+json" set:html={articleJsonLdHtml} />
  )
}