---
import type { Sermon } from "../../lib/sermonApi";
import { LANG_LABELS, LANG_COLORS } from "../../lib/sermons/constants";
import { formatDateLong, preacherLabel, summaryPreview, sermonThumb } from "../../lib/sermons/format";
import { withBaseUrl } from "../../lib/urls";

export interface Props {
  sermon: Sermon;
  summaryWordLimit?: number;
  /** `home`: adds `sermon-card sermon-card--home`, hides description/summary. */
  variant?: "default" | "home";
}

const { sermon, summaryWordLimit = 30, variant = "default" } = Astro.props as Props;
const isHome = variant === "home";
const showDescription = !isHome;

const thumb = sermonThumb(sermon.youtube_id);
const preacher = preacherLabel(sermon.preacher_chi, sermon.preacher_eng);
const date = formatDateLong(sermon.date);
const langLabel = LANG_LABELS[sermon.language] ?? sermon.language;
const langColor = LANG_COLORS[sermon.language] ?? "bg-cream-2 text-ink-3";
const summaryText = showDescription ? summaryPreview(sermon.summary, summaryWordLimit) : "";---

<a
  href={`/sermons/${sermon.youtube_id}`}
  class:list={[
    "group overflow-hidden block xp-panel-inner bg-white hover:shadow-xl transition-all duration-300",
    isHome && "sermon-card--home",
  ]}
>
  <div class="relative w-full overflow-hidden pb-[56.25%]">
    <img
      src={thumb}
      alt={sermon.sermon_title}
      class="absolute inset-0 w-full h-full object-cover transition-transform duration-300 group-hover:scale-105 block"
      loading="lazy"
      onerror={`this.src='${withBaseUrl("/uploads/sermon-placeholder.webp'")}`}
    />
  </div>
  <div class="p-5">
    <div class="flex items-start justify-between gap-2 mb-2">
      <h3 class="text-lg font-bold leading-snug line-clamp-2 flex-1">{sermon.sermon_title}</h3>
      <span class={`shrink-0 inline-block px-2 py-0.5 text-xs font-medium rounded-full ${langColor}`}>
        {langLabel}
      </span>
    </div>
    <div class="flex items-center text-sm text-muted mb-1 gap-1">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
      </svg>
      <span>{date}</span>
    </div>
    <div class="flex items-center text-sm text-muted mb-1 gap-1">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
      </svg>
      <span>{preacher}</span>
    </div>
    <div
      class:list={[
        "flex items-center text-sm text-muted gap-1",
        showDescription ? "mb-3" : "mb-1",
      ]}
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
      </svg>
      <span>{sermon.location}</span>
    </div>
    {summaryText && <p class="text-muted text-sm mb-4 leading-relaxed">{summaryText}</p>}
    <p class="text-secondary-600 font-medium text-sm group-hover:text-secondary-500 group-hover:underline transition-colors">Watch / 觀看 →</p>
  </div>
</a>
