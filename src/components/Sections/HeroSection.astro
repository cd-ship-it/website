---
import Button from "../UI/Button.astro";
import LocalizedInline from "../UI/LocalizedInline.astro";
import type { LocalizedText } from "../../lib/i18n";

type LText = string | LocalizedText;

export interface Props {
  title?: LText;
  subtitle?: LText;
  backgroundImage?: string;
  ctaText?: LText;
  ctaLink?: string;
  secondaryCtaText?: LText;
  secondaryCtaLink?: string;
}

const {
  title            = { en: "Welcome to Crosspoint", "zh-Hant": "歡迎來到匯點教會", "zh-Hans": "欢迎来到汇点教会" },
  subtitle         = { en: "25 Years Strong. Still Moving Forward in Faith.", "zh-Hant": "25 年恩典。繼續在信仰中前行。", "zh-Hans": "25 年恩典。继续在信仰中前行。" },
  backgroundImage  = "https://crosspointchurchsv.org/wp-content/uploads/2026/03/HistoryHero2.jpg",
  ctaText          = { en: "Plan Your Visit",  "zh-Hant": "計劃探訪",  "zh-Hans": "计划探访" },
  ctaLink          = "/im-new",
  secondaryCtaText = { en: "Watch Sermons",    "zh-Hant": "觀看講道",  "zh-Hans": "观看讲道" },
  secondaryCtaLink = "/sermons",
} = Astro.props;
---

<section
  class="relative flex items-end bg-cover bg-center"
  style={`
    background-image: url(${backgroundImage});
    min-height: 100svh;
    min-height: 100vh;
  `}
>
  <!-- Overlay: subtle gradient from transparent top to dark bottom -->
  <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(26,20,16,0.15) 0%, rgba(26,20,16,0.72) 65%, rgba(26,20,16,0.88) 100%);"></div>

  <div class="container relative z-10 pb-20 pt-40">
    <div class="max-w-3xl">
      <p class="text-secondary-400 text-xs font-semibold tracking-widest uppercase mb-4">Crosspoint Church · Silicon Valley</p>
      <h1 class="font-serif font-bold text-white mb-6 leading-tight text-hero">
        <LocalizedInline value={title} />
      </h1>
      <p class="text-white/80 text-lg md:text-xl mb-10 max-w-2xl leading-relaxed">
        <LocalizedInline value={subtitle} />
      </p>

      <div class="flex flex-wrap gap-4">
        <Button href={ctaLink} variant="secondary" size="lg">
          <LocalizedInline value={ctaText} />
        </Button>

        <Button
          href={secondaryCtaLink}
          variant="outline"
          size="lg"
          class="!border-white/40 !text-white hover:!bg-white/15 hover:!border-white/70"
        >
          <LocalizedInline value={secondaryCtaText} />
        </Button>
      </div>
    </div>

    <div class="hero-scroll-hint">
      <span>Scroll</span>
      <div class="hero-scroll-line"></div>
      <div class="hero-scroll-arrow">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9"/>
        </svg>
      </div>
    </div>
  </div>
</section>
