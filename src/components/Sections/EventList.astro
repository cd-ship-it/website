---
import { fetchAllEvents, eventHasFeatureCategory } from "../../lib/eventApi";
import type { EventItem } from "../../lib/eventApi";
import { monthLabel, dayNum, rangeLabel } from "../../lib/events/format";
import Button from "../UI/Button.astro";
import LocalizedInline from "../UI/LocalizedInline.astro";

export interface Props {
  count?: number;
  showViewAll?: boolean;
}

const { count, showViewAll = true } = Astro.props;

let events: EventItem[] = [];
try {
  const allEvents = await fetchAllEvents();
  events = typeof count === "number" ? allEvents.slice(0, count) : allEvents;
} catch {
  events = [];
}

const sorted = [...events].sort(
  (a, b) => new Date(a.startDate).getTime() - new Date(b.startDate).getTime(),
);
const featuredSorted = sorted.filter(eventHasFeatureCategory);
const regularSorted = sorted.filter((e) => !eventHasFeatureCategory(e));
const ordered = [...featuredSorted, ...regularSorted];

const compactEvents = ordered.slice(0, 6);

const featuredInCompact = compactEvents.filter(eventHasFeatureCategory);
const regularInCompact = compactEvents.filter((e) => !eventHasFeatureCategory(e));

function thumbBackgroundStyle(imageUrl: string | undefined): string | undefined {
  const u = imageUrl?.trim();
  if (!u) return undefined;
  return `background-image: url(${JSON.stringify(u)})`;
}

---

<section
  id="events-home"
  class="section-default home-section-block"
  aria-labelledby="events-heading"
>
  <div class="container">
    <div class="home-section-intro pl-5">
      <h2 id="events-heading" class="section-heading">
        <LocalizedInline value={{ en: "Upcoming Events", "zh-Hant": "近期活動", "zh-Hans": "近期活动" }} />
      </h2>
      <p class="section-sub">
        <LocalizedInline
          value={{
            en: "Join us across campuses for upcoming gatherings and ministry events.",
            "zh-Hant": "歡迎你來參與活動。",
            "zh-Hans": "欢迎你來参与活动。",
          }}
        />
      </p>
    </div>

    <div class="home-section-body">
      {compactEvents.length > 0 ? (
        <div class="events-home-wrap">
          {featuredInCompact.length > 0 && (
            <div class="events-home-featured" aria-label="Featured events">
              {featuredInCompact.map((event) => {
                const eventHref = `${import.meta.env.BASE_URL}events/${encodeURIComponent(event.slug)}`;
                return (
                <div class="events-grid-item events-grid-item--featured group">
                  <div class="events-grid-date events-grid-date--featured">
                    <span class="events-grid-month">{monthLabel(event.startDate)}</span>
                    <span class="events-grid-day">{dayNum(event.startDate)}</span>
                  </div>
                  {event.image?.trim() && (
                    <a href={eventHref} class="events-grid-thumb events-grid-thumb--featured">
                      <span
                        class="events-grid-thumb-bg"
                        style={thumbBackgroundStyle(event.image)}
                        role="img"
                        aria-label={event.title}
                      />
                    </a>
                  )}
                  <div class="events-grid-info">
                    <h3 class="events-grid-title events-grid-title--featured">
                      <a href={eventHref} class="events-featured-title-link">{event.title}</a>
                    </h3>
                    <p class="events-grid-meta events-grid-meta--featured">
                      {rangeLabel(event.startDate, event.endDate, event.time)}
                    </p>
                    {event.location && <p class="events-grid-meta events-grid-meta--featured">{event.location}</p>}
                    <div class="events-featured-actions">
                      <Button
                        href={eventHref}
                        variant="secondary"
                        size="md"
                        class="events-featured-cta-btn"
                      >
                        <LocalizedInline
                          value={{ en: "See Details", "zh-Hant": "查看更多", "zh-Hans": "查看更多" }}
                        />
                      </Button>
                    </div>
                  </div>
                </div>
                );
              })}
            </div>
          )}

          {regularInCompact.length > 0 && (
            <div class:list={["events-home-grid", featuredInCompact.length > 0 ? "events-home-grid--below-featured" : ""]}>
              {regularInCompact.map((event) => (
                <a href={`${import.meta.env.BASE_URL}events/${encodeURIComponent(event.slug)}`} class="events-grid-item group">
                  <div class="events-grid-date">
                    <span class="events-grid-month">{monthLabel(event.startDate)}</span>
                    <span class="events-grid-day">{dayNum(event.startDate)}</span>
                  </div>
                  {event.image?.trim() && (
                    <div class="events-grid-thumb">
                      <span
                        class="events-grid-thumb-bg"
                        style={thumbBackgroundStyle(event.image)}
                        role="img"
                        aria-label={event.title}
                      />
                    </div>
                  )}
                  <div class="events-grid-info">
                    <h3 class="events-grid-title">{event.title}</h3>
                    <p class="events-grid-meta">{rangeLabel(event.startDate, event.endDate, event.time)}</p>
                    {event.location && <p class="events-grid-meta">{event.location}</p>}
                    <p class="events-grid-cta">
                      <span class="text-secondary-500">
                        <LocalizedInline
                          value={{ en: "See Details", "zh-Hant": "查看更多", "zh-Hans": "查看更多" }}
                        />
                      </span>
                      <svg width="12" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                        <path d="M5 12h14M12 5l7 7-7 7" />
                      </svg>
                    </p>
                  </div>
                </a>
              ))}
            </div>
          )}
        </div>
      ) : (
        <div class="text-center py-10 bg-cream-2 rounded-2xl">
          <p class="text-muted">No upcoming events available right now.</p>
        </div>
      )}

      {showViewAll && compactEvents.length > 0 && (
        <div class="mt-8 flex justify-end">
          <Button href={`${import.meta.env.BASE_URL}events`} variant="primary" size="lg">
            View all events
          </Button>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .events-home-wrap {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .events-home-featured {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .events-home-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
  }

  .events-home-grid--below-featured {
    margin-top: 0;
  }

  @media (max-width: 767px) {
    .events-home-grid {
      grid-template-columns: 1fr;
    }
  }

  .events-grid-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 1.25rem 1.1rem;
    text-decoration: none;
    color: inherit;
    transition: transform 0.15s;
  }
  .events-grid-item:hover {
    transform: translateX(2px);
  }

  .events-grid-item--featured {
    width: 100%;
    gap: 1.35rem;
    padding: 1.5rem 1.5rem 1.35rem;
    border-radius: 1rem;
    background: var(--secondary-50, #fcecd3);
    border: 1px solid var(--cream-3, #ede8e0);
  }
  .events-grid-item--featured:hover {
    transform: translateX(3px);
    border-color: var(--secondary-300, #c4a574);
  }

  @media (max-width: 767px) {
    .events-grid-item--featured {
      flex-direction: column;
      align-items: center;
      gap: 1rem;
      padding: 1.15rem 1.1rem 1.25rem;
    }
    .events-grid-item--featured:hover {
      transform: none;
    }

    /* Month + day on one row */
    .events-grid-date--featured {
      flex-direction: row;
      align-items: baseline;
      justify-content: center;
      gap: 0.5rem;
      width: 100%;
      min-width: 0;
      padding: 0;
    }
    .events-grid-date--featured .events-grid-month {
      font-size: 0.9375rem;
      letter-spacing: 0.1em;
    }
    .events-grid-date--featured .events-grid-day {
      font-size: 1.65rem;
      margin-top: 0;
      line-height: 1;
    }

    /* Nearly full-width image with horizontal inset inside the card */
    .events-grid-thumb--featured {
      display: block;
      box-sizing: border-box;
      width: calc(100% - 1.25rem);
      max-width: 100%;
      margin-left: auto;
      margin-right: auto;
      height: auto;
      aspect-ratio: 16 / 9;
      max-height: none;
      align-self: center;
    }

    .events-grid-info {
      width: 100%;
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    .events-grid-item--featured .events-grid-info {
      align-items: center;
      text-align: center;
    }

    .events-grid-title--featured {
      font-size: 1.2rem;
      margin-bottom: 0.35rem;
    }

    .events-grid-meta--featured {
      font-size: 0.9rem;
      line-height: 1.45;
    }

    .events-grid-item--featured .events-featured-actions {
      margin-top: 0.65rem;
      justify-content: center;
      width: 100%;
    }

    /* Smaller secondary CTA on narrow screens */
    .events-featured-actions :global(a.events-featured-cta-btn) {
      min-height: 2.5rem;
      padding: 0.45rem 1rem !important;
      font-size: 0.8125rem !important;
    }
  }

  .events-grid-date {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-width: 3rem;
    padding: 0.1rem 0;
    flex-shrink: 0;
  }
  .events-grid-date--featured {
    min-width: 4.25rem;
    padding: 0.25rem 0;
  }

  .events-grid-month {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--orange);
  }
  .events-grid-date--featured .events-grid-month {
    font-size: 1.125rem;
    letter-spacing: 0.14em;
  }

  .events-grid-day {
    font-family: var(--serif);
    font-size: 1.5rem;
    font-weight: 800;
    line-height: 1;
    color: var(--ink);
  }
  .events-grid-date--featured .events-grid-day {
    font-size: 2.35rem;
    margin-top: 0.15rem;
  }

  .events-grid-thumb {
    flex-shrink: 0;
    width: 4.5rem;
    height: 4.5rem;
    border-radius: 0.75rem;
    overflow: hidden;
    background: var(--cream-2);
  }
  .events-grid-thumb--featured {
    width: 16rem;
    height: 9rem;
    border-radius: 1rem;
  }
  a.events-grid-thumb {
    text-decoration: none;
    color: inherit;
  }
  a.events-grid-thumb:focus-visible {
    outline: 2px solid var(--secondary-500, #c4a574);
    outline-offset: 2px;
  }

  .events-featured-title-link {
    color: inherit;
    text-decoration: none;
  }
  .events-featured-title-link:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .events-featured-title-link:focus-visible {
    outline: 2px solid var(--secondary-500, #c4a574);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .events-featured-actions {
    margin-top: 0.85rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .events-grid-thumb-bg {
    display: block;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    background-color: var(--cream-2);
  }

  .events-grid-info {
    flex: 1;
    min-width: 0;
  }
  .events-grid-title {
    font-family: var(--serif);
    font-size: 1rem;
    font-weight: 700;
    color: var(--ink);
    line-height: 1.3;
    margin-bottom: 0.2rem;
  }
  .events-grid-title--featured {
    font-size: 1.45rem;
    font-weight: 800;
    line-height: 1.25;
    margin-bottom: 0.35rem;
  }

  .events-grid-meta {
    font-size: 0.78rem;
    color: var(--muted);
    margin-bottom: 0.05rem;
  }
  .events-grid-meta--featured {
    font-size: 1.05rem;
    margin-bottom: 0.12rem;
  }

  .events-grid-cta {
    margin-top: 0.45rem;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--primary-500);
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }
</style>
