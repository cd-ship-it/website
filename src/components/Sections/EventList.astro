---
import { fetchAllEvents } from "../../lib/eventApi";
import type { EventItem } from "../../lib/eventApi";
import EventCard from "../UI/EventCard.astro";
import Button from "../UI/Button.astro";

export interface Props {
  count?: number;
  showViewAll?: boolean;
}

const { count, showViewAll = true } = Astro.props;

let events: EventItem[] = [];
try {
  const allEvents = await fetchAllEvents();
  const today = new Date();
  today.setHours(0, 0, 0, 0);

  const upcoming = allEvents
    .filter((event) => {
      const d = new Date(`${event.startDate}T00:00:00`);
      return !Number.isNaN(d.getTime()) && d >= today;
    })
    .sort((a, b) => new Date(a.startDate).getTime() - new Date(b.startDate).getTime());

  events = typeof count === "number" ? upcoming.slice(0, count) : upcoming;
} catch {
  events = [];
}

const compactEvents = events.slice(0, 6);

const eventsSectionBg =
  "https://crosspointchurchsv.org/wp-content/uploads/2026/03/signal-2023-10-28-11-17-16-441-scaled.jpg";
---

<section
  class="section-default"
  style={`background-image: linear-gradient(
      to bottom,
      rgba(253, 250, 246, 0.99) 0%,
      rgba(253, 250, 246, 0.78) 45%,
      rgba(245, 243, 239, 0.85) 100%
    ),
    url("${eventsSectionBg}");

    background-size: cover, cover;
    background-position: center, center;
    background-repeat: no-repeat, no-repeat;`}
>
  <div >
    <p class="eyebrow">What's Happening</p>
    <h2 class="section-heading">Upcoming Events</h2>
    <p class="section-sub">
      Join us for these upcoming events and become part of our community
    </p>

    {compactEvents.length > 0 && (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {compactEvents.map((event) => (
          <EventCard event={event} />
        ))}
      </div>
    )}

    {compactEvents.length === 0 && (
      <div class="text-center py-10 bg-cream-2 rounded-2xl">
        <p class="text-muted">No upcoming events available right now.</p>
      </div>
    )}

    {showViewAll && compactEvents.length > 0 && (
      <div class="mt-12 text-center">
        <Button href="/events" variant="primary" size="lg">
          View All Events
        </Button>
      </div>
    )}
  </div>
</section>
