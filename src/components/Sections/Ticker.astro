---
// Identity stats strip — replaced generic scrolling marquee with three
// facts that communicate CrossPoint's footprint at a glance.
---

<div class="bg-primary-800 border-t border-primary-700/40" aria-hidden="true">
  <div class="container">
    <div class="grid grid-cols-3 divide-x divide-primary-700/40">

      <div class="flex items-center justify-center gap-2 md:gap-3 py-4 px-3">
        <span class="text-secondary-400 font-bold text-xl md:text-2xl leading-none tabular-nums">25</span>
        <span class="text-white/55 text-[0.6rem] md:text-xs font-semibold uppercase tracking-widest leading-tight">
          Years<br />Strong
        </span>
      </div>

      <div class="flex items-center justify-center gap-2 md:gap-3 py-4 px-3">
        <span class="text-secondary-400 font-bold text-xl md:text-2xl leading-none tabular-nums">5</span>
        <span class="text-white/55 text-[0.6rem] md:text-xs font-semibold uppercase tracking-widest leading-tight">
          Bay Area<br />Campuses
        </span>
      </div>

      <div class="flex items-center justify-center gap-2 md:gap-3 py-4 px-3">
        <span class="text-secondary-400 font-bold text-xl md:text-2xl leading-none tabular-nums">3</span>
        <span class="text-white/55 text-[0.6rem] md:text-xs font-semibold uppercase tracking-widest leading-tight">
          Languages<br />Spoken
        </span>
      </div>

    </div>
  </div>
</div>
