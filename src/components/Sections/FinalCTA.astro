---
import Button from "../UI/Button.astro";

export interface Props {
  heading?: string;
  subtext?: string;
  primaryCtaText?: string;
  primaryCtaLink?: string;
  secondaryCtaText?: string;
  secondaryCtaLink?: string;
  backgroundImage?: string;
}

const {
  heading = "Ready to Join Our Community?",
  subtext = "We'd love to welcome you to our church family. Come visit us this Sunday or reach out with any questions.",
  primaryCtaText = "I'm New Here",
  primaryCtaLink = "/im-new",
  secondaryCtaText = "Contact Us",
  secondaryCtaLink = "/contact",
  backgroundImage = `${import.meta.env.BASE_URL}uploads/PL-2_wide.webp`,
} = Astro.props;

const B = import.meta.env.BASE_URL;
const p = (path: string) => (!path || /^https?:\/\//.test(path)) ? path : `${B}${path.replace(/^\//, "")}`;
const resolvedPrimaryLink = p(primaryCtaLink);
const resolvedSecondaryLink = p(secondaryCtaLink);
---

<section
  class="relative overflow-hidden py-24"
  style={`background-image: linear-gradient(rgba(255, 244, 232, 0.78), rgba(250, 232, 212, 0.88)), url(${backgroundImage}); background-size: cover; background-position: center;`}
>
  <div class="absolute top-0 right-0 w-96 h-96 rounded-full opacity-[0.12] translate-x-1/2 -translate-y-1/2 pointer-events-none" style="background: radial-gradient(circle, #E8961F, transparent 70%);"></div>
  <div class="absolute bottom-0 left-0 w-64 h-64 rounded-full opacity-[0.08] -translate-x-1/2 translate-y-1/2 pointer-events-none" style="background: radial-gradient(circle, #E8961F, transparent 70%);"></div>

  <div
    class="absolute inset-0 pointer-events-none"
    style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.03) 1px, transparent 0); background-size: 28px 28px;"
  ></div>

  <div class="container relative z-10">
    <div class="grid grid-cols-1 gap-8 lg:grid-cols-[1.2fr_0.8fr] lg:items-end">
      <div class="max-w-2xl">
        <!-- <div class="flex items-center gap-3 mb-5">
          <span class="inline-block w-8 h-px bg-secondary-400 opacity-70"></span>
          <p class="text-secondary-400 text-xs font-semibold tracking-[0.22em] uppercase">You're Welcome Here</p>
        </div> -->
        <h2 class="font-serif font-bold text-ink mb-6 leading-tight text-cta-band">
          {heading}
        </h2>
        <p class="text-ink-3 text-lg max-w-xl leading-relaxed">
          {subtext}
        </p>
      </div>

      <div class="rounded-[1.75rem] border border-ink/10 bg-white/70 p-6 shadow-sm backdrop-blur-md md:p-8">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-secondary-600 mb-3">Take the next step</p>
        <!-- <p class="text-sm leading-relaxed text-white/65 mb-6">
          Whether you're visiting for the first time or looking for a place to belong, we'll help you find the right next step.
        </p> -->
        <div class="flex flex-col gap-3 sm:flex-row lg:flex-col">
          <Button href={resolvedPrimaryLink} variant="secondary" size="lg" class="w-full">
            {primaryCtaText}
          </Button>
          <Button
            href={resolvedSecondaryLink}
            variant="outline"
            size="lg"
            class="w-full !border-primary-900/35 !bg-white !text-primary-950 !shadow-sm hover:!bg-cream-2 hover:!border-primary-900/55"
          >
            {secondaryCtaText}
          </Button>
        </div>
      </div>
    </div>
  </div>
</section>
