---
import Button from "../UI/Button.astro";
import LocalizedInline from "../UI/LocalizedInline.astro";
import { getCollection } from "astro:content";
import type { LocalizedText } from "../../lib/i18n";
import { getCampusCount } from "../../lib/siteInfo/serviceTimes";

const entries = await getCollection("siteInfo");
const entry = entries.find(
  (item) =>
    item.id === "home-second-hero" ||
    item.slug === "home-second-hero" ||
    item.id.endsWith("/home-second-hero") ||
    item.id.endsWith("/home-second-hero.md") ||
    item.id === "home-second-hero.md",
);
const s = entry?.data.secondHero;
const campusCount = await getCampusCount();
const storyStats: Array<{ value: string; label: LocalizedText }> = [
  {
    value: String(campusCount),
    label: {
      en: "Bay Area campuses",
      "zh-Hant": "灣區會堂",
      "zh-Hans": "湾区会堂",
    },
  },
  {
    value: "3",
    label: {
      en: "languages",
      "zh-Hant": "語言",
      "zh-Hans": "语言",
    },
  },
  {
    value: "1",
    label: {
      en: "church family",
      "zh-Hant": "教會家庭",
      "zh-Hans": "教会家庭",
    },
  },
];
---

{s && (
  <section class="bg-primary-900 px-6 py-[72px] text-white" style="background-image: url('/uploads/bg-home-second-hero.webp'); background-size: cover; background-position: center;">
    <div class="container">
      <div class="grid grid-cols-1 items-stretch gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:gap-16">
        <div class="relative overflow-hidden rounded-[1.75rem] bg-primary-950 min-h-[22rem] lg:min-h-[34rem]">
          <img
            src={s.image}
            alt={s.imageAlt?.en ?? ""}
            class="absolute inset-0 h-full w-full object-cover"
          />
          <div class="absolute inset-0 bg-gradient-to-b from-primary-950/10 via-primary-950/25 to-primary-950/75"></div>
          
        </div>

        <div class="flex flex-col justify-center text-white">
           {s.heading && (
            <h2 class="font-serif font-bold text-heading text-white/90 leading-tight text-second-hero mb-6 whitespace-pre-line">
              <LocalizedInline value={s.heading} />
            </h2>
          )} 
          {s.paragraph1 && (
            <p class="body-copy text-lg mb-5 max-w-xl text-white/90">
              <LocalizedInline value={s.paragraph1} />
            </p>
          )}
          {s.paragraph2 && (
            <p class="body-copy text-lg mb-8 max-w-xl whitespace-pre-line text-white/90">
              <LocalizedInline value={s.paragraph2} />
            </p>
          )}

          <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-8 max-w-2xl">
            {storyStats.map((stat) => (
              <div class="px-5 py-4">
                <div class="font-serif text-3xl font-bold leading-none text-white">{stat.value}</div>
                <div class="mt-2 text-[0.68rem] font-semibold uppercase tracking-[0.16em] text-white/70">
                  <LocalizedInline value={stat.label} />
                </div>
              </div>
            ))}
          </div>

          {s.ctaText && s.ctaLink && (
            <div>
              <Button href={s.ctaLink} variant="primary" size="lg">
                <LocalizedInline value={s.ctaText} />
              </Button>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>
)}
