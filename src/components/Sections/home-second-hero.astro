---
import Button from "../UI/Button.astro";
import LocalizedInline from "../UI/LocalizedInline.astro";
import { getCollection } from "astro:content";

const entries = await getCollection("siteInfo");
const entry = entries.find(
  (item) =>
    item.id === "home-second-hero" ||
    item.slug === "home-second-hero" ||
    item.id.endsWith("/home-second-hero") ||
    item.id.endsWith("/home-second-hero.md") ||
    item.id === "home-second-hero.md",
);
const s = entry?.data.secondHero;
---

{s && (
  <section class="py-24 bg-primary-900 relative overflow-hidden">
    <!-- Shared dot-grid texture (ties to PageHeader + FinalCTA visual language) -->
    <div
      class="absolute inset-0 pointer-events-none"
      style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.035) 1px, transparent 0); background-size: 28px 28px;"
    ></div>

    <div class="container relative z-10">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-20 items-center">

        <div class="relative">
          <img
            src={s.image}
            alt={s.imageAlt?.en ?? ""}
            class="rounded-2xl object-cover w-full aspect-[4/3] shadow-2xl"
          />
          <!-- Amber-gold accent border offset -->
          <div class="absolute -bottom-4 -right-4 w-full h-full rounded-2xl border-2 border-secondary-500/35 pointer-events-none"></div>
        </div>

        <div>
          <div class="flex items-center gap-3 mb-4">
            <span class="inline-block w-6 h-px bg-secondary-400 opacity-75"></span>
            <p class="text-secondary-400 text-xs font-semibold tracking-[0.22em] uppercase">Our Story</p>
          </div>
          {s.heading && (
            <h2 class="font-serif font-bold text-white leading-tight text-second-hero mb-6">
              <LocalizedInline value={s.heading} />
            </h2>
          )}
          {s.paragraph1 && (
            <p class="text-white/60 mb-4 text-base leading-relaxed">
              <LocalizedInline value={s.paragraph1} />
            </p>
          )}
          {s.paragraph2 && (
            <p class="text-white/60 mb-8 text-base leading-relaxed">
              <LocalizedInline value={s.paragraph2} />
            </p>
          )}
          {s.ctaText && s.ctaLink && (
            <Button href={s.ctaLink} variant="secondary">
              <LocalizedInline value={s.ctaText} />
            </Button>
          )}
        </div>

      </div>
    </div>
  </section>
)}
