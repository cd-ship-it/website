---
import Button from "../UI/Button.astro";
import { fetchSermons } from "../../lib/sermonApi";
import type { Sermon } from "../../lib/sermonApi";
import { LANG_LABELS } from "../../lib/sermons/constants";
import { fmtDate, preacherLabel } from "../../lib/sermons/format";

export interface Props {
  count?: number;
  showViewAll?: boolean;
}

const { count = 4, showViewAll = true } = Astro.props;

let sermons: Sermon[] = [];
try {
  const res = await fetchSermons({ per_page: count, page: 1 });
  sermons = res.data;
} catch {}

---

{sermons.length > 0 && (
  <section class="sermons-home">
    <div class="container">
      <div class="sermons-home-header">
        <div>
          {/* <p class="sermons-eyebrow">Messages</p> */}
          <h2 class="sermons-heading">Recent Sermons</h2>
        </div>
      </div>

      <div class="sermons-home-grid">
        {sermons.map((sermon) => (
          <a href={`${import.meta.env.BASE_URL}sermons/${sermon.youtube_id}`} class="sermon-card-dark group">
            <div class="sermon-card-dark-thumb">
              <img
                src={`https://img.youtube.com/vi/${sermon.youtube_id}/mqdefault.jpg`}
                alt={sermon.sermon_title}
                loading="lazy"
                onerror={`this.src='${import.meta.env.BASE_URL}uploads/sermon-placeholder.webp'`}
              />
              <div class="sermon-card-dark-desaturate" aria-hidden="true"></div>
              <div class="sermon-card-dark-play">
                <svg width="40" height="40" viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="24" fill="rgba(232,150,31,0.9)"/><path d="M19 15l14 9-14 9V15z" fill="#fff"/></svg>
              </div>
            </div>
            <div class="sermon-card-dark-info">
              <span class="sermon-card-dark-lang">{LANG_LABELS[sermon.language] ?? sermon.language}</span>
              {sermon.location && <p class="sermon-card-dark-campus">{sermon.location}</p>}
              <h3 class="sermon-card-dark-title">{sermon.sermon_title}</h3>
              <p class="sermon-card-dark-meta">
                {preacherLabel(sermon.preacher_chi, sermon.preacher_eng)}
              </p>
              <p class="sermon-card-dark-date">{fmtDate(sermon.date)}</p>
            </div>
          </a>
        ))}
      </div>

      {showViewAll && (
        <div class="mt-8 flex justify-end">
            <Button href={`${import.meta.env.BASE_URL}sermons`} variant="primary" size="lg">
                View all sermons
              </Button>
        </div>
      )}
    </div>
  </section>
)}

<style>
  .sermons-home {
    background: linear-gradient(180deg, #091529 0%, #0f2040 100%);
    padding: 5rem 0;
  }

  .sermons-home-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 2.5rem;
    gap: 1rem;
  }
  .sermons-eyebrow {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 0.35rem;
  }
  .sermons-heading {
    font-family: var(--serif);
    font-weight: 700;
    font-size: var(--font-section-major);
    line-height: 1.15;
    color: #fff;
  }
  /* ── Equal-weight card grid ─────────────────── */
  .sermons-home-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 640px) {
    .sermons-home-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .sermons-home-grid { grid-template-columns: repeat(4, 1fr); }
  }

  .sermon-card-dark {
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    transition: border-color 0.25s, box-shadow 0.25s, transform 0.25s;
  }
  .sermon-card-dark:hover {
    border-color: rgba(232,150,31,0.35);
    box-shadow: 0 12px 40px rgba(0,0,0,0.3);
    transform: translateY(-3px);
  }

  .sermon-card-dark-thumb {
    position: relative;
    width: 100%;
    aspect-ratio: 16/9;
    overflow: hidden;
    isolation: isolate;
  }
  .sermon-card-dark-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: saturate(0.45) grayscale(0.35) contrast(0.95);
    transition: transform 0.45s ease, filter 0.3s ease;
  }
  .sermon-card-dark:hover .sermon-card-dark-thumb img {
    transform: scale(1.05);
    filter: none;
  }

  .sermon-card-dark-desaturate {
    position: absolute;
    inset: 0;
    background: rgba(9, 21, 41, 0.32);
    mix-blend-mode: multiply;
    pointer-events: none;
    transition: opacity 0.25s ease;
  }
  .sermon-card-dark:hover .sermon-card-dark-desaturate {
    opacity: 0;
  }

  .sermon-card-dark-play {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,0,0,0.25);
    opacity: 0;
    transition: opacity 0.25s;
  }
  .sermon-card-dark:hover .sermon-card-dark-play { opacity: 1; }

  .sermon-card-dark-info { padding: 1rem 1.15rem 1.25rem; }

  .sermon-card-dark-lang {
    display: inline-block;
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 0.18rem 0.55rem;
    border-radius: 4px;
    background: rgba(232,150,31,0.15);
    color: var(--orange);
    margin-bottom: 0.5rem;
  }
  .sermon-card-dark-title {
    font-family: var(--serif);
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
    line-height: 1.3;
    margin-bottom: 0.35rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .sermon-card-dark-campus {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.55);
    margin-bottom: 0.45rem;
  }
  .sermon-card-dark-meta {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.5);
    margin-bottom: 0.1rem;
  }
  .sermon-card-dark-date {
    font-size: 0.72rem;
    color: rgba(255,255,255,0.3);
  }
</style>
