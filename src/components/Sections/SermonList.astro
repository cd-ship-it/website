---
import Button from "../UI/Button.astro";
import { fetchSermons } from "../../lib/sermonApi";
import type { Sermon } from "../../lib/sermonApi";

export interface Props {
  count?: number;
  showViewAll?: boolean;
  variant?: "default" | "home";
}

const { count = 4, showViewAll = true, variant = "default" } = Astro.props;
const isHome = variant === "home";

let sermons: Sermon[] = [];
try {
  const res = await fetchSermons({ per_page: count, page: 1 });
  sermons = res.data;
} catch {}

const LANG_LABELS: Record<string, string> = {
  English: "English",
  Cantonese: "粵語",
  Mandarin: "國語",
};

function fmtDate(d: string) {
  return new Date(`${d}T00:00:00`).toLocaleDateString("en-US", {
    month: "short", day: "numeric", year: "numeric",
  });
}
---

{sermons.length > 0 && (
  <section class:list={[isHome ? "sermons-home" : "section-default home-section-block"]}>
    {isHome ? (
      <div class="container">
        <div class="sermons-home-header">
          <div>
            <p class="sermons-eyebrow">Messages</p>
            <h2 class="sermons-heading">Recent Sermons</h2>
          </div>
          {showViewAll && (
            <a href="/sermons" class="sermons-view-all">
              All sermons
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          )}
        </div>

        <div class="sermons-home-grid">
          {sermons.map((sermon) => (
            <a href={`/sermons/${sermon.youtube_id}`} class="sermon-card-dark group">
              <div class="sermon-card-dark-thumb">
                <img
                  src={`https://img.youtube.com/vi/${sermon.youtube_id}/mqdefault.jpg`}
                  alt={sermon.sermon_title}
                  loading="lazy"
                  onerror="this.src='/uploads/sermon-placeholder.webp'"
                />
                <div class="sermon-card-dark-play">
                  <svg width="40" height="40" viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="24" fill="rgba(232,150,31,0.9)"/><path d="M19 15l14 9-14 9V15z" fill="#fff"/></svg>
                </div>
              </div>
              <div class="sermon-card-dark-info">
                <span class="sermon-card-dark-lang">{LANG_LABELS[sermon.language] ?? sermon.language}</span>
                <h3 class="sermon-card-dark-title">{sermon.sermon_title}</h3>
                <p class="sermon-card-dark-meta">
                  {[sermon.preacher_chi, sermon.preacher_eng].filter(Boolean).join(" · ")}
                </p>
                <p class="sermon-card-dark-date">{fmtDate(sermon.date)}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    ) : (
      <div>
        <div class="home-section-intro">
          <p class="eyebrow">Messages</p>
          <h2 class="section-heading">Recent Sermons</h2>
          <p class="section-sub">Listen to or watch our latest messages from Sunday services</p>
        </div>
        <div class="home-section-body">
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {sermons.map((sermon) => {
              const thumb = `https://img.youtube.com/vi/${sermon.youtube_id}/mqdefault.jpg`;
              const langLabel = LANG_LABELS[sermon.language] ?? sermon.language;
              return (
                <a href={`/sermons/${sermon.youtube_id}`} class="group overflow-hidden block xp-panel-inner bg-white hover:shadow-xl transition-all duration-300">
                  <div class="relative w-full overflow-hidden pb-[56.25%]">
                    <img src={thumb} alt={sermon.sermon_title} class="absolute inset-0 w-full h-full object-cover transition-transform duration-300 group-hover:scale-105 block" loading="lazy" onerror="this.src='/uploads/sermon-placeholder.webp'" />
                  </div>
                  <div class="p-5">
                    <div class="flex items-start justify-between gap-2 mb-2">
                      <h3 class="text-lg font-bold leading-snug line-clamp-2 flex-1">{sermon.sermon_title}</h3>
                      <span class="shrink-0 inline-block px-2 py-0.5 text-xs font-medium rounded-full bg-primary-100 text-primary-800">{langLabel}</span>
                    </div>
                    <p class="text-sm text-muted">{fmtDate(sermon.date)}</p>
                    <p class="mt-2 text-secondary-600 font-medium text-sm group-hover:text-secondary-500 group-hover:underline transition-colors">Watch / 觀看 →</p>
                  </div>
                </a>
              );
            })}
          </div>
          {showViewAll && (
            <div class="mt-12 text-center">
              <Button href="/sermons" variant="outline">View All Sermons</Button>
            </div>
          )}
        </div>
      </div>
    )}
  </section>
)}

<style>
  .sermons-home {
    background: linear-gradient(180deg, #091529 0%, #0f2040 100%);
    padding: 5rem 0;
  }

  .sermons-home-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 2.5rem;
    gap: 1rem;
  }
  .sermons-eyebrow {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 0.35rem;
  }
  .sermons-heading {
    font-family: var(--serif);
    font-weight: 700;
    font-size: var(--font-section-major);
    line-height: 1.15;
    color: #fff;
  }
  .sermons-view-all {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: rgba(255,255,255,0.45);
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.15s, gap 0.15s;
  }
  .sermons-view-all:hover { color: rgba(255,255,255,0.8); gap: 0.55rem; }

  /* ── Equal-weight card grid ─────────────────── */
  .sermons-home-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 640px) {
    .sermons-home-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .sermons-home-grid { grid-template-columns: repeat(4, 1fr); }
  }

  .sermon-card-dark {
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    transition: border-color 0.25s, box-shadow 0.25s, transform 0.25s;
  }
  .sermon-card-dark:hover {
    border-color: rgba(232,150,31,0.35);
    box-shadow: 0 12px 40px rgba(0,0,0,0.3);
    transform: translateY(-3px);
  }

  .sermon-card-dark-thumb {
    position: relative;
    width: 100%;
    aspect-ratio: 16/9;
    overflow: hidden;
  }
  .sermon-card-dark-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.45s ease;
  }
  .sermon-card-dark:hover .sermon-card-dark-thumb img { transform: scale(1.05); }

  .sermon-card-dark-play {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,0,0,0.25);
    opacity: 0;
    transition: opacity 0.25s;
  }
  .sermon-card-dark:hover .sermon-card-dark-play { opacity: 1; }

  .sermon-card-dark-info { padding: 1rem 1.15rem 1.25rem; }

  .sermon-card-dark-lang {
    display: inline-block;
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 0.18rem 0.55rem;
    border-radius: 4px;
    background: rgba(232,150,31,0.15);
    color: var(--orange);
    margin-bottom: 0.5rem;
  }
  .sermon-card-dark-title {
    font-family: var(--serif);
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
    line-height: 1.3;
    margin-bottom: 0.35rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .sermon-card-dark-meta {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.5);
    margin-bottom: 0.1rem;
  }
  .sermon-card-dark-date {
    font-size: 0.72rem;
    color: rgba(255,255,255,0.3);
  }
</style>
