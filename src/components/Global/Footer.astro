---
import { getCollection } from "astro:content";

let officeHours;
try {
  const siteInfoEntries = await getCollection("siteInfo");
  officeHours = siteInfoEntries.find(entry => entry.id === "office-hours");
} catch (error) {
  officeHours = undefined;
}

const footerNavs = [
  {
    title: "About",
    items: [
      { text: "About Us", href: "/about-us" },
      { text: "I'm New", href: "/im-new" },
      { text: "Our Pastors", href: "/about-pastors" },
      { text: "Contact", href: "/contact" },
    ],
  },
  {
    title: "Resources",
    items: [
      { text: "Sermons", href: "/sermons" },
      { text: "Events", href: "/events" },
      { text: "Weekly Prayer", href: "/weekly-prayer" },
      { text: "Heart of a Shepherd", href: "/heart-of-a-shepherd" },
    ],
  },
  {
    title: "Connect",
    items: [
      { text: "Giving", href: "/giving" },
      { text: "Prayer Request", href: "/contact#prayer" },
      { text: "Life Groups", href: "/ministries/life-groups" },
      { text: "Campuses", href: "/campus" },
    ],
  },
];

const socialLinks = [
  {
    name: "Facebook",
    href: "https://facebook.com/crosspointchurchsv",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>`,
  },
  {
    name: "Instagram",
    href: "https://instagram.com/crosspointchurchsv",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>`,
  },
  {
    name: "YouTube",
    href: "https://youtube.com/@crosspointchurchsv",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>`,
  },
];

const currentYear = new Date().getFullYear();

let OfficeHoursContent = null;
if (officeHours) {
  const { Content } = await officeHours.render();
  OfficeHoursContent = Content;
}
---

<footer class="site-footer">
  <!-- Tagline band -->
  <div class="footer-tagline">
    <div class="container">
      <a href="/" class="footer-logo-link" aria-label="Crosspoint Church home">
        <img
          alt="Crosspoint Church"
          src="https://crosspointchurchsv.org/wp-content/uploads/2022/04/Xpt-ID2015-1_1400x346-1.png"
          class="footer-logo"
        />
      </a>
      <p class="footer-tagline-text">A Christ-centered,<br class="hidden md:inline" /> multicultural church family.</p>
    </div>
  </div>

  <!-- Main content -->
  <div class="footer-body">
    <div class="container">
      <div class="footer-grid">
        <!-- Left: contact + office hours -->
        <div class="footer-info">
          <address class="footer-address">
            <p>658 Gibraltar Ct.</p>
            <p>Milpitas, CA 95035</p>
            <p class="mt-3">
              <a href="mailto:info@crosspointchurchsv.org" class="footer-link-highlight">
                info@crosspointchurchsv.org
              </a>
            </p>
          </address>

          {OfficeHoursContent && (
            <div class="footer-office-hours">
              <h4 class="footer-micro-heading">Office Hours</h4>
              <div class="prose prose-sm prose-invert max-w-none [&_h3]:text-cream/80 [&_h3]:text-xs [&_h3]:font-bold [&_h3]:mb-1 [&_ul]:list-none [&_ul]:p-0 [&_li]:mb-1 [&_strong]:text-cream/80">
                <OfficeHoursContent />
              </div>
            </div>
          )}

          <div class="footer-social">
            {socialLinks.map((link) => (
              <a
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
                class="footer-social-link"
                aria-label={link.name}
              >
                <Fragment set:html={link.icon} />
                <span>{link.name}</span>
              </a>
            ))}
          </div>
        </div>

        <!-- Right: nav columns -->
        <nav class="footer-nav" aria-label="Footer navigation">
          {footerNavs.map((group) => (
            <div class="footer-nav-group">
              <h4 class="footer-micro-heading">{group.title}</h4>
              <ul class="footer-nav-list">
                {group.items.map((item) => (
                  <li>
                    <a href={item.href} class="footer-nav-link">{item.text}</a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </nav>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p>&copy; {currentYear} Crosspoint Church. All rights reserved.</p>
      <div class="footer-legal">
        <a href="/privacy-policy">Privacy</a>
        <span class="footer-legal-sep" aria-hidden="true">&middot;</span>
        <a href="/terms-of-service">Terms</a>
        <span class="footer-legal-sep" aria-hidden="true">&middot;</span>
        <a href="/special-announcements">Disclaimer</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    --footer-bg: #091529;
    --footer-text: rgba(249, 250, 251, 0.65);
    --footer-text-dim: rgba(249, 250, 251, 0.4);
    --footer-accent: #E8961F;
    --footer-border: rgba(249, 250, 251, 0.08);
    background: var(--footer-bg);
    color: var(--footer-text);
  }

  /* ── Tagline band ────────────────────────────────── */
  .footer-tagline {
    border-bottom: 1px solid var(--footer-border);
    padding: 3rem 0 2.5rem;
  }
  .footer-tagline .container {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  @media (min-width: 768px) {
    .footer-tagline .container {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }
  .footer-logo-link { display: inline-block; flex-shrink: 0; }
  .footer-logo {
    height: 2.75rem;
    width: auto;
    filter: brightness(0) invert(1);
    opacity: 0.85;
  }
  .footer-tagline-text {
    font-family: var(--serif);
    font-size: clamp(1.15rem, 2vw, 1.5rem);
    font-weight: 600;
    line-height: 1.4;
    color: rgba(249, 250, 251, 0.82);
    max-width: 22ch;
  }

  /* ── Body ─────────────────────────────────────────── */
  .footer-body { padding: 3rem 0 2.5rem; }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr 1.4fr;
      gap: 4rem;
    }
  }

  /* ── Info column ──────────────────────────────────── */
  .footer-address {
    font-style: normal;
    font-size: 0.9rem;
    line-height: 1.75;
    color: var(--footer-text);
  }
  .footer-link-highlight {
    color: var(--footer-accent);
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .footer-link-highlight:hover { opacity: 0.8; }

  .footer-office-hours {
    margin-top: 1.75rem;
    font-size: 0.85rem;
    color: var(--footer-text-dim);
  }

  .footer-social {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    margin-top: 2rem;
  }
  .footer-social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    padding: 0.45rem 0.8rem;
    border-radius: 9999px;
    border: 1px solid var(--footer-border);
    color: var(--footer-text-dim);
    text-decoration: none;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }
  .footer-social-link:hover {
    color: rgba(249, 250, 251, 0.9);
    border-color: rgba(249, 250, 251, 0.2);
    background: rgba(249, 250, 251, 0.05);
  }

  /* ── Nav columns ─────────────────────────────────── */
  .footer-nav {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  @media (max-width: 520px) {
    .footer-nav {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .footer-micro-heading {
    font-family: var(--sans);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(249, 250, 251, 0.45);
    margin-bottom: 0.85rem;
  }

  .footer-nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .footer-nav-link {
    font-size: 0.85rem;
    color: var(--footer-text);
    text-decoration: none;
    transition: color 0.15s;
  }
  .footer-nav-link:hover { color: rgba(249, 250, 251, 0.95); }

  /* ── Bottom bar ──────────────────────────────────── */
  .footer-bottom {
    border-top: 1px solid var(--footer-border);
    padding: 1.5rem 0;
  }
  .footer-bottom-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.72rem;
    color: var(--footer-text-dim);
  }
  @media (min-width: 640px) {
    .footer-bottom-inner {
      flex-direction: row;
      justify-content: space-between;
    }
  }
  .footer-legal {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .footer-legal a {
    color: var(--footer-text-dim);
    text-decoration: none;
    transition: color 0.15s;
  }
  .footer-legal a:hover { color: rgba(249, 250, 251, 0.8); }
  .footer-legal-sep { opacity: 0.35; }
</style>
