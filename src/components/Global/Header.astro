---
import Navigation from "./Navigation.astro";
---

<header
  id="site-header"
  class="sticky top-0 z-50 w-full bg-white border-b border-gray-200 transition-shadow duration-300"
>
  <div class="container flex items-center justify-between h-18">
    <a href="/" class="flex items-center shrink-0">
      <span class="sr-only">Crosspoint Church</span>
      <img
        alt="Crosspoint Church"
        src="https://crosspointchurchsv.org/wp-content/uploads/2022/04/Xpt-ID2015-1_1400x346-1.png"
        class="h-12 w-auto"
      />
    </a>
    <Navigation />
  </div>
</header>

<script>
  // Add a drop-shadow once the user scrolls past the hero
  const header = document.getElementById("site-header");
  if (header) {
    const onScroll = () => {
      if (window.scrollY > 8) {
        header.classList.add("shadow-md");
      } else {
        header.classList.remove("shadow-md");
      }
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();
  }
</script>
