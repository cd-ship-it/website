---
/**
 * Events / Sermons / Giving — absolutely centered on the header bar (full container width).
 * Parent must be `position: relative` (see Header.astro).
 */
import { I18N, type LocaleStrings } from "../../lib/i18n";
import LocalizedInline from "../UI/LocalizedInline.astro";

type NavKey = keyof LocaleStrings["nav"];

function navLabel(key: NavKey) {
  return {
    en: I18N.en.nav[key],
    "zh-Hant": I18N["zh-Hant"].nav[key],
    "zh-Hans": I18N["zh-Hans"].nav[key],
  };
}

const BASE = import.meta.env.BASE_URL;
const u = (path: string) => `${BASE}${path.replace(/^\//, "")}`;
const currentPath = Astro.url.pathname;

function isLinkActive(href: string) {
  if (!href || href === "#") return false;
  return currentPath === href || (href !== BASE && currentPath.startsWith(href));
}

const centerLinkClass = (active: boolean) =>
  `text-sm font-normal transition-colors sm:text-base ${
    active ? "text-secondary-600" : "text-ink-2 hover:text-secondary-600"
  }`;
---

<nav
  class="pointer-events-auto ml-auto flex items-center gap-3 pr-1 sm:gap-4 md:absolute md:left-1/2 md:top-1/2 md:z-10 md:-translate-x-1/2 md:-translate-y-1/2 md:gap-10 md:pr-0"
  aria-label="Quick links"
>
  <a
    href={u("/events")}
    class={centerLinkClass(isLinkActive(u("/events")))}
    aria-current={isLinkActive(u("/events")) ? "page" : undefined}
  >
    <LocalizedInline value={navLabel("events")} />
  </a>
  <a
    href={u("/sermons")}
    class={centerLinkClass(isLinkActive(u("/sermons")))}
    aria-current={isLinkActive(u("/sermons")) ? "page" : undefined}
  >
    <LocalizedInline value={navLabel("sermons")} />
  </a>
  <a
    href={u("/giving")}
    class={centerLinkClass(isLinkActive(u("/giving")))}
    aria-current={isLinkActive(u("/giving")) ? "page" : undefined}
  >
    <LocalizedInline value={navLabel("giving")} />
  </a>
</nav>
