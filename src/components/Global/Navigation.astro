---
import { getEntry } from "astro:content";
import { LANG_LABELS, I18N, type LocalizedText, type SiteLang, type LocaleStrings } from "../../lib/i18n";
import LocalizedInline from "../UI/LocalizedInline.astro";

type NavKey = keyof LocaleStrings["nav"];

/** Matches `src/content/config.ts` navigation collection (nested up to 3 levels). */
type NavMenuL3 = { id: string; label: LocalizedText; href: string };
type NavMenuL2 = { id: string; label: LocalizedText; href: string; children?: NavMenuL3[] };
type NavMenuTop = { id: string; label: LocalizedText; href: string; children?: NavMenuL2[] };

function navLabel(key: NavKey): LocalizedText {
  return {
    en: I18N.en.nav[key],
    "zh-Hant": I18N["zh-Hant"].nav[key],
    "zh-Hans": I18N["zh-Hans"].nav[key],
  };
}

function fallbackNavFromI18n(): NavMenuTop[] {
  const L = navLabel;
  return [
    {
      id: "about",
      label: L("about"),
      href: "/about-us",
      children: [
        { id: "aboutUs", label: L("aboutUs"), href: "/about-us" },
        { id: "staff", label: L("staff"), href: "/staff" },
      ],
    },
    { id: "ministries", label: L("ministries"), href: "/ministries" },
    { id: "sermons", label: L("sermons"), href: "/sermons" },
    { id: "events", label: L("events"), href: "/events" },
    { id: "imNew", label: L("imNew"), href: "/im-new" },
    { id: "contact", label: L("contact"), href: "/contact" },
    { id: "giving", label: L("giving"), href: "/giving" },
  ];
}

const navEntry = await getEntry("navigation", "main-menu");
const fromFile =
  navEntry && !navEntry.data.draft && navEntry.data.items?.length ? navEntry.data.items : null;

const navItems: NavMenuTop[] = (fromFile ?? fallbackNavFromI18n()).filter(
  (item) => item.id !== "home",
);

const languageOptions: Array<{ value: SiteLang; label: string }> = [
  { value: "en", label: LANG_LABELS.en },
  { value: "zh-Hant", label: LANG_LABELS["zh-Hant"] },
  { value: "zh-Hans", label: LANG_LABELS["zh-Hans"] },
];

const currentPath = Astro.url.pathname;

function isLinkActive(href: string) {
  if (!href || href === "#") return false;
  return currentPath === href || (href !== "/" && currentPath.startsWith(href));
}

function isL3Active(l3: NavMenuL3) {
  return isLinkActive(l3.href);
}
function isL2Active(l2: NavMenuL2) {
  if (l2.children?.some(isL3Active)) return true;
  return isLinkActive(l2.href);
}
function isTopActive(item: NavMenuTop) {
  if (item.children?.length) return item.children.some(isL2Active);
  return isLinkActive(item.href);
}

function hasChildren(item: NavMenuTop): item is NavMenuTop & { children: NavMenuL2[] } {
  return Array.isArray(item.children) && item.children.length > 0;
}

/** First real URL for a parent whose own `href` may be `#`. */
function firstNavigableHref(item: NavMenuTop): string {
  if (item.href && item.href !== "#") return item.href;
  for (const l2 of item.children ?? []) {
    if (l2.href && l2.href !== "#") return l2.href;
    for (const l3 of l2.children ?? []) {
      if (l3.href && l3.href !== "#") return l3.href;
    }
  }
  return "#";
}
---

<!-- Desktop Navigation -->
<nav class="hidden lg:block">
  <ul class="flex items-center space-x-6">
    {
      navItems.map((item) => {
        if (hasChildren(item)) {
          const parentHref = firstNavigableHref(item);
          const isActive = isTopActive(item);
          return (
            <li class="relative group">
              <a
                href={parentHref}
                class={`text-base font-medium transition-colors flex items-center gap-1 ${
                  isActive ? "text-secondary-400" : "text-white/75 hover:text-secondary-400"
                }`}
                aria-haspopup="true"
                aria-expanded="false"
              >
                <LocalizedInline value={item.label} />
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-3.5 w-3.5 shrink-0"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  aria-hidden="true"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
                </svg>
              </a>
              <ul
                class="nav-desktop-dropdown absolute left-0 top-full z-50 min-w-[280px] max-w-[min(100vw-2rem,22rem)] border-x border-b border-gray-200 border-t-[3px] border-t-secondary-500 bg-white py-0 opacity-0 shadow-[0_4px_12px_rgba(9,21,41,0.15)] transition-all duration-150 invisible group-hover:visible group-hover:opacity-100"
                role="menu"
              >
                {item.children.map((child) => {
                  const childActive = isL2Active(child);
                  const hasGrand = child.children && child.children.length > 0;
                  if (!hasGrand) {
                    return (
                      <li role="none" class="border-b border-[#f0f0f0] last:border-b-0">
                        <a
                          href={child.href}
                          class:list={[
                            "block px-5 py-[15px] text-base font-medium leading-snug text-primary-700 transition-colors hover:bg-gray-50",
                            childActive && "font-semibold",
                          ]}
                          role="menuitem"
                          aria-current={childActive ? "page" : undefined}
                        >
                          <LocalizedInline value={child.label} />
                        </a>
                      </li>
                    );
                  }
                  return (
                    <li role="none" class="group/sub relative border-b border-[#f0f0f0] last:border-b-0">
                      <a
                        href={child.href || "#"}
                        class:list={[
                          "flex items-center justify-between gap-2 px-5 py-[15px] text-base font-medium leading-snug text-primary-700 transition-colors hover:bg-gray-50",
                          childActive && "font-semibold",
                        ]}
                        role="menuitem"
                        aria-current={isLinkActive(child.href) ? "page" : undefined}
                      >
                        <span class="min-w-0 flex-1">
                          <LocalizedInline value={child.label} />
                        </span>
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          class="h-4 w-4 shrink-0 text-primary-400"
                          fill="none"
                          viewBox="0 0 24 24"
                          stroke="currentColor"
                          aria-hidden="true"
                        >
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                        </svg>
                      </a>
                      <ul
                        role="menu"
                        class="invisible absolute left-full top-0 z-[60] ml-0 min-w-[260px] max-w-[min(100vw-2rem,20rem)] border-x border-b border-gray-200 border-t-[3px] border-t-secondary-500 bg-white py-0 opacity-0 shadow-[0_4px_12px_rgba(9,21,41,0.15)] transition-all duration-150 group-hover/sub:visible group-hover/sub:opacity-100"
                      >
                        {child.children!.map((g) => {
                          const gActive = isL3Active(g);
                          const gh = g.href?.trim();
                          return (
                            <li role="none" class="border-b border-[#f0f0f0] last:border-b-0">
                              {gh ? (
                                <a
                                  href={gh}
                                  class:list={[
                                    "block px-5 py-2.5 text-sm font-medium leading-snug text-primary-700 transition-colors hover:bg-gray-50",
                                    gActive && "font-semibold",
                                  ]}
                                  role="menuitem"
                                  aria-current={gActive ? "page" : undefined}
                                >
                                  <LocalizedInline value={g.label} />
                                </a>
                              ) : (
                                <span class="block px-5 py-2.5 text-sm font-medium leading-snug text-muted">
                                  <LocalizedInline value={g.label} />
                                </span>
                              )}
                            </li>
                          );
                        })}
                      </ul>
                    </li>
                  );
                })}
              </ul>
            </li>
          );
        }
        const href = item.href;
        const isActive = isLinkActive(href);
        return (
          <li>
            <a
              href={href}
              class={`text-base font-medium transition-colors ${
                isActive ? "text-secondary-400" : "text-white/75 hover:text-secondary-400"
              }`}
              aria-current={isActive ? "page" : undefined}
            >
              <LocalizedInline value={item.label} />
            </a>
          </li>
        );
      })
    }
    
    <li class="relative">
      <label for="language-select-desktop" class="sr-only"><LocalizedInline value={navLabel("language")} /></label>
      <div class="relative">
        <select
          id="language-select-desktop"
          class="nav-language-select nav-language-select--desktop"
          data-language-select
        >
          {languageOptions.map((opt) => (
            <option value={opt.value} selected={opt.value === "en"}>{opt.label}</option>
          ))}
        </select>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="nav-language-chevron h-4 w-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          aria-hidden="true"
        >
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </div>
    </li>
  </ul>
</nav>

<!-- Mobile Menu Button -->
<button
  id="mobile-menu-button"
  class="relative p-2 text-white/75 transition-colors hover:text-secondary-400 focus:outline-none lg:hidden"
  aria-label="Toggle Menu"
  aria-expanded="false"
>
  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
  </svg>
</button>

<!-- Mobile Menu Dropdown - Compact & Clean -->
<div
  id="mobile-menu"
  class="absolute top-full left-0 right-0 z-50 origin-top scale-y-0 transform border-t-[3px] border-t-secondary-500 bg-white shadow-[0_4px_12px_rgba(9,21,41,0.15)] transition-transform duration-200 ease-out lg:hidden"
  role="menu"
  aria-labelledby="mobile-menu-button"
>
  <!-- Navigation Links -->
  <div class="px-4 py-6">
    <div class="flex flex-col gap-2">
      {
        navItems.map((item, index) => {
          if (hasChildren(item)) {
            const subId = `mobile-sub-${index}`;
            const isActive = isTopActive(item);
            return (
              <div class="flex flex-col gap-1 mobile-nav-parent">
                <button
                  type="button"
                  class={`mobile-submenu-trigger flex w-full items-center justify-between rounded-lg border border-transparent px-4 py-3 text-left text-sm font-medium transition-colors ${
                    isActive
                      ? "border-secondary-200 bg-secondary-50 text-primary-700"
                      : "text-ink-2 hover:bg-gray-50 hover:text-primary-700"
                  }`}
                  aria-expanded="false"
                  aria-controls={subId}
                  data-submenu-id={subId}
                >
                  <LocalizedInline value={item.label} />
                  <svg class="mobile-submenu-chevron h-5 w-5 shrink-0 transition-transform duration-200" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </button>
                <div
                  id={subId}
                  class="mobile-submenu overflow-hidden transition-all duration-200 ease-out"
                  role="menu"
                  aria-hidden="true"
                >
                  <div class="ml-3 flex flex-col gap-0 border-l-2 border-[#e8e8e8] pb-2 pl-2 pt-1">
                    {item.children.map((child) => {
                      const hasGrand = child.children && child.children.length > 0;
                      if (!hasGrand) {
                        const childActive = isLinkActive(child.href);
                        return (
                          <a
                            href={child.href}
                            class={`block rounded-lg border border-transparent px-4 py-2.5 text-sm font-medium leading-snug transition-colors ${
                              childActive
                                ? "border-secondary-200 bg-secondary-50 font-semibold text-primary-700"
                                : "text-primary-700 hover:bg-gray-50"
                            }`}
                            role="menuitem"
                            aria-current={childActive ? "page" : undefined}
                          >
                            <LocalizedInline value={child.label} />
                          </a>
                        );
                      }
                      const nestedSubId = `mobile-sub-${index}-nested-${child.id}`;
                      return (
                        <div class="flex flex-col gap-0.5">
                          <button
                            type="button"
                            class="mobile-submenu-trigger flex w-full items-center justify-between rounded-lg border border-transparent px-4 py-2.5 text-left text-sm font-medium leading-snug text-primary-700 transition-colors hover:bg-gray-50"
                            aria-expanded="false"
                            aria-controls={nestedSubId}
                            data-submenu-id={nestedSubId}
                          >
                            <span class="min-w-0 flex-1 text-left">
                              <LocalizedInline value={child.label} />
                            </span>
                            <svg
                              class="mobile-submenu-chevron h-4 w-4 shrink-0"
                              xmlns="http://www.w3.org/2000/svg"
                              fill="none"
                              viewBox="0 0 24 24"
                              stroke="currentColor"
                              aria-hidden="true"
                            >
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                            </svg>
                          </button>
                          <div
                            id={nestedSubId}
                            class="mobile-submenu overflow-hidden transition-all duration-200 ease-out"
                            role="menu"
                            aria-hidden="true"
                          >
                            <div class="mb-1 ml-3 flex flex-col gap-0.5 border-l-2 border-[#e8e8e8] pb-1 pl-2 pt-0">
                              {child.href && child.href !== "#" && (
                                <a
                                  href={child.href}
                                  class={`block rounded-lg border border-transparent px-3 py-2 text-xs font-medium leading-snug transition-colors ${
                                    isLinkActive(child.href)
                                      ? "border-secondary-200 bg-secondary-50 font-semibold text-primary-700"
                                      : "text-primary-700 hover:bg-gray-50"
                                  }`}
                                  role="menuitem"
                                  aria-current={isLinkActive(child.href) ? "page" : undefined}
                                >
                                  <LocalizedInline
                                    value={{
                                      en: "Overview",
                                      "zh-Hant": "概覽",
                                      "zh-Hans": "概览",
                                    }}
                                  />
                                </a>
                              )}
                              {child.children!.map((g) => {
                                const gActive = isLinkActive(g.href);
                                const gh = g.href?.trim();
                                return gh ? (
                                  <a
                                    href={gh}
                                    class={`block rounded-lg border border-transparent px-3 py-2 text-xs font-medium leading-snug transition-colors ${
                                      gActive
                                        ? "border-secondary-200 bg-secondary-50 font-semibold text-primary-700"
                                        : "text-primary-700 hover:bg-gray-50"
                                    }`}
                                    role="menuitem"
                                    aria-current={gActive ? "page" : undefined}
                                  >
                                    <LocalizedInline value={g.label} />
                                  </a>
                                ) : (
                                  <span class="block rounded-lg px-3 py-2 text-xs font-medium leading-snug text-muted">
                                    <LocalizedInline value={g.label} />
                                  </span>
                                );
                              })}
                            </div>
                          </div>
                        </div>
                      );
                    })}
                  </div>
                </div>
              </div>
            );
          }
          const href = item.href;
          const isActive = isLinkActive(href);
          return (
            <a
              href={href}
              class={`block rounded-lg border border-transparent px-4 py-3 text-sm font-medium transition-colors ${
                isActive
                  ? "border-secondary-200 bg-secondary-50 text-primary-700"
                  : "text-ink-2 hover:bg-gray-50 hover:text-primary-700"
              }`}
              role="menuitem"
              aria-current={isActive ? "page" : undefined}
            >
              <LocalizedInline value={item.label} />
            </a>
          );
        })
      }
    </div>
    
    <div class="mt-3 border-t border-gray-100 pt-3">
      <p class="mb-2 px-4 text-xs font-semibold uppercase tracking-wide text-muted" id="mobile-lang-heading">
        <LocalizedInline value={navLabel("language")} />
      </p>
      <div class="flex flex-col gap-2 px-4" role="group" aria-labelledby="mobile-lang-heading">
        {languageOptions.map((opt) => (
          <button
            type="button"
            data-language-option={opt.value}
            class="block w-full rounded-lg border border-transparent px-4 py-3 text-left text-sm font-medium text-ink-3 transition-colors hover:bg-gray-50 hover:text-primary-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-700/30"
            aria-pressed="false"
          >
            {opt.label}
          </button>
        ))}
      </div>
    </div>
  </div>
</div>

<style>
  /* Mobile menu button animation */
  #mobile-menu-button:hover svg {
    transform: scale(1.1);
  }
  
  #mobile-menu-button svg {
    transition: transform 0.2s ease;
  }
  
  /* Mobile menu show/hide — transform alone can leave a hit target; clip + disable pointer events when closed */
  #mobile-menu {
    overflow: hidden;
  }
  #mobile-menu:not(.show) {
    pointer-events: none;
  }
  #mobile-menu.show {
    transform: scaleY(1);
    pointer-events: auto;
  }
  
  /* Smooth hover effects */
  #mobile-menu a {
    transition: all 0.15s ease;
  }
  
  /* Active state styling */
  #mobile-menu a[aria-current="page"] {
    font-weight: 600;
  }
  
  /* Mobile submenu: collapsed by default */
  .mobile-submenu {
    max-height: 0;
    opacity: 0;
  }
  
  .mobile-submenu.mobile-submenu-open {
    max-height: 20rem;
    opacity: 1;
  }
  
  .mobile-submenu-trigger[aria-expanded="true"] .mobile-submenu-chevron {
    transform: rotate(180deg);
  }

  .nav-language-select {
    appearance: none;
    -webkit-appearance: none;
    -moz-appearance: none;
    border: 1px solid transparent;
    border-radius: 0.5rem;
    background: transparent;
    color: rgba(255,255,255,0.82);
    font-weight: 500;
    line-height: 1.25rem;
    cursor: pointer;
    transition: color 0.15s ease, background-color 0.15s ease, border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .nav-language-select--desktop {
    font-size: 1rem;
    padding: 0.35rem 1.75rem 0.35rem 0.6rem;
  }

  .nav-language-select:hover {
    color: var(--orange);
    background-color: rgba(255,255,255,0.08);
    border-color: rgba(255,255,255,0.25);
  }

  .nav-language-select:focus-visible {
    outline: none;
    border-color: var(--orange);
    box-shadow: 0 0 0 2px rgba(232, 150, 31, 0.35);
  }


  /* option elements inherit OS styling — force readable text in the dropdown */
  .nav-language-select option {
    color: var(--ink);
    background-color: #fff;
  }
  .nav-language-chevron {
    position: absolute;
    right: 0.6rem;
    top: 50%;
    transform: translateY(-50%);
    color: rgba(255,255,255,0.45);
    pointer-events: none;
  }
</style>

<script>
  // @ts-nocheck — inline client script; Astro still typechecks frontmatter
  const KEY = "site_lang";
  const VALID = ["en", "zh-Hant", "zh-Hans"];

  const normalizeLang = (value) => (VALID.includes(value) ? value : "en");

  function readStoredLang() {
    try {
      const fromLs = localStorage.getItem(KEY);
      if (fromLs && VALID.includes(fromLs)) return fromLs;
    } catch {
      /* private mode / blocked */
    }
    const m = document.cookie.match(/(?:^|; )site_lang=([^;]+)/);
    if (m) {
      try {
        const v = decodeURIComponent(m[1]);
        if (VALID.includes(v)) return v;
      } catch {
        /* ignore */
      }
    }
    const fromHtml = document.documentElement.dataset.lang;
    if (fromHtml && VALID.includes(fromHtml)) return fromHtml;
    return "en";
  }

  function applyLangToDocument(lang) {
    const L = normalizeLang(lang);
    document.documentElement.lang = L;
    document.documentElement.dataset.lang = L;
    window.__siteLang = L;
  }

  function syncLanguageSelects(lang) {
    const L = normalizeLang(lang);
    document.querySelectorAll("[data-language-select]").forEach((el) => {
      if (el instanceof HTMLSelectElement) el.value = L;
    });
    document.querySelectorAll("[data-language-option]").forEach((el) => {
      if (!(el instanceof HTMLButtonElement)) return;
      const v = el.getAttribute("data-language-option");
      const isSel = v === L;
      el.setAttribute("aria-pressed", isSel ? "true" : "false");
      el.classList.toggle("border-secondary-200", isSel);
      el.classList.toggle("bg-secondary-50", isSel);
      el.classList.toggle("font-semibold", isSel);
      el.classList.toggle("text-primary-700", isSel);
      el.classList.toggle("text-ink-3", !isSel);
    });
  }

  function initLangUi() {
    const lang = normalizeLang(readStoredLang());
    applyLangToDocument(lang);
    syncLanguageSelects(lang);
  }

  initLangUi();

  // Mobile menu functionality
  document.addEventListener('DOMContentLoaded', () => {
    initLangUi();

    const languageSelects = document.querySelectorAll("[data-language-select]");

    const applyLanguage = (nextLang) => {
      const lang = normalizeLang(nextLang);
      try {
        localStorage.setItem(KEY, lang);
      } catch {
        /* ignore */
      }
      document.cookie = `site_lang=${encodeURIComponent(lang)}; Path=/; Max-Age=31536000; SameSite=Lax`;
      applyLangToDocument(lang);
      syncLanguageSelects(lang);
      window.dispatchEvent(new CustomEvent("site-lang-change", { detail: { lang } }));
    };

    languageSelects.forEach((el) => {
      if (!(el instanceof HTMLSelectElement)) return;
      el.addEventListener("change", (event) => {
        const target = event.target;
        if (target instanceof HTMLSelectElement) applyLanguage(target.value);
      });
    });

    const mobileMenuButton = document.getElementById('mobile-menu-button');
    const mobileMenu = document.getElementById('mobile-menu');
    
    let isMenuOpen = false;
    
    const collapseMobileSubmenus = () => {
      mobileMenu?.querySelectorAll(".mobile-submenu.mobile-submenu-open").forEach((el) => {
        el.classList.remove("mobile-submenu-open");
        el.setAttribute("aria-hidden", "true");
      });
      mobileMenu?.querySelectorAll('.mobile-submenu-trigger[aria-expanded="true"]').forEach((btn) => {
        btn.setAttribute("aria-expanded", "false");
      });
    };

    /** Prefer this over toggling from `isMenuOpen` — keeps DOM + state in sync if they ever drift. */
    const closeMobileMenu = () => {
      if (!mobileMenu?.classList.contains("show")) {
        isMenuOpen = false;
        return;
      }
      isMenuOpen = false;
      mobileMenu.classList.remove("show");
      mobileMenuButton?.setAttribute("aria-expanded", "false");
      collapseMobileSubmenus();
    };

    // Function to toggle mobile menu
    const toggleMobileMenu = () => {
      isMenuOpen = !isMenuOpen;
      
      if (isMenuOpen) {
        mobileMenu?.classList.add('show');
        mobileMenuButton?.setAttribute('aria-expanded', 'true');
      } else {
        mobileMenu?.classList.remove('show');
        mobileMenuButton?.setAttribute('aria-expanded', 'false');
        collapseMobileSubmenus();
      }
    };

    document.querySelectorAll("[data-language-option]").forEach((el) => {
      el.addEventListener("click", (e) => {
        e.stopPropagation();
        const v = el.getAttribute("data-language-option");
        if (!v) return;
        applyLanguage(v);
        closeMobileMenu();
      });
    });
    
    mobileMenuButton?.addEventListener('click', (e) => {
      e.stopPropagation();
      toggleMobileMenu();
    });
    
    // Close menu when clicking outside
    document.addEventListener('click', (e) => {
      const target = e.target;
      if (
        isMenuOpen &&
        mobileMenu &&
        mobileMenuButton &&
        target instanceof Node &&
        !mobileMenu.contains(target) &&
        !mobileMenuButton.contains(target)
      ) {
        toggleMobileMenu();
      }
    });
    
    // Close menu when clicking a navigation link (not a submenu trigger)
    mobileMenu?.querySelectorAll('a[href^="/"]').forEach((link) => {
      link.addEventListener('click', () => {
        if (isMenuOpen) {
          setTimeout(() => toggleMobileMenu(), 100);
        }
      });
    });
    
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isMenuOpen) {
        toggleMobileMenu();
      }
    });
    
    window.addEventListener('resize', () => {
      if (window.innerWidth >= 1024 && isMenuOpen) {
        toggleMobileMenu();
      }
    });
    
    // Mobile submenu toggle: click parent to show/hide children
    mobileMenu?.querySelectorAll('.mobile-submenu-trigger').forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const id = trigger.getAttribute('aria-controls') ?? trigger.getAttribute('data-submenu-id');
        if (!id) return;
        const sub = document.getElementById(id);
        if (!sub) return;
        const isExpanded = trigger.getAttribute('aria-expanded') === 'true';
        if (isExpanded) {
          sub.classList.remove('mobile-submenu-open');
          sub.setAttribute('aria-hidden', 'true');
          trigger.setAttribute('aria-expanded', 'false');
        } else {
          sub.classList.add('mobile-submenu-open');
          sub.setAttribute('aria-hidden', 'false');
          trigger.setAttribute('aria-expanded', 'true');
        }
      });
    });
  });
</script>