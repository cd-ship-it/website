---
import { getEntry } from "astro:content";
import { LANG_LABELS, I18N, type LocalizedText, type SiteLang, type LocaleStrings } from "../../lib/i18n";
import LocalizedInline from "../UI/LocalizedInline.astro";

type NavKey = keyof LocaleStrings["nav"];

/** Matches `src/content/config.ts` navigation collection (nested up to 3 levels). */
type NavMenuL3 = { id: string; label: LocalizedText; href: string };
type NavMenuL2 = { id: string; label: LocalizedText; href: string; children?: NavMenuL3[] };
type NavMenuTop = { id: string; label: LocalizedText; href: string; children?: NavMenuL2[] };

function navLabel(key: NavKey): LocalizedText {
  return {
    en: I18N.en.nav[key],
    "zh-Hant": I18N["zh-Hant"].nav[key],
    "zh-Hans": I18N["zh-Hans"].nav[key],
  };
}

function fallbackNavFromI18n(): NavMenuTop[] {
  const L = navLabel;
  return [
    {
      id: "about",
      label: L("about"),
      href: "/about-us",
      children: [
        { id: "aboutUs", label: L("aboutUs"), href: "/about-us" },
        { id: "staff", label: L("staff"), href: "/staff" },
      ],
    },
    { id: "ministries", label: L("ministries"), href: "/ministries" },
    { id: "sermons", label: L("sermons"), href: "/sermons" },
    { id: "events", label: L("events"), href: "/events" },
    { id: "blog", label: L("blog"), href: "/blog" },
    { id: "imNew", label: L("imNew"), href: "/im-new" },
    { id: "contact", label: L("contact"), href: "/contact" },
    { id: "giving", label: L("giving"), href: "/giving" },
  ];
}

const navEntry = await getEntry("navigation", "main-menu");
const fromFile =
  navEntry && !navEntry.data.draft && navEntry.data.items?.length ? navEntry.data.items : null;

const navItems: NavMenuTop[] = (fromFile ?? fallbackNavFromI18n()).filter(
  (item) => item.id !== "home",
);

const languageOptions: Array<{ value: SiteLang; label: string }> = [
  { value: "en", label: LANG_LABELS.en },
  { value: "zh-Hant", label: LANG_LABELS["zh-Hant"] },
  { value: "zh-Hans", label: LANG_LABELS["zh-Hans"] },
];

const currentPath = Astro.url.pathname;

function isLinkActive(href: string) {
  if (!href || href === "#") return false;
  return currentPath === href || (href !== "/" && currentPath.startsWith(href));
}

function isL3Active(l3: NavMenuL3) {
  return isLinkActive(l3.href);
}
function isL2Active(l2: NavMenuL2) {
  if (l2.children?.some(isL3Active)) return true;
  return isLinkActive(l2.href);
}
function isTopActive(item: NavMenuTop) {
  if (item.children?.length) return item.children.some(isL2Active);
  return isLinkActive(item.href);
}

function hasChildren(item: NavMenuTop): item is NavMenuTop & { children: NavMenuL2[] } {
  return Array.isArray(item.children) && item.children.length > 0;
}

/** First real URL for a parent whose own `href` may be `#`. */
function firstNavigableHref(item: NavMenuTop): string {
  if (item.href && item.href !== "#") return item.href;
  for (const l2 of item.children ?? []) {
    if (l2.href && l2.href !== "#") return l2.href;
    for (const l3 of l2.children ?? []) {
      if (l3.href && l3.href !== "#") return l3.href;
    }
  }
  return "#";
}
---

<!-- Desktop Navigation -->
<nav class="hidden lg:block">
  <ul class="flex items-center space-x-6">
    {
      navItems.map((item) => {
        if (hasChildren(item)) {
          const parentHref = firstNavigableHref(item);
          const isActive = isTopActive(item);
          return (
            <li class="relative group">
              <a
                href={parentHref}
                class={`text-base font-medium transition-colors hover:text-primary-600 flex items-center gap-0.5 ${
                  isActive ? "text-primary-600" : "text-ink"
                }`}
                aria-haspopup="true"
                aria-expanded="false"
              >
                <LocalizedInline value={item.label} />
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-0.5 opacity-70" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </a>
              <ul
                class="absolute left-0 top-full pt-1 min-w-[220px] opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 z-50 bg-white rounded-lg shadow-lg border border-gray-100 py-1"
                role="menu"
              >
                {item.children.map((child) => {
                  const childActive = isL2Active(child);
                  const hasGrand = child.children && child.children.length > 0;
                  return (
                    <li role="none" class={hasGrand ? "border-b border-gray-50 last:border-0 pb-1 last:pb-0" : ""}>
                      <a
                        href={child.href}
                        class={`block px-4 py-2 text-sm font-medium transition-colors hover:bg-primary-50 hover:text-primary-600 ${
                          childActive && !hasGrand ? "text-primary-600 bg-primary-50" : "text-ink"
                        }`}
                        role="menuitem"
                        aria-current={childActive && !hasGrand ? "page" : undefined}
                      >
                        <LocalizedInline value={child.label} />
                      </a>
                      {hasGrand && (
                        <ul class="pb-1" role="menu">
                          {child.children!.map((g) => {
                            const gActive = isL3Active(g);
                            return (
                              <li role="none">
                                <a
                                  href={g.href}
                                  class={`block pl-6 pr-4 py-1.5 text-xs font-medium transition-colors hover:bg-primary-50 hover:text-primary-600 ${
                                    gActive ? "text-primary-600 bg-primary-50" : "text-ink"
                                  }`}
                                  role="menuitem"
                                  aria-current={gActive ? "page" : undefined}
                                >
                                  <LocalizedInline value={g.label} />
                                </a>
                              </li>
                            );
                          })}
                        </ul>
                      )}
                    </li>
                  );
                })}
              </ul>
            </li>
          );
        }
        const href = item.href;
        const isActive = isLinkActive(href);
        return (
          <li>
            <a
              href={href}
              class={`text-base font-medium transition-colors hover:text-primary-600 ${
                isActive ? "text-primary-600" : "text-ink"
              }`}
              aria-current={isActive ? "page" : undefined}
            >
              <LocalizedInline value={item.label} />
            </a>
          </li>
        );
      })
    }
    
    <li>
      <label for="language-select-desktop" class="sr-only"><LocalizedInline value={navLabel("language")} /></label>
      <select
        id="language-select-desktop"
        class="text-sm border border-gray-300 rounded-md px-2 py-1 bg-white text-ink focus:outline-none focus:ring-2 focus:ring-primary-500"
        data-language-select
      >
        {languageOptions.map((opt) => (
          <option value={opt.value} selected={opt.value === "en"}>{opt.label}</option>
        ))}
      </select>
    </li>
  </ul>
</nav>

<!-- Mobile Menu Button -->
<button
  id="mobile-menu-button"
  class="lg:hidden p-2 text-ink hover:text-primary-600 focus:outline-none transition-colors relative"
  aria-label="Toggle Menu"
  aria-expanded="false"
>
  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
  </svg>
</button>

<!-- Mobile Menu Dropdown - Compact & Clean -->
<div
  id="mobile-menu"
  class="absolute top-full left-0 right-0 bg-white shadow-lg border-t border-gray-100 transform scale-y-0 origin-top transition-transform duration-200 ease-out lg:hidden z-50"
  role="menu"
  aria-labelledby="mobile-menu-button"
>
  <!-- Navigation Links -->
  <div class="px-4 py-6">
    <div class="flex flex-col gap-2">
      {
        navItems.map((item, index) => {
          if (hasChildren(item)) {
            const subId = `mobile-sub-${index}`;
            const isActive = isTopActive(item);
            return (
              <div class="flex flex-col gap-1 mobile-nav-parent">
                <button
                  type="button"
                  class={`mobile-submenu-trigger flex items-center justify-between w-full px-4 py-3 text-sm font-medium rounded-lg transition-colors text-left border border-transparent ${
                    isActive
                      ? "bg-primary-50 text-primary-600 border-primary-200"
                      : "text-ink hover:bg-cream hover:text-primary-600"
                  }`}
                  aria-expanded="false"
                  aria-controls={subId}
                  data-submenu-id={subId}
                >
                  <LocalizedInline value={item.label} />
                  <svg class="mobile-submenu-chevron h-5 w-5 shrink-0 transition-transform duration-200" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </button>
                <div
                  id={subId}
                  class="mobile-submenu overflow-hidden transition-all duration-200 ease-out"
                  role="menu"
                  aria-hidden="true"
                >
                  <div class="flex flex-col gap-1 pl-2 pt-1 pb-2 border-l-2 border-gray-200 ml-3">
                    {item.children.map((child) => {
                      const hasGrand = child.children && child.children.length > 0;
                      const l2Active = isL2Active(child);
                      if (!hasGrand) {
                        const childActive = isLinkActive(child.href);
                        return (
                          <a
                            href={child.href}
                            class={`block px-4 py-2.5 text-sm font-medium rounded-lg transition-colors ${
                              childActive
                                ? "bg-primary-50 text-primary-600 border border-primary-200"
                                : "text-ink hover:bg-cream hover:text-primary-600 border border-transparent"
                            }`}
                            role="menuitem"
                            aria-current={childActive ? "page" : undefined}
                          >
                            <LocalizedInline value={child.label} />
                          </a>
                        );
                      }
                      return (
                        <div class="flex flex-col gap-0.5">
                          <a
                            href={child.href}
                            class={`block px-4 py-2.5 text-sm font-medium rounded-lg transition-colors ${
                              isLinkActive(child.href)
                                ? "bg-primary-50 text-primary-600 border border-primary-200"
                                : l2Active
                                  ? "text-primary-600 border border-transparent"
                                  : "text-ink hover:bg-cream hover:text-primary-600 border border-transparent"
                            }`}
                            role="menuitem"
                            aria-current={isLinkActive(child.href) ? "page" : undefined}
                          >
                            <LocalizedInline value={child.label} />
                          </a>
                          <div class="flex flex-col gap-0.5 pl-3 border-l border-gray-200 ml-2 mb-1">
                            {child.children!.map((g) => {
                              const gActive = isLinkActive(g.href);
                              return (
                                <a
                                  href={g.href}
                                  class={`block px-3 py-2 text-xs font-medium rounded-lg transition-colors ${
                                    gActive
                                      ? "bg-primary-50 text-primary-600 border border-primary-200"
                                      : "text-ink hover:bg-cream hover:text-primary-600 border border-transparent"
                                  }`}
                                  role="menuitem"
                                  aria-current={gActive ? "page" : undefined}
                                >
                                  <LocalizedInline value={g.label} />
                                </a>
                              );
                            })}
                          </div>
                        </div>
                      );
                    })}
                  </div>
                </div>
              </div>
            );
          }
          const href = item.href;
          const isActive = isLinkActive(href);
          return (
            <a
              href={href}
              class={`block px-4 py-3 text-sm font-medium rounded-lg transition-colors ${
                isActive
                  ? "bg-primary-50 text-primary-600 border border-primary-200"
                  : "text-ink hover:bg-cream hover:text-primary-600 border border-transparent"
              }`}
              role="menuitem"
              aria-current={isActive ? "page" : undefined}
            >
              <LocalizedInline value={item.label} />
            </a>
          );
        })
      }
    </div>
    
    <div class="mt-3 pt-3 border-t border-gray-100">
      <label for="language-select-mobile" class="block px-4 pb-2 text-xs font-semibold uppercase tracking-wide text-muted">
        <LocalizedInline value={navLabel("language")} />
      </label>
      <div class="px-4">
        <select
          id="language-select-mobile"
          class="w-full text-sm border border-gray-300 rounded-md px-3 py-2 bg-white text-ink focus:outline-none focus:ring-2 focus:ring-primary-500"
          data-language-select
        >
          {languageOptions.map((opt) => (
            <option value={opt.value} selected={opt.value === "en"}>{opt.label}</option>
          ))}
        </select>
      </div>
    </div>
  </div>
</div>

<style>
  /* Mobile menu button animation */
  #mobile-menu-button:hover svg {
    transform: scale(1.1);
  }
  
  #mobile-menu-button svg {
    transition: transform 0.2s ease;
  }
  
  /* Mobile menu show/hide states */
  #mobile-menu.show {
    transform: scaleY(1);
  }
  
  /* Smooth hover effects */
  #mobile-menu a {
    transition: all 0.15s ease;
  }
  
  /* Active state styling */
  #mobile-menu a[aria-current="page"] {
    font-weight: 600;
  }
  
  /* Mobile submenu: collapsed by default */
  .mobile-submenu {
    max-height: 0;
    opacity: 0;
  }
  
  .mobile-submenu.mobile-submenu-open {
    max-height: 20rem;
    opacity: 1;
  }
  
  .mobile-submenu-trigger[aria-expanded="true"] .mobile-submenu-chevron {
    transform: rotate(180deg);
  }
</style>

<script>
  // @ts-nocheck — inline client script; Astro still typechecks frontmatter
  const KEY = "site_lang";
  const VALID = ["en", "zh-Hant", "zh-Hans"];

  const normalizeLang = (value) => (VALID.includes(value) ? value : "en");

  function readStoredLang() {
    try {
      const fromLs = localStorage.getItem(KEY);
      if (fromLs && VALID.includes(fromLs)) return fromLs;
    } catch {
      /* private mode / blocked */
    }
    const m = document.cookie.match(/(?:^|; )site_lang=([^;]+)/);
    if (m) {
      try {
        const v = decodeURIComponent(m[1]);
        if (VALID.includes(v)) return v;
      } catch {
        /* ignore */
      }
    }
    const fromHtml = document.documentElement.dataset.lang;
    if (fromHtml && VALID.includes(fromHtml)) return fromHtml;
    return "en";
  }

  function applyLangToDocument(lang) {
    const L = normalizeLang(lang);
    document.documentElement.lang = L;
    document.documentElement.dataset.lang = L;
    window.__siteLang = L;
  }

  function syncLanguageSelects(lang) {
    document.querySelectorAll("[data-language-select]").forEach((el) => {
      if (el instanceof HTMLSelectElement) el.value = lang;
    });
  }

  function initLangUi() {
    const lang = normalizeLang(readStoredLang());
    applyLangToDocument(lang);
    syncLanguageSelects(lang);
  }

  initLangUi();

  // Mobile menu functionality
  document.addEventListener('DOMContentLoaded', () => {
    initLangUi();

    const languageSelects = document.querySelectorAll("[data-language-select]");

    const applyLanguage = (nextLang) => {
      const lang = normalizeLang(nextLang);
      try {
        localStorage.setItem(KEY, lang);
      } catch {
        /* ignore */
      }
      document.cookie = `site_lang=${encodeURIComponent(lang)}; Path=/; Max-Age=31536000; SameSite=Lax`;
      applyLangToDocument(lang);
      syncLanguageSelects(lang);
      window.dispatchEvent(new CustomEvent("site-lang-change", { detail: { lang } }));
    };

    languageSelects.forEach((el) => {
      if (!(el instanceof HTMLSelectElement)) return;
      el.addEventListener("change", (event) => {
        const target = event.target;
        if (target instanceof HTMLSelectElement) applyLanguage(target.value);
      });
    });

    const mobileMenuButton = document.getElementById('mobile-menu-button');
    const mobileMenu = document.getElementById('mobile-menu');
    
    let isMenuOpen = false;
    
    // Function to toggle mobile menu
    const toggleMobileMenu = () => {
      isMenuOpen = !isMenuOpen;
      
      if (isMenuOpen) {
        mobileMenu?.classList.add('show');
        mobileMenuButton?.setAttribute('aria-expanded', 'true');
      } else {
        mobileMenu?.classList.remove('show');
        mobileMenuButton?.setAttribute('aria-expanded', 'false');
        // Close any open submenus
        mobileMenu?.querySelectorAll('.mobile-submenu.mobile-submenu-open').forEach((el) => {
          el.classList.remove('mobile-submenu-open');
          el.setAttribute('aria-hidden', 'true');
        });
        mobileMenu?.querySelectorAll('.mobile-submenu-trigger[aria-expanded="true"]').forEach((btn) => {
          btn.setAttribute('aria-expanded', 'false');
        });
      }
    };
    
    mobileMenuButton?.addEventListener('click', (e) => {
      e.stopPropagation();
      toggleMobileMenu();
    });
    
    // Close menu when clicking outside
    document.addEventListener('click', (e) => {
      const target = e.target;
      if (
        isMenuOpen &&
        mobileMenu &&
        mobileMenuButton &&
        target instanceof Node &&
        !mobileMenu.contains(target) &&
        !mobileMenuButton.contains(target)
      ) {
        toggleMobileMenu();
      }
    });
    
    // Close menu when clicking a navigation link (not a submenu trigger)
    mobileMenu?.querySelectorAll('a[href^="/"]').forEach((link) => {
      link.addEventListener('click', () => {
        if (isMenuOpen) {
          setTimeout(() => toggleMobileMenu(), 100);
        }
      });
    });
    
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isMenuOpen) {
        toggleMobileMenu();
      }
    });
    
    window.addEventListener('resize', () => {
      if (window.innerWidth >= 1024 && isMenuOpen) {
        toggleMobileMenu();
      }
    });
    
    // Mobile submenu toggle: click parent to show/hide children
    mobileMenu?.querySelectorAll('.mobile-submenu-trigger').forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const id = trigger.getAttribute('aria-controls') ?? trigger.getAttribute('data-submenu-id');
        if (!id) return;
        const sub = document.getElementById(id);
        if (!sub) return;
        const isExpanded = trigger.getAttribute('aria-expanded') === 'true';
        if (isExpanded) {
          sub.classList.remove('mobile-submenu-open');
          sub.setAttribute('aria-hidden', 'true');
          trigger.setAttribute('aria-expanded', 'false');
        } else {
          sub.classList.add('mobile-submenu-open');
          sub.setAttribute('aria-hidden', 'false');
          trigger.setAttribute('aria-expanded', 'true');
        }
      });
    });
  });
</script>