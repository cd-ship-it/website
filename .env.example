# Set to "production" on your hosting platform to deploy under /v2
# Leave as "development" (or unset) for local dev at localhost:4321/
PLATFORM=development

PUBLIC_WORDPRESS_URL="https://your-wordpress-site.com"

# Google Analytics 4 Measurement ID (find it in GA4 → Admin → Data Streams → your web stream)
# PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Optional: contact form POST URL (defaults to /api/contact.php on your SiteGround domain)
# PUBLIC_CONTACT_FORM_URL="/api/contact.php"

# Google reCAPTCHA v3 — public site key (client). Secret key goes in public/api/contact.php.
# Get a v3 key pair at https://www.google.com/recaptcha/admin
# PUBLIC_RECAPTCHA_SITE_KEY=""

# Navigation: omit or `default` = standard desktop + mobile menu. `alt` = Events/Sermons/Giving centered + hamburger (all breakpoints).
# PUBLIC_NAVIGATION_VARIANT=alt

# Home hero: set to `true` to disable the looping background video and use the static image only.
# PUBLIC_HERO_VIDEO_DISABLED=true

# Home page: set to `true` or `1` to disable GSAP entrance animations (hero + scroll sections).
# PUBLIC_HOME_GSAP_DISABLED=true

